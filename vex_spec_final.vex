// ──────────────────────────────────────────────────────────────────────────────
// SECTION 28 — STANDARD LIBRARY CORE
// ──────────────────────────────────────────────────────────────────────────────

import std::time
import std::process
import std::json

// ── std::io — full API ────────────────────────────────────────────────────────

fn ioDemo() {
    // Basic output
    io::println("hello")             // stdout + newline
    io::print("no newline")         // stdout, no newline
    io::printErr("to stderr")       // stderr + newline
    io::flush()                      // flush stdout buffer

    // Named handles
    let out := io::stdout()
    out.writeLn("via Writer handle")
    out.flush()

    let err := io::stderr()
    err.writeLn("error message")

    // stdin reading
    let line := io::readLine()       // str? — null on EOF
    if let l = line {
        io::println(f"you typed: {l}")
    }

    let all := io::readAll()         // read everything from stdin
    io::println(f"total stdin bytes: {all.len()}")
}

// ── std::math — full API ──────────────────────────────────────────────────────

fn mathDemo() {
    // Constants
    io::println(f"PI  = {math::PI}")
    io::println(f"E   = {math::E}")
    io::println(f"TAU = {math::TAU}")

    // Basic functions
    io::println(math::sqrt(2.0))        // 1.4142...
    io::println(math::cbrt(27.0))       // 3.0
    io::println(math::abs(-42.0))       // 42.0
    io::println(math::abs(-42))         // 42 (int overload)
    io::println(math::floor(3.7))       // 3.0
    io::println(math::ceil(3.2))        // 4.0
    io::println(math::round(2.5))       // 2.0 (banker's rounding: half-to-even)
    io::println(math::round(3.5))       // 4.0
    io::println(math::trunc(-3.9))      // -3.0

    // Trig
    io::println(math::sin(math::PI / 2.0))   // 1.0
    io::println(math::cos(0.0))              // 1.0
    io::println(math::atan2(1.0, 1.0))       // PI/4

    // Exp / log
    io::println(math::exp(1.0))         // E
    io::println(math::log(math::E))     // 1.0
    io::println(math::log2(8.0))        // 3.0
    io::println(math::log10(1000.0))    // 3.0
    io::println(math::pow(2.0, 10.0))   // 1024.0

    // Min / max / clamp
    io::println(math::min(3, 7))        // 3
    io::println(math::max(3.0, 7.0))    // 7.0
    io::println(math::clamp(15, 0, 10)) // 10

    // Number theory
    io::println(math::gcd(48, 36))      // 12
    io::println(math::lcm(4, 6))        // 12

    // Special value checks
    io::println(math::isNaN(math::NAN))         // true
    io::println(math::isInf(math::INF))         // true
    io::println(math::isFinite(42.0))           // true
    io::println(math::hypot(3.0, 4.0))          // 5.0
    io::println(math::lerp(0.0, 10.0, 0.3))     // 3.0
}

// ── std::mem — full API ───────────────────────────────────────────────────────

fn memDemo() {
    // Owned heap
    var h: ^int = mem::new(42)
    io::println(*h)              // 42
    *h = 99
    io::println(*h)              // 99
    // h freed at scope exit

    // Shared heap (ARC)
    var s: ~str = mem::share("shared text")
    var s2 := s.clone()          // refcount = 2
    io::println(*s == *s2)       // true

    // Convert owned to shared
    var o: ^str = mem::new("to be shared")
    var shared: ~str = mem::intoShared(move o)   // o is now invalid

    // Raw allocation (unsafe)
    unsafe {
        let raw: *byte = mem::alloc(256)
        mem::zero(raw, 256)
        raw[0] = 0xFF
        io::println(raw[0])     // 255
        mem::free(raw)
    }

    // Arena: fast scoped allocation
    {
        let arena := mem::Arena(4096)
        unsafe {
            let a: *int64 = arena.alloc<int64>()
            let b: *float64 = arena.alloc<float64>()
            *a = 123
            *b = 4.56
            io::println(f"arena values: {*a} {*b}")
        }
        // arena freed here — one O(1) deallocation for everything inside
    }

    // mem::asBytes — view struct as raw bytes
    struct Header { magic: uint32, version: uint16, flags: uint16 }
    let hdr := Header { magic: 0xDEADBEEF, version: 1, flags: 0 }
    let bytes := mem::asBytes(hdr)  // []byte view, 8 bytes
    io::println(f"header bytes: {bytes.len()}")
}

// ── std::time — full API ──────────────────────────────────────────────────────

fn timeDemo() {
    // Instant — monotonic clock
    let start := time::now()
    thread::sleep(10ms)
    let elapsed := start.elapsed()
    io::println(f"elapsed: {elapsed.totalMs()}ms")

    // Instant arithmetic
    let future := start + 5s
    let diff    := future - start
    io::println(f"diff: {diff.totalSecs():.1f}s")

    // Duration construction
    let d1 := time::Duration.fromMs(1500)
    let d2 := 2s                        // duration literal
    let d3 := d1 + d2                   // 3500ms
    let d4 := d3 * 2.0                  // 7000ms
    io::println(f"d4 = {d4.totalMs()}ms")

    // Format / parse
    let formatted := time::format(start, "%Y-%m-%d %H:%M:%S")
    io::println(formatted)

    match time::parse("2024-01-15 09:30:00", "%Y-%m-%d %H:%M:%S") {
        Ok(t)  => io::println(f"parsed: {time::format(t, \"%Y\")}")
        Err(e) => io::println(f"parse error: {e}")
    }
}

// ── std::process — full API ───────────────────────────────────────────────────

fn processDemo() {
    // Command-line arguments
    let args := process::args()
    io::println(f"program: {args[0]}")
    for i, arg in args { io::println(f"arg[{i}] = {arg}") }

    // Environment variables
    let home := process::env("HOME") ?? "/tmp"
    io::println(f"HOME = {home}")
    process::setEnv("MY_VAR", "hello")
    io::println(process::env("MY_VAR") ?? "not set")

    // Run child process
    match process::exec("ls", ["-la", "/tmp"]) {
        Ok(status) => io::println(f"exit code: {status.code}")
        Err(e)     => io::println(f"exec failed: {e}")
    }

    // process::exit terminates immediately — deinit() does NOT run
    // process::exit(0)
}

// ── std::json — full API ──────────────────────────────────────────────────────

struct Person { name: str, age: int, email: str? }

fn jsonDemo() {
    // marshal: struct → JSON string
    let p := Person { name: "Alice", age: 30, email: "alice@example.com" }
    match json::marshal(p) {
        Ok(s)  => io::println(s)
        Err(e) => io::println(f"marshal error: {e}")
    }

    // unmarshal: JSON string → struct
    let raw := "{\"name\":\"Bob\",\"age\":25,\"email\":null}"
    match json::unmarshal<Person>(raw) {
        Ok(person) => io::println(f"name={person.name} age={person.age}")
        Err(e)     => io::println(f"unmarshal error: {e}")
    }

    // parse: JSON → JsonValue (dynamic)
    match json::parse(raw) {
        Ok(v) => match v {
            json::JsonValue.Object(obj) => {
                let name := obj["name"]
                match name {
                    json::JsonValue.Str(s) => io::println(f"name = {s}")
                    _                      => io::println("unexpected type")
                }
            }
            _ => io::println("expected object")
        }
        Err(e) => io::println(f"parse error: {e}")
    }

    // stringify: JsonValue → string
    let arr := json::JsonValue.Array([
        json::JsonValue.Int(1),
        json::JsonValue.Str("hello"),
        json::JsonValue.Bool(true),
    ])
    io::println(json::stringify(arr, pretty: false))    // [1,"hello",true]
    io::println(json::stringify(arr, pretty: true))     // formatted
}

// ── std::collections — full API ───────────────────────────────────────────────

fn collectionsFullDemo() {
    // Queue (FIFO)
    var q: collections::Queue<int> = collections::Queue()
    q.push(1); q.push(2); q.push(3)
    io::println(q.peek() ?? -1)     // 1 (front, not removed)
    io::println(q.pop()  ?? -1)     // 1 (removed)
    io::println(q.len())            // 2

    // Stack (LIFO)
    var s: collections::Stack<str> = collections::Stack()
    s.push("a"); s.push("b"); s.push("c")
    io::println(s.pop() ?? "")      // "c"
    io::println(s.peek() ?? "")     // "b"

    // Deque (double-ended)
    var d: collections::Deque<int> = collections::Deque()
    d.pushFront(1); d.pushBack(2); d.pushFront(0)
    io::println(d.popFront() ?? -1)   // 0
    io::println(d.popBack()  ?? -1)   // 2

    // PriorityQueue (min-heap)
    var pq: collections::PriorityQueue<int> = collections::PriorityQueue()
    pq.push(5); pq.push(1); pq.push(3); pq.push(2)
    io::println(pq.pop() ?? -1)    // 1 (smallest)
    io::println(pq.pop() ?? -1)    // 2

    // Max-heap via custom comparator
    var pqMax: collections::PriorityQueue<int> = collections::PriorityQueue(|a, b| -> b - a)
    pqMax.push(5); pqMax.push(1); pqMax.push(3)
    io::println(pqMax.pop() ?? -1)  // 5 (largest)

    // OrderedMap (insertion-order iteration — COL3)
    var om: collections::OrderedMap<str, int> = collections::OrderedMap()
    om.set("banana", 2); om.set("apple", 1); om.set("cherry", 3)
    for k, v in om {
        io::println(f"{k}: {v}")    // banana, apple, cherry (insertion order)
    }
    io::println(om.get("apple") ?? 0)   // 1

    // SortedSet (ascending-order iteration — COL4)
    var ss: collections::SortedSet<int> = collections::SortedSet()
    ss.add(5); ss.add(1); ss.add(3); ss.add(2); ss.add(4)
    for v in ss {
        io::print(f"{v} ")          // 1 2 3 4 5 (ascending)
    }
    io::println(f"min={ss.min() ?? 0} max={ss.max() ?? 0}")
}

// ── std::crypto — full API ────────────────────────────────────────────────────

import std::crypto

fn cryptoDemo() {
    let data := "hello world".bytes()

    // Hashing
    let sha256hash := crypto::sha256(data)
    let sha512hash := crypto::sha512(data)
    let blake3hash := crypto::blake3(data)
    io::println(f"sha256: {sha256hash.len()} bytes")  // 32
    io::println(f"sha512: {sha512hash.len()} bytes")  // 64
    io::println(f"blake3: {blake3hash.len()} bytes")  // 32

    // HMAC
    let key  := "secret-key".bytes()
    let hmac := crypto::hmacSha256(key, data)
    io::println(f"hmac: {hmac.len()} bytes")           // 32

    // Secure random bytes
    let rng := crypto::randomBytes(32)
    io::println(f"random: {rng.len()} bytes")

    // Constant-time comparison (side-channel safe)
    let match_ := crypto::constantTimeEq(sha256hash, sha256hash)
    io::println(f"match: {match_}")   // true

    // AES-256-GCM encryption
    let aesKey: [32]byte = crypto::randomBytes(32)  // as [32]byte
    let nonce:  [12]byte = crypto::randomBytes(12)  // as [12]byte
    let aes := crypto::Aes256Gcm(aesKey)

    let plaintext  := "secret message".bytes()
    let ciphertext := aes.encrypt(nonce, plaintext)
    io::println(f"encrypted: {ciphertext.len()} bytes")

    match aes.decrypt(nonce, ciphertext) {
        Ok(decrypted) => io::println(str(decrypted) ?? "invalid utf8")
        Err(e)        => io::println(f"decrypt failed: {e}")
    }
}