// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║           VEX LANGUAGE — FINAL COMPLETE RULES & COMPILER REFERENCE         ║
// ║  Every rule is unambiguous. Every symbol has exactly one meaning.           ║
// ║  Supersedes all prior versions. All gaps resolved. Build system updated.    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝
//
//  This file is the single authoritative specification for the Vex language.
//  It merges and resolves all content from v2.0 and v3.0. Nothing is referenced
//  externally — everything is written out in full here.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 1 — SYMBOL DISAMBIGUATION TABLE
// ═══════════════════════════════════════════════════════════════════════════════
//
//  This is the most important table for compiler writers.
//  Every symbol has EXACTLY ONE meaning in its context. No ambiguity.
//
//  Symbol      Meaning                          Example
//  ──────      ──────────────────────────────── ─────────────────────────────
//  <T>         generic type parameter           fn f<T>(x: T) -> T
//  *T          raw pointer type                 var p: *int
//  *x          dereference pointer              *p = 42
//  &x          take address of value            let r := &x
//  &T          borrow reference type            fn f(x: &int)
//  &mut T      mutable borrow type              fn f(x: &mut int)
//  ^T          owned heap pointer type          var h: ^str
//  ~T          shared (ref-counted) ptr type    var s: ~str
//  T?          nullable type                    var n: int?
//  x?          error propagate (suffix op)      let v := fn()?
//  x?.m()      safe call on nullable            x?.toString()
//  x ?? y      null coalesce                    x ?? "default"
//  :=          infer-and-assign                 var x := 42
//  =>          match arm separator              case 1 => "one"
//  ->          fn return type / lambda body     fn f()->int   |x|->x
//  ::          module path separator ONLY — used for module access after import.
//                import std::io      → std/io.vex or std/io.vxl
//                io::println("hi")   → fn println inside module io
//                import std::io { println, print } → selective import syntax
//                Last segment = always a .vex/.vxl filename (never a fn/type/const)
//                import std::io::println ← ERROR: no println.vex exists
//                NEVER for static methods, enum variants, or constructors
//                NEVER used between non-module identifiers
//  mod         reserved keyword — accesses current file's module-level scope.
//                mod.x    → module-level variable x  (when shadowed by local or field)
//                mod.f()  → module-level function f  (when shadowed)
//                Cannot be used as identifier, variable, parameter, or import alias.
//                Parallel to self (instance scope) and super (parent class scope).
//  |>          pipe operator                    x |> f
//  ..          exclusive range                  0..10 = [0,9]
//  ..=         inclusive range                  0..=10 = [0,10]
//  ...         variadic param / spread          fn f(x:...int) / [...a, b]
//  ..          struct fill remaining fields     { x: 1, .. }  (only in struct literal)
//  _           discard / wildcard               let _ = f()  /  match x { _ => }
//  @           decorator prefix                 @inline fn f()
//  #           compile directive                #if OS == "linux"
//  |           lambda parameter delimiter       |x, y| -> x+y  (only before ->)
//  |           set union operator               setA | setB
//  |           match OR pattern                 1 | 2 | 3 =>
//  &           set intersection                 setA & setB
//  &           bitwise AND                      a & b
//  -           set difference (on sets)         setA - setB
//  -           arithmetic minus                 a - b
//  {}T         set type                         var s: {}str
//  {}          empty set / struct block         {} (context determines which)
//  [N]T        fixed-size array type            var a: [5]int
//  []T         dynamic list type                var l: []int
//  [K:V]       map type                         var m: [str:int]
//  [x,y,z]     array/list literal               [1, 2, 3]
//  [k:v,..]    map literal                      ["a": 1, "b": 2]
//  (A,B,C)     tuple type                       var t: (int, str)
//  (a,b,c)     tuple literal                    (1, "hi", true)
//  `...`       raw multiline string             `SELECT * FROM x`
//  f"..."      interpolated string              f"x={x}"
//  r"..."      raw string (no escapes)          r"\n is literal"
//
//  DISAMBIGUATION RULES FOR COMPILER:
//    * before type       → pointer type:    var p: *int
//    * before expr       → dereference:     *p = 42
//    & before type       → borrow type:     fn f(x: &int)
//    & before expr       → take address:    let r := &x
//    & between exprs     → bitwise AND:     a & b
//    & between sets      → set intersect:   setA & setB
//    - between exprs     → subtract:        a - b
//    - between sets      → set difference:  setA - setB
//    | around idents     → lambda params:   |x, y| -> ...  (only valid before ->)
//    | between patterns  → match OR:        1 | 2 => ...   (only in match arm)
//    | between exprs     → bitwise OR:      a | b
//    { }                 → struct literal if preceded by type name or field names
//    { }                 → block if contains statements
//    {}T                 → set type (empty braces BEFORE type)
//    [N]T                → N is comptime integer → fixed array
//    []T                 → no N → dynamic list
//    <T>                 → after fn/struct/class/enum name → generic type parameter
//    'c'                 → single quotes around one character → char literal

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 2 — OPERATOR PRECEDENCE & DISAMBIGUATION
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE SYM1:  :: has HIGHER precedence than . (:: binds tighter).
//             This means:  math::Vec.create()
//             parses as:   (math::Vec).create()
//             NOT as:      math::(Vec.create())
//             The compiler reads all :: segments first to resolve the module+type,
//             then applies . to access a member of the resolved type/value.
//
// RULE SYM2:  A :: chain is resolved LEFT-TO-RIGHT as a module path.
//             Each segment except the last must be a module directory or module name.
//             The last segment must be a module file name (.vex or .vxl).
//             After :: resolves the module, . takes over for members.
//
//             Example parse steps for  io::println("hi"):
//               Step 1: io  = module (found io.vex or io.vxl)
//               Step 2: println = pub fn inside module io
//               Result: call to fn println with arg "hi"
//
//             Example parse steps for  shapes::Circle.origin():
//               Step 1: shapes = module (found shapes.vex)
//               Step 2: Circle = pub struct inside module shapes
//               Step 3: .origin() = static method on struct Circle
//               Result: call to static fn origin of struct Circle
//
// RULE SYM3:  . after :: always means: member access on the item named by the
//             last :: segment. The item can be a struct, class, enum, or const.
//             It is NEVER another module path step — use :: for that.
//
// RULE SYM4:  You cannot mix :: and . arbitrarily.
//             Legal:    module::Type.staticMethod()
//             Legal:    module::Type.EnumVariant
//             Legal:    module::constant
//             ILLEGAL:  module.Type::method()   ← ERROR: . before :: is forbidden
//             ILLEGAL:  module::fn.something()  ← ERROR: fn is not a type
//
// COMPLETE PRECEDENCE TABLE:
//
//  Level  Operators                  Associativity   Notes
//  ─────  ─────────────────────────  ─────────────   ──────────────────────
//  15     ::                         left            module path (highest precedence)
//  14     () [] . ++ --              left            postfix (. after :: resolves)
//  13     ! ~ - * & ++ -- move       right           prefix unary
//  12     **                         right           power (right-associative)
//  11     * / %                      left
//  10     + -                        left
//  9      << >> >>>                  left            bitwise shift
//  8      < > <= >= is as as?        left            comparison and type ops
//  7      == !=                      left
//  6      &                          left            bitwise AND
//  5      ^                          left            bitwise XOR
//  4      |                          left            bitwise OR
//  3      && (and)                   left            logical AND (short-circuit)
//  2      || (or)                    left            logical OR  (short-circuit)
//  1      ??                         left            null coalesce
//  0      |>                         left            pipe
//  -1     ? (error propagate)        postfix         lowest — wraps entire expr
//  -2     = += -= etc.               right           assignment (lowest)
//
//  KEY RULE: :: is at level 15, . is at level 14.
//  Therefore :: always resolves BEFORE . in any expression.
//  math::Vec.create() = (math::Vec).create() — always, no exceptions.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 3 — LEXICAL RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// WHITESPACE:
//   Spaces, tabs, newlines are all whitespace. Ignored except inside strings.
//   Newlines do NOT act as statement terminators.
//   Statements are terminated by:
//     - end of block `}`
//     - explicit `;` (optional, allowed for style)
//     - logical line completeness (compiler knows expression is complete)
//
// COMMENTS:
//   // single-line comment
//   /* multi-line comment */
//   /// doc comment (used by `vex doc` tool)
//
// IDENTIFIERS:
//   [a-zA-Z_][a-zA-Z0-9_]*
//   Case-sensitive.
//   CamelCase for types (structs, classes, enums, interfaces, traits)
//   camelCase or snake_case for variables, functions
//   UPPER_SNAKE for constants
//   _prefix for private/internal by convention
//   T U R Key Value for generic type params (used inside <> angle brackets)
//
// KEYWORDS (reserved — cannot be used as identifiers):
//   var let const fn async await yield
//   if elif else match
//   for while do loop in step
//   skip stop return
//   struct class enum union trait interface impl
//   bitfield sealed abstract
//   pub priv prot internal
//   self super Self
//   init deinit
//   static prop op
//   true false null
//   and or not          (alternative to && || ! — both accepted)
//   move copy
//   unsafe extern
//   import type distinct
//   comptime defer use
//   try catch panic assert assertEq
//   select timeout
//   asm inline
//   where
//
// INTEGER LITERAL TOKENS:
//   [0-9][0-9_]*               decimal        42   1_000_000
//   0x[0-9a-fA-F][0-9a-fA-F_]* hex           0xFF  0xFF_00
//   0b[01][01_]*               binary         0b1010  0b1010_1100
//   0o[0-7][0-7_]*             octal          0o755
//   suffix: L=int64  u=uint  u8=uint8  u16=uint16  u32=uint32  u64=uint64
//           i8=int8  i16=int16  i32=int32  i64=int64
//
// FLOAT LITERAL TOKENS:
//   [0-9][0-9_]*\.[0-9][0-9_]*([eE][+-]?[0-9]+)?
//   suffix: f=float32  (no suffix = float64)
//
// COMPOUND OPERATOR TOKENS:
//   **   power            2 ** 10
//   **=  power-assign     x **= 2
//   ...  spread/variadic  [...a, ...b]  fn f(x: ...int)
//   ..   exclusive range  0..10
//   ..=  inclusive range  0..=10
//   ::   module path      io::println
//   :=   infer-assign     var x := 42
//   ->   return type      fn f() -> int
//   =>   match arm        1 => "one"
//   |>   pipe             x |> f
//   ??   null coalesce    x ?? 0
//   ?.   safe call        x?.method()
//   &&   logical AND      a && b
//   ||   logical OR       a || b
//   !=   not equal        a != b
//   ==   equal            a == b
//   <=   less-equal       a <= b
//   >=   greater-equal    a >= b
//   <<   left shift       a << 2
//   >>   right shift      a >> 1
//   >>> unsigned right    a >>> 1
//   ++   increment        x++  ++x
//   --   decrement        x--  --x
//
// DURATION LITERAL TOKENS (suffix on integer literal):
//   ms   milliseconds    1000ms
//   s    seconds         5s
//   us   microseconds    500us
//   ns   nanoseconds     100ns
//   → Type: Duration (from std::time)
//
// STRING LITERAL TOKENS:
//   "..."   regular string (escape sequences: \n \t \r \\ \" \0 \u{XXXXXX})
//   r"..."  raw string (no escapes — backslash is literal)
//   f"..."  interpolated string ({expr} expanded, {expr:fmt} with format spec)
//   `...`   multiline raw string (preserves indentation, strips common indent)
//
// CHAR LITERAL TOKENS:
//   'c'     single char (escape sequences same as string: '\n' '\t' etc.)
//   '\u{XXXXXX}'  Unicode codepoint




// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER E — FORMAT STRING SPECIFIERS
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — paste into Chapter 3 (Lexical Rules) after the f"..." line,
// or as a standalone new CHAPTER 3-A — FORMAT STRING SPECIFIERS
// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 3-A — FORMAT STRING SPECIFIERS
// ═══════════════════════════════════════════════════════════════════════════════
//
//  Syntax inside f"...":   {expr}          basic interpolation
//                           {expr:spec}    with format specifier
//                           {expr!conv}    with conversion before formatting
//
// ── E.1  CONVERSION FLAGS (!conv) ────────────────────────────────────────────
//
// RULE FMT1:  CONVERSION (applied before specifier):
//   {x!s}   → call x.toString() before formatting    (force string conversion)
//   {x!r}   → call x.toRepr()   before formatting    (debug/repr form)
//   {x!d}   → call x.toDisplay() before formatting   (same as !s for most types)
//   Conversion is applied first, then the specifier (if any) is applied to the result.
//
// ── E.2  FORMAT SPECIFIER SYNTAX ─────────────────────────────────────────────
//
// RULE FMT2:  SPECIFIER SYNTAX (all fields optional):
//   [[fill]align][sign][#][0][width][grouping][.precision][type]
//
//   fill     = any single character used as fill character (default: space)
//   align    = < (left)  > (right)  ^ (center)  = (sign-aware pad for numbers)
//   sign     = + (always show sign)  - (only show minus, default)  space (space for positive)
//   #        = alternate form (0x prefix for hex, 0b for binary, 0o for octal)
//   0        = zero-pad (equivalent to fill='0' align='=')
//   width    = minimum field width (integer, or {varName} for dynamic width)
//   grouping = _ (underscore separator)  , (comma separator)  (for numbers only)
//   .prec    = precision: decimal places for floats; max chars for strings
//   type     = d  i  b  o  x  X  e  E  f  g  G  s  c  p  (see table below)
//
// RULE FMT3:  TYPE SPECIFIERS:
//
//   Type   Applies to       Output
//   ────   ──────────────   ─────────────────────────────────────────────────
//   d      int / uint       decimal integer (default for ints)
//   i      int              same as d (alias)
//   b      int / uint       binary  (with #: "0b" prefix)
//   o      int / uint       octal   (with #: "0o" prefix)
//   x      int / uint       hex lowercase  (with #: "0x" prefix)
//   X      int / uint       hex uppercase  (with #: "0X" prefix)
//   e      float            scientific notation lowercase  1.23e+04
//   E      float            scientific notation uppercase  1.23E+04
//   f      float            fixed-point decimal  (default for floats)
//   g      float            shortest of e or f (trailing zeros removed)
//   G      float            shortest of E or F (trailing zeros removed)
//   s      str              string (default for str)
//   c      char / int       single character (int → Unicode codepoint)
//   p      *T / ^T / ~T     pointer address as hex  0x7fff...
//   %      float            multiply by 100, append %  (0.5 → "50%")
//
// RULE FMT4:  COMPLETE EXAMPLES:
//
//   Expression              Result             Explanation
//   ─────────────────────   ────────────────   ────────────────────────────────
//   f"{42}"                 "42"               default int format
//   f"{42:d}"               "42"               explicit decimal
//   f"{42:08d}"             "00000042"         zero-pad to width 8
//   f"{42:>10d}"            "        42"       right-align in width 10
//   f"{42:<10d}"            "42        "       left-align  in width 10
//   f"{42:^10d}"            "    42    "       center in width 10
//   f"{42:+d}"              "+42"              always show sign
//   f"{255:#x}"             "0xff"             hex with prefix
//   f"{255:#X}"             "0XFF"             hex uppercase with prefix
//   f"{255:#b}"             "0b11111111"       binary with prefix
//   f"{255:#o}"             "0o377"            octal with prefix
//   f"{1000000:_d}"         "1_000_000"        underscore grouping
//   f"{1000000:,d}"         "1,000,000"        comma grouping
//   f"{3.14159:.2f}"        "3.14"             2 decimal places
//   f"{3.14159:.4f}"        "3.1416"           4 decimal places (rounds)
//   f"{3.14159:10.2f}"      "      3.14"       width 10, 2 decimal places
//   f"{3.14159:010.2f}"     "0000003.14"       zero-pad, width 10, 2 dec
//   f"{3.14159:e}"          "3.14159e+00"      scientific notation
//   f"{3.14159:.2e}"        "3.14e+00"         sci with 2 decimal places
//   f"{3.14159:g}"          "3.14159"          shortest representation
//   f"{0.5:%}"              "50%"              percentage
//   f"{'hello':>10s}"       "     hello"       right-align string
//   f"{'hello':<10s}"       "hello     "       left-align string
//   f"{'hello':^10s}"       "  hello   "       center string
//   f"{'hello':.3s}"        "hel"              truncate string to 3 chars
//   f"{'hello':*^10s}"      "**hello***"       center with * fill
//   f"{n:{width}.{prec}f}"  dynamic            dynamic width and precision
//
// RULE FMT5:  DYNAMIC WIDTH AND PRECISION
//   Width and precision can be variables: {expr:{widthExpr}.{precExpr}type}
//   Both widthExpr and precExpr must evaluate to non-negative int at runtime.
//   Example: f"{pi:{totalWidth}.{decimalPlaces}f}"
//
// RULE FMT6:  NESTED BRACES IN f-STRINGS
//   {{ and }} are literal { and } characters in the output.
//   f"{{ and }}"  →  "{ and }"
//
// RULE FMT7:  MULTILINE f-STRINGS
//   f"..." can span multiple lines. Newlines inside the string are preserved.
//   Expressions inside {} may NOT span multiple lines (no newline inside {}).
//
// RULE FMT8:  op str() AND DISPLAY
//   When {x} is formatted with no specifier:
//     If x has op str() → calls that.
//     If x is a primitive (int, float, bool, char) → built-in formatter.
//     If x implements Display trait → calls display().
//     Otherwise → COMPILE ERROR: type has no string representation.
//
// RULE FMT9:  @derive(Display) GENERATES:
//   op str() → "{TypeName}(field1={self.field1}, field2={self.field2})"
//   for structs/enums. Field order = declaration order.
//
// RULE FMT10: RAW STRINGS r"..." DO NOT INTERPOLATE.
//   f"..." → interpolated.  r"..." → no interpolation, no escape sequences.
//   rf"..." or fr"..." → NOT valid. Use f"..." with r"..." via variable if needed.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 4 — VISIBILITY RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE VIS1:  DEFAULT VISIBILITY TABLE — applies when no keyword is written.
//
//   Context                         Default     Notes
//   ─────────────────────────────   ─────────   ──────────────────────────────
//   Module-level fn                 pub         Callable from any importing module
//   Module-level struct             pub         Type usable from any module
//   Module-level class              pub         Type usable from any module
//   Module-level enum               pub         Type usable from any module
//   Module-level trait/interface    pub         Usable from any module
//   Module-level const              pub         Visible from any module
//   Module-level type alias         pub         Visible from any module
//   Module-level var (global)       priv        Mutable global state is private
//   struct field                    pub         Read/write from outside module
//   class field                     priv        Encapsulated by default
//   class method                    pub         Callable from outside
//   struct method                   pub         Callable from outside
//   enum variant                    pub always  Variants are always public
//   trait method (abstract)         pub always  Must be implementable by others
//   trait method (default impl)     pub always  Can be called on any implementor
//   impl block method               follows fn default (pub)
//
// RULE VIS2:  THE FOUR VISIBILITY MODIFIERS (explicit):
//
//   Keyword     Visible to
//   ─────────   ────────────────────────────────────────────────────────────
//   pub         Any code in any module (no restriction)
//   priv        Only this file (the .vex file where it is declared)
//   internal    All files in the same project directory (not subdirectories)
//   prot        This class AND subclasses only (classes only, not structs)
//
// RULE VIS3:  `prot` is ONLY valid on class fields and methods.
//             Using `prot` on a struct, fn, or module-level item = COMPILE ERROR.
//
// RULE VIS4:  Visibility applies to the DECLARATION, not individual uses.
//
// RULE VIS5:  Example — a complete class showing all visibility modifiers:
//
//   class BankAccount {
//       priv balance: float64           // only this file can read/write
//       prot accountId: str             // this class + subclasses
//       internal auditLog: []str        // all files in same directory
//       pub owner: str                  // anyone
//
//       pub fn deposit(amount: float64) { self.balance += amount }
//       priv fn validatePin(pin: str) -> bool { ... }
//       prot fn getAccountId() -> str = self.accountId
//       internal fn writeAudit(msg: str) { self.auditLog.append(msg) }
//   }

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 5 — STATIC vs INSTANCE CALL RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE CALL1: STATIC METHOD — defined with `static fn` inside a struct/class.
//             Called with:  TypeName.method(args)
//             The left of . must be a TYPE NAME (resolved at compile time).
//             No instance (no `self`) is involved.
//
//             OK:     Point.origin()          ← TypeName.staticMethod
//             OK:     User.maxAge()           ← TypeName.staticMethod
//             OK:     Animal.count            ← TypeName.staticField
//             ERROR:  p.origin()              ← calling static on instance = ERROR
//             ERROR:  Point::origin()         ← :: never used for static = ERROR
//
// RULE CALL2: INSTANCE METHOD — defined with `fn` (no `static`) inside struct/class.
//             Called with:  variable.method(args)
//             The left of . must be an EXPRESSION that evaluates to an instance.
//
//             OK:     p.distanceTo(q)         ← variable.instanceMethod
//             OK:     user.getName()          ← variable.instanceMethod
//             OK:     User("x",30).greet()    ← expression.instanceMethod
//             ERROR:  Point.distanceTo(q)     ← calling instance on type = ERROR
//
// RULE CALL3: COMPILER ERROR MESSAGES for wrong call style:
//
//   Code written            What happened             Compiler error
//   ────────────────────    ─────────────────         ─────────────────────────────
//   p.origin()              instance calls static     ERROR: `origin` is a static
//                                                     method on `Point`. Use Point.origin()
//   Point.distanceTo(q)     type calls instance       ERROR: `distanceTo` is an instance
//                                                     method. Call on a value: p.distanceTo(q)
//   Point::origin()         :: used for method        ERROR: `::` is for module paths only.
//                                                     Did you mean `Point.origin()`?
//   io.println("hi")        . used for module         ERROR: `io` is a module. Use io::println("hi")
//
// RULE CALL4: HOW COMPILER DISAMBIGUATES the left side of `.`:
//             Step 1: Is the left side a MODULE name?  → ERROR, must use ::
//             Step 2: Is the left side a TYPE name?    → static access (field or method)
//             Step 3: Is the left side a VARIABLE?     → instance access
//             Step 4: Is the left side an EXPRESSION?  → instance access on result
//
// RULE CALL5: ENUM VARIANTS always use . on the TYPE NAME (same as static):
//             Color.Red            ← TypeName.Variant
//             Color.Custom(r,g,b)  ← TypeName.Variant(data)
//             Color::Red           ← ERROR always

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 6 — TYPE SYSTEM RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE T1:  Every expression has exactly one static type known at compile time.
// RULE T2:  `any` is the escape hatch — can hold any runtime value.
//           Reading from `any` requires `match as` or `as?` cast (see Chapter 13).
// RULE T3:  Primitive types are NEVER nullable.
//           int, float, bool, char, byte = never null.
// RULE T4:  Reference types nullable only when declared with ?:  var s: str? = null
// RULE T5:  Null is NOT a value of any type except T?. null by itself has type null.
// RULE T6:  T? is a distinct type from T. Cannot pass T? where T expected without unwrap.
// RULE T7:  Implicit numeric promotion: int8→int16→int32→int64→int128
//           int→float64 (when used in float expression). NO other implicit conversions.
// RULE T8:  Narrowing cast always explicit: int32(x)
// RULE T9:  str(x) calls x.toString() or the built-in formatter.
// RULE T10: int?(str) = try-parse, returns int?. int(str) = panics if invalid.
// RULE T11: struct = value type. class = reference type (always heap).
// RULE T12: Generic type parameter T resolved at compile time. No runtime erasure.
// RULE T13: Constraints: where clause or inline colon.
//           fn f<T: Ord>(a: T, b: T) -> T            ← inline single trait
//           fn f<T: Ord + Clone>(a: T)                ← inline multiple traits
//           fn f<T, U>() where T: Ord, U: Clone + T   ← where clause
// RULE T14: Self inside trait/impl = the implementing type.
// RULE T15: never type = function that never returns (bottom type).


// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER H — NUMERIC OVERFLOW & CHECKED ARITHMETIC
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — add as CHAPTER 6-A immediately after Chapter 6 (Type System Rules)
// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 6-A — NUMERIC OVERFLOW & CHECKED ARITHMETIC
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE NUM1:  DEFAULT ARITHMETIC BEHAVIOR BY BUILD MODE
//
//   Build mode         Behavior on overflow
//   ─────────────────  ──────────────────────────────────────────────────────
//   Debug (-O0, -g)    PANIC at runtime with message "integer overflow"
//   Release (-O2,-O3)  UNDEFINED BEHAVIOR (same as C — compiler may assume
//                       no overflow for optimization purposes)
//
//   This matches the Rust / Swift model: safe in debug, fast in release.
//   For ALWAYS-defined behavior regardless of mode: use explicit operators below.
//
// RULE NUM2:  EXPLICIT OVERFLOW OPERATORS (always-defined, any build mode):
//
//   Operator   Name            Behavior
//   ────────   ─────────────   ───────────────────────────────────────────────
//   +%         wrapping add    result = (a + b) mod 2^N  (wraps silently)
//   -%         wrapping sub    result = (a - b) mod 2^N
//   *%         wrapping mul    result = (a * b) mod 2^N
//   /%         wrapping div    defined for all inputs (div -MAX by -1 wraps)
//   +|         saturating add  result = min(max(a+b, MIN_T), MAX_T)
//   -|         saturating sub  result = min(max(a-b, MIN_T), MAX_T)
//   *|         saturating mul  result = min(max(a*b, MIN_T), MAX_T)
//
//   These are OPERATORS, not function calls. Same syntax as + - *.
//   Available for all signed and unsigned integer types.
//   NOT available for float types (floats use IEEE 754 Inf/NaN for overflow).
//
// RULE NUM3:  CHECKED ARITHMETIC (returns T? — null on overflow):
//   int.checkedAdd(a, b)  → int?   (null if overflow)
//   int.checkedSub(a, b)  → int?
//   int.checkedMul(a, b)  → int?
//   int.checkedDiv(a, b)  → int?   (null if b == 0 OR signed overflow)
//   Available for all integer types (int8, int16, int32, int64, uint*, int).
//   Return T? — null means overflow occurred. Use ?? to provide a default.
//
// RULE NUM4:  CHECKED NARROWING CAST:
//   int32.checked(val: int64) → int32?   (null if val does not fit in int32)
//   int32.wrap(val: int64)    → int32    (truncates — always succeeds, wraps)
//   uint8.checked(val: int)   → uint8?
//   uint8.wrap(val: int)      → uint8
//   Available for all integer type pairs where narrowing is possible.
//
// RULE NUM5:  FLOAT OVERFLOW BEHAVIOR (always IEEE 754 regardless of build mode):
//   float64 / float32 never panic on overflow.
//   Overflow → Infinity (math::INF or -math::INF).
//   Divide by zero → Infinity (not a panic).
//   0.0 / 0.0 → NaN (math::NAN).
//   NaN comparisons: NaN == NaN → false. NaN != NaN → true. NaN < x → false.
//   Use math::isNaN(), math::isInf(), math::isFinite() to check.
//
// RULE NUM6:  INTEGER DIVISION AND MODULO RULES:
//   a / b for integers: truncates toward zero (same as C).
//   a % b for integers: result has same sign as a (truncated remainder).
//   Examples:  7 /  3 =  2       7 %  3 =  1
//             -7 /  3 = -2      -7 %  3 = -1
//              7 / -3 = -2       7 % -3 =  1
//             -7 / -3 =  2      -7 % -3 = -1
//   a / 0 or a % 0: PANIC in debug. Undefined behavior in release.
//   Use checkedDiv to avoid: int.checkedDiv(a, 0) → null (safe).
//
// RULE NUM7:  BIT SHIFT OVERFLOW RULES:
//   Shifting by amount >= bit width of type: ALWAYS PANIC (in all build modes).
//   var x: int32 = 1; x << 32  → PANIC: shift amount 32 >= 32
//   Shifting by negative amount: ALWAYS PANIC.
//   This differs from C where shift-by-width is undefined behavior.
//
// RULE NUM8:  UNSIGNED ARITHMETIC:
//   uint* types: arithmetic is ALWAYS wrapping (mod 2^N) in all build modes.
//   No overflow panic for uint types. uint is inherently modular.
//   RATIONALE: unsigned overflow is defined mathematically (modular arithmetic).
//   var x: uint8 = 255; x + 1 → 0 (silently wraps, no panic, no undefined behavior).


// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER I — TYPE INFERENCE RULES
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — add as CHAPTER 6-B immediately after Chapter 6-A
// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 6-B — TYPE INFERENCE RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE INF1:  VEX TYPE INFERENCE ALGORITHM
//   Vex uses BIDIRECTIONAL TYPE INFERENCE:
//     SYNTHESIS (bottom-up): infer type from the expression itself.
//     CHECKING  (top-down):  infer type from the expected type at the use site.
//   The two directions interact — the compiler alternates between them.
//   This avoids requiring explicit types in most positions while remaining
//   decidable and producing precise error messages.
//
// RULE INF2:  LITERAL TYPE DEFAULTS (when no context provides a type):
//   Integer literal    → int    (int64 on 64-bit platform)
//   Float literal      → float  (float64)
//   String literal     → str
//   Char literal       → char
//   Bool literal       → bool
//   null               → null (type is T? — requires context to determine T)
//   [] (empty list)    → requires context. Without context: COMPILE ERROR.
//   {} (empty set)     → requires context. Without context: COMPILE ERROR.
//   [:] (empty map)    → requires context. Without context: COMPILE ERROR.
//
// RULE INF3:  CONTEXT-DRIVEN LITERAL REFINEMENT
//   If the context provides a type, literals adopt that type:
//     var x: int8 = 42         → 42 is int8 (not int)
//     var y: float32 = 3.14    → 3.14 is float32 (not float64)
//     var z: []str = []        → [] is []str (context provides T)
//   If the literal value does NOT fit the context type: COMPILE ERROR.
//     var x: int8 = 200        → COMPILE ERROR: 200 does not fit in int8 (range -128..127)
//
// RULE INF4:  := INFERENCE (most common case)
//   var x := expr    → x gets the type of expr (synthesized from right-hand side).
//   Once inferred, x's type is FIXED. It cannot change later.
//   var x := 42      → x: int
//   var x := 42u8    → x: uint8  (suffix drives the type)
//   var x := []      → COMPILE ERROR: cannot infer type of empty list without context.
//
// RULE INF5:  FUNCTION RETURN TYPE INFERENCE
//   fn f() → return type omitted → inferred as void.
//   fn f() -> T = expr → T must match typeof(expr) exactly. COMPILE ERROR if not.
//   fn f() { return expr } → return type must be annotated if non-void.
//   Compiler does NOT infer return types from block bodies (only from = expr form).
//   RATIONALE: explicit return types for block-body functions serve as documentation
//   and prevent accidental type changes from propagating silently.
//
// RULE INF6:  LAMBDA TYPE INFERENCE
//   |p| -> expr  in isolation: COMPILE ERROR (cannot infer parameter type).
//   |p| -> expr  as argument:  inferred from the function parameter type.
//   |p| -> expr  as assigned:  inferred from the variable's declared fn type.
//   Examples:
//     list.map(|x| -> x * 2)     → x inferred as list's element type
//     let f: fn(int)->int = |x| -> x + 1  → x inferred as int from the fn type
//
// RULE INF7:  GENERIC TYPE ARGUMENT INFERENCE
//   fn max<T: Ord>(a: T, b: T) → T
//   max(3, 5)         → T inferred as int (both args are int)
//   max(3, 5.0)       → COMPILE ERROR: conflicting types (int vs float64) for T
//   max<float64>(3, 5.0) → explicit annotation resolves: 3 promoted to float64
//   Box(42)           → Box<int> (T inferred from argument)
//   Box<str>("hi")    → explicit; "hi" checked against str
//
// RULE INF8:  NULL INFERENCE
//   null has type null by itself. In context of T? → null has type T?.
//   var x: int? = null    → OK
//   var x := null         → COMPILE ERROR: cannot determine T in T?
//   fn f() -> int? { return null }  → OK (context is int?)
//   let x = cond ? someInt : null   → x: int? (one branch is int, other is null)
//
// RULE INF9:  TUPLE TYPE INFERENCE
//   let t := (1, "hi", true)   → t: (int, str, bool)
//   let (a, b) := t            → a: int, b: str  (destructuring inference)
//   let (_, b, c) := t         → b: str, c: bool (_ discarded)
//
// RULE INF10: INFERENCE ACROSS MATCH ARMS
//   All arms of a match expression must produce the same type.
//   If they differ: COMPILE ERROR unless one type is T and the other is T? (auto-lift).
//   The inferred type of the match expression = common type of all arms.
//   let v := match x { 1 => "one", 2 => "two", _ => "other" }  → v: str
//
// RULE INF11: INFERENCE FAILURE — WHEN TO ANNOTATE
//   Annotate explicitly when:
//     a. Literal type is ambiguous and context doesn't constrain it.
//     b. Empty collection literal [] / {} / [:] without assignment target type.
//     c. Generic function called with conflicting or ambiguous argument types.
//     d. Lambda in isolation (not passed to a typed parameter).
//     e. Recursive function (return type must always be explicit for block bodies).


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 7 — VARIABLE RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE V1:  `var` = mutable. `let` = immutable after assignment. `const` = comptime.
// RULE V2:  All variables MUST be initialized before first use. Compile error otherwise.
// RULE V3:  `:=` infers type from right-hand side. Type cannot change after inference.
// RULE V4:  Type annotation form: `var name: Type = value`
//           If type given but no value: zero-initialized (0, false, "", null, etc.)
// RULE V5:  Multiple declaration: `var a, b := expr1, expr2` (right side evaluated first)
// RULE V6:  Swap: `a, b = b, a` (right side evaluated before any assignment)
// RULE V7:  `_` discards a value. Cannot be read. Suppresses unused warning.
// RULE V8:  Shadowing: allowed in inner scope. Outer variable still accessible.
// RULE V9:  `const` must be evaluable at compile time. Cannot depend on runtime values.
// RULE V10: Global (module-level) `var` initialized in declaration order.
//           Circular dependencies in global init = compile error.
//           Referencing a global var defined BELOW it in same file = COMPILE ERROR.
// RULE V11: Unused `var`/`let` = COMPILE WARNING. Use `_` prefix to suppress.
// RULE V12: `let` in a loop = new binding each iteration (no mutation across iterations).

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 8 — FUNCTION RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE F1:  fn name(params) -> ReturnType { body }
// RULE F2:  Return type omitted = void. Compiler infers void.
// RULE F3:  Single-expression body: fn name(p) -> T = expr
//           Identical to: fn name(p) -> T { return expr }
// RULE F4:  Last expression in a block = implicit return value.
//           `return value` for early return. `return` alone = early void return.
// RULE F5:  Named return values: fn f() -> (x: int, y: str)
//           Named returns are zero-initialized. Plain `return` returns them.
// RULE F6:  Default parameters: fn f(a: int, b: int = 10)
//           Defaults evaluated at CALL SITE each time (not once at definition).
// RULE F7:  Named arguments: f(b: 20, a: 5) — order doesn't matter when named.
//           Positional args must come before named args: f(5, b: 20) OK.
// RULE F8:  Variadic: fn f(x: ...T) → inside fn, x is []T.
//           Must be LAST parameter. Spread: f(...list) expands list into variadic.
// RULE F9:  Function type: fn(A, B) -> R  or  fn(A, B) (void return)
//           Generic function type: fn<T>(T, T) -> T
// RULE F10: Pass-by-value (copy) for primitive types and structs.
//           Pass-by-reference with &T (borrow) or &mut T (mutable borrow).
//           Classes always passed by reference (they are reference types).
// RULE F11: async fn: always returns Future<ReturnType>. Cannot call await outside async fn.
// RULE F12: fn* (generator): returns an iterator. Each `yield` produces one value.
//           Generator is lazy — code only runs when iterated.
// RULE F13: Overloading: allowed by parameter TYPES but not count alone.
// RULE F14: Recursion: always allowed. Tail-call optimization applied when:
//           the recursive call is the LAST operation before return.
// RULE F15: Generic function resolution: type inferred from arguments when possible.
//           Explicit: maxOf<int>(3, 5) — explicit generic type before argument list.
// RULE F16: Method call syntax: x.f(args) = f(x, args) when f's first param is x's type
//           (Universal Function Call Syntax — UFCS). Enables method chaining.


// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER F — GENERATOR / yield RULES
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — expand RULE F12 in Chapter 8 (Function Rules)
// Add rules GEN_Y1–GEN_Y10 immediately after RULE F12
// ════════════════════════════════════════════════════════════════════════════════

// ── RULE F12 EXPANDED — GENERATOR FUNCTIONS (fn*) ────────────────────────────
//
// RULE GEN_Y1:  GENERATOR DECLARATION SYNTAX
//   fn* name(params) -> YieldType { body using yield }
//   The return type after -> is the TYPE OF EACH YIELDED VALUE, not the generator itself.
//   Calling a generator function does NOT execute the body.
//   It returns a Generator<YieldType> object (which implements Iterator<YieldType>).
//
// RULE GEN_Y2:  yield STATEMENT
//   yield expr    → produces one value of type YieldType, suspends execution.
//   After yield: execution resumes from the next statement when .next() is called.
//   yield is ONLY valid inside fn* functions. Using yield outside = COMPILE ERROR.
//   yield terminates if the generator is dropped (caller stops iterating).
//
// RULE GEN_Y3:  GENERATOR OBJECT
//   Calling fn* name(args) → Generator<YieldType>
//   Generator<T> implements:
//     fn next() -> T?     → returns next yielded value, or null when exhausted
//     fn hasNext() -> bool
//     fn take(n: uint) -> []T
//     fn skip(n: uint) -> Generator<T>
//     fn map<R>(f: fn(T)->R) -> Generator<R>
//     fn filter(f: fn(T)->bool) -> Generator<T>
//     fn collect() -> []T     (materializes entire generator into []T)
//   Generator<T> implements Iterable<T> → usable in for loops directly.
//
// RULE GEN_Y4:  LAZY EVALUATION
//   Generator body runs ONLY when .next() is called. One call advances one yield.
//   Infinite generators are valid: the body never reaches the end of the function.
//   Example: fn* naturals() -> int { var i := 0; loop { yield i; i++ } }
//   Reading: naturals().take(5) → [0, 1, 2, 3, 4]   (safe — stops at 5)
//
// RULE GEN_Y5:  GENERATOR EXHAUSTION
//   When the fn* body returns (or falls off the end): generator is exhausted.
//   Subsequent .next() calls return null.
//   Explicit return from fn* (with no value): ends the generator immediately.
//   return with a value inside fn* = COMPILE ERROR (return type is void for fn*).
//
// RULE GEN_Y6:  GENERATOR STATE MACHINE COMPILATION
//   Like async fn, the compiler transforms fn* into a state machine struct:
//     struct name_Generator {
//         state:   uint32,      // current suspension point (0 = not started)
//         params:  ParamTypes,  // captured parameters
//         locals:  LocalTypes,  // locals that live across yield points
//     }
//   Each yield = one state. .next() resumes from the current state.
//   sizeof(Generator) = sizeof all locals live across any yield.
//   Allocated on heap (one allocation per generator creation call).
//
// RULE GEN_Y7:  YIELD FROM (delegating to another generator)
//   yield* otherGenerator    → yields all values from otherGenerator, then continues.
//   Equivalent to: for v in otherGenerator { yield v }
//   But more efficient: no intermediate collection, direct delegation.
//
// RULE GEN_Y8:  GENERATORS AND CLOSURES
//   fn* may capture outer variables (same capture rules as lambdas).
//   Default capture: by borrow. copy / move prefix supported.
//   fn* move (param) -> YieldType { ... }   → moves outer vars into generator state.
//
// RULE GEN_Y9:  GENERATOR vs async fn
//   fn*  → synchronous generator. No await inside. Yields values one by one.
//   async fn → asynchronous computation. await inside. Returns one Future.
//   async fn* (ASYNC GENERATOR): yields Futures. Each .next() returns Future<T?>.
//   Syntax: async fn* name() -> T { ... yield await something() ... }
//   Iterated with: for await v in asyncGen() { }
//
// RULE GEN_Y10: GENERATOR TYPE IN FUNCTION SIGNATURES
//   fn consumeGen(g: Generator<int>) { for v in g { io::println(v) } }
//   fn makeGen() -> Generator<int> = naturals()
//   Generator<T> is a concrete type: can be stored in variables, passed, returned.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 9 — LAMBDA RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE L1:  Syntax: |p1: T1, p2: T2| -> expr
//                   |p1, p2| -> expr            (types inferred)
//                   || -> expr                  (no params)
//                   |p| -> { stmt; stmt; expr } (block body)
// RULE L2:  Types inferred from assignment target or call-site parameter type.
// RULE L3:  Lambda has implicit FnType: fn(params) -> ReturnType
// RULE L4:  Closures capture outer variables by BORROW by default.
//           Lambda cannot outlive the borrowed variables.
// RULE L5:  `copy` prefix: all captured outer variables copied at creation.
//             Syntax: copy |params| -> body
//           `move` prefix: ownership of captured outer vars transferred to lambda.
//             Syntax: move |params| -> body
//           Applies to ALL captured variables — no per-variable selection.
// RULE L6:  Lambda can be assigned to var/let of matching fn type.
// RULE L7:  Lambda can be passed to fn param of matching fn type.
// RULE L8:  Lambdas are zero-cost when not capturing (compiled as fn pointer).
// RULE L9:  Immediately invoked: (|x| -> x * 2)(5)
// RULE L10: Method reference syntax uses . on type name (NOT ::)
//           str.upper  = |s: str| -> s.upper()       (instance method ref)
//           io::println = |x: any| -> io::println(x)  (module fn ref — :: is correct here)
//           Point.origin = || -> Point.origin()        (static method ref)

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 10 — STRUCT RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE S1:  struct = value type. Assignment copies the value.
// RULE S2:  Default field visibility: pub. Use `priv` on field for module-private.
// RULE S3:  `init` constructor: fn init(params) { body }
//           Short form: init(x, y) = auto-assigns self.x=x, self.y=y.
//           Multiple init overloads allowed (distinguished by parameter types).
// RULE S4:  `static fn name()` = method on the type itself, no self param.
//           Called as TypeName.name()  — dot on the TYPE NAME.
//           TypeName::name()  ← WRONG — :: is only for module paths.
// RULE S5:  `self` = reference to current instance. Always explicit.
// RULE S6:  Struct literal: TypeName { field1: val, field2: val }
// RULE S7:  Struct update / spread: TypeName { ...other, field1: new_val }
// RULE S8:  Struct destructuring: let { x, y } := point
//           Rename: let { x: px, y: py } := point
//           Ignore rest: let { x, .. } := point
// RULE S9:  Operator overloading inside struct body — see Chapter 12 for full rules.
// RULE S10: Properties: prop name: T { get => ..., set(v) => ... }
//           Read-only: omit set.
// RULE S11: `ref struct` = struct allocated on heap, passed by reference.
//           Behaves like a class but without inheritance.
// RULE S12: `impl TypeName { fn extraMethod() {} }` adds methods outside struct body.
//           Can be in a different file (but same module). Cannot be in a different module.
// RULE S13: Structs can implement any number of interfaces and traits.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 11 — CLASS RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE CL1:  class = reference type, always heap-allocated.
// RULE CL2:  Default field visibility: priv. Default method visibility: pub.
// RULE CL3:  Single inheritance: class Child : Parent {}
//            super(args) calls parent init. Must be FIRST statement in child init.
// RULE CL4:  Methods are virtual (overridable) by default.
//            `final` keyword prevents override: pub final fn f()
//            `@override` decorator verifies: @override pub fn f()
// RULE CL5:  `abstract class` = cannot instantiate directly. Abstract methods have no body.
// RULE CL6:  `sealed class` = can only be subclassed within the SAME FILE.
//            Good for exhaustive matching.
// RULE CL7:  Class instances are memory-managed:
//            Default: owned (^ClassName). When assigned to another var, it moves.
//            Shared: ~ClassName. Clone increments refcount.
// RULE CL8:  deinit { } block: runs when object is freed. No parameters.
// RULE CL9:  `static` fields/methods belong to the class, not instances.
//            Access with . on the CLASS NAME:  ClassName.field   ClassName.method()
//            NEVER use :: for static:  ClassName::method() ← WRONG
// RULE CL10: Properties same as structs (prop keyword).
// RULE CL11: Interface/trait implementation same as structs.
// RULE CL12: Object creation: call the class name as a function — ClassName(args)
//            No `new` keyword. No ::. Just the name.
//              let u := User("Alice", 30)        ← creates a User object
//              let p := Point(3.0, 4.0)          ← creates a Point object
//              User("Alice", 30).greet()         ← create + call instance method

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 12 — OPERATOR OVERLOADING RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE OVL1:  Operator overloading is ONLY allowed inside struct and class bodies,
//             or in an impl block for a struct/class. Not allowed at module level.
//
// RULE OVL2:  OPERATORS THAT CAN BE OVERLOADED:
//
//   Operator   Signature required                    Notes
//   ────────   ────────────────────────────────────  ──────────────────────────
//   +          op +(other: Self) -> Self
//   -          op -(other: Self) -> Self             binary minus
//   *          op *(other: Self) -> Self
//   /          op /(other: Self) -> Self
//   %          op %(other: Self) -> Self
//   **         op **(exp: int) -> Self               exponent (int exponent only)
//   ==         op ==(other: Self) -> bool            also enables !=
//   <          op <(other: Self) -> bool             also enables >, <=, >=
//   []         op [](index: T) -> R                  index type T can vary
//   []=        op []=(index: T, value: R)            index assign
//   ()         op ()(args...) -> R                   callable objects
//   str()      op str() -> str                       toString / Display
//   -          op -() -> Self                        unary minus (no `other` param)
//   !          op !() -> Self                        unary not
//   &          op &(other: Self) -> Self             bitwise AND or set intersect
//   |          op |(other: Self) -> Self             bitwise OR or set union
//   ^          op ^(other: Self) -> Self             bitwise XOR
//   <<         op <<(n: int) -> Self                 left shift
//   >>         op >>(n: int) -> Self                 right shift
//
// RULE OVL3:  OPERATORS THAT CANNOT BE OVERLOADED (fixed language semantics):
//
//   Operator   Reason it cannot be overloaded
//   ────────   ──────────────────────────────────────────────────────────────
//   =          Assignment has fixed ownership/borrow semantics.
//   :=         Inference-assignment is compiler-only.
//   .          Member access is fundamental. Overloading . breaks type safety.
//   ::         Module resolution is compile-time only.
//   &&         Short-circuit logic — right side may not evaluate.
//   ||         Short-circuit logic — right side may not evaluate.
//   ??         Null coalescing is type-system-level.
//   ?.         Safe call depends on nullable type.
//   |>         Pipe is syntactic sugar, not a value.
//   ?          Error propagation is control flow.
//   ..  ..=    Range creation produces Range<T> type.
//   as         Type assertion/cast.
//   is         Type check.
//   ++  --     Increment/decrement — no overload to avoid C++ confusion.
//
// RULE OVL4:  Overloading == automatically enables != (compiler generates it).
//             Overloading < automatically enables >, <=, >= (compiler generates them).
//
// RULE OVL5:  Overloaded operators must return the declared type.
//             op ==(other: Self) MUST return bool.
//
// RULE OVL6:  Compound assignment operators (+=, -=, *=, /=, etc.) are
//             AUTOMATICALLY derived from their binary counterparts.
//             If you define op +, then += works automatically.
//             You can optionally define op += separately for efficiency (in-place mutation).
//
// RULE OVL7:  Overloaded operators obey the same PRECEDENCE TABLE as built-in operators.
//             You cannot change operator precedence through overloading.
//
// RULE OVL8:  Overloaded operators should not have side effects that change global state
//             or do I/O (enforced if @pure is required by the type).
//
// RULE OVL9:  An overloaded operator defined in module A cannot be used by module B
//             UNLESS module B imports module A (or imports the type from module A).
//
// RULE OVL10: The [] and []= operators together form a read/write pair.
//             If you define op [] (read), []= (write) is optional.
//             If you define op []= (write) without op [], reading by index is a compile error.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 13 — INTERFACE & TRAIT RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE I1:  interface = abstract contract, no implementations.
// RULE I2:  trait = contract with optional default implementations.
// RULE I3:  Both structs and classes implement interfaces/traits the same way.
// RULE I4:  Implementation: class/struct body can directly implement methods
//           OR use `impl InterfaceName { }` block for grouping.
// RULE I5:  All abstract methods must be implemented. Partial impl = compile error.
// RULE I6:  Default method in trait can be overridden by implementing type.
// RULE I7:  Interface/trait inheritance: trait B : A (B extends A's contract).
// RULE I8:  Generic traits: trait Comparable<T> means the compareTo takes T.
// RULE I9:  Interface as type enables dynamic dispatch: fn f(x: Drawable)
// RULE I10: Interface type is always by-reference. Passing a struct as interface
//           automatically boxes it (heap allocation if needed).
// RULE I11: Self in trait = the implementing type.
// RULE I12: Orphan rule: you can implement a trait for a type ONLY IF:
//           the type is defined in the current module, OR
//           the trait is defined in the current module (or both).

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 14 — METHOD RESOLUTION ORDER (MRO)
// ═══════════════════════════════════════════════════════════════════════════════
//
// VEX has: single class inheritance + multiple trait implementation.
//
// RULE MRO1:  CLASS METHOD lookup order (when calling instance.method()):
//
//   Step 1: Look in the EXACT runtime class of the instance.
//   Step 2: If not found, look in the PARENT class (walk up inheritance chain).
//   Step 3: If not found at any class level, look in IMPLEMENTED TRAITS.
//           Among traits, look in the order they were listed in the class declaration.
//   Step 4: If not found anywhere → COMPILE ERROR: method does not exist.
//
//   NOTE: Class methods always win over trait default methods.
//
// RULE MRO2:  CONFLICT BETWEEN TWO TRAITS with same method name:
//
//   If a class implements two traits that both define a method with the same name,
//   AND neither is overridden in the class body, it is a COMPILE ERROR.
//   The programmer MUST resolve it explicitly.
//
//   EXAMPLE:
//     trait Flyable  { fn move() = io::println("flying")  }
//     trait Swimmable{ fn move() = io::println("swimming") }
//
//     class Duck : Flyable, Swimmable {
//         // ERROR: `move` is ambiguous — MUST override:
//         fn move() = io::println("waddling")
//     }
//
// RULE MRO3:  FULL EXAMPLE:
//
//   trait Show { fn show() = io::println("trait Show default") }
//   class A    { fn show() { io::println("A.show") } }
//   class B : A { }          // B inherits show() from A
//   class C : B { }          // C inherits show() from B (which came from A)
//
//   C().show()   → prints "A.show"  (C→B→A wins over trait default)
//
//   class D : A implements Show { }
//   D().show()   → prints "A.show"  (class method beats trait default)
//
//   class E implements Show { }    // no parent class
//   E().show()   → prints "trait Show default"
//
// RULE MRO4:  @override on a method: compiler VERIFIES that at least one of:
//             a) A parent class defines a method with the same name and compatible signature.
//             b) An implemented trait defines a method with the same name.
//             If neither is true → COMPILE ERROR: nothing to override.
//
// RULE MRO5:  super.method() calls the PARENT CLASS version of the method.
//             There is no way to call a specific trait's default implementation directly.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 15 — GENERICS RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE G1:  Generic parameter syntax: T U R Key Value (<T> angle bracket notation)
// RULE G2:  Generic in function: fn name<T, U>(params) -> ReturnType { }
// RULE G3:  Generic in struct:   struct Name<T> { field: T }
// RULE G4:  Generic in class:    class Name<T> : Parent { }
// RULE G5:  Generic in trait:    trait Name<T> { fn f(x: T) }
// RULE G6:  Generic in enum:     enum Name<T> { Variant(T), Other }
// RULE G7:  Constraints inline:  fn f<T: Ord>(a: T, b: T) -> T
//           Multiple:            fn f<T: Ord + Clone>(a: T)
//           Where clause:        fn f<T, U>() where T: Ord, U: Clone + T
// RULE G8:  U: T means U must implement trait T (trait bound).
// RULE G9:  Instantiation: inferred from arguments when possible.
//           Explicit: Box<str>("hello")   maxOf<int>(3, 5)
//
// RULE G10:  IMPLEMENTATION STRATEGY: Full Monomorphization.
//            The compiler generates a SEPARATE compiled copy of each generic
//            function or type for every concrete type it is used with.
//
//            Example: fn max<T: Ord>(a: T, b: T) -> T
//            If used with int, str, and Point — compiler generates:
//              fn max_int(a: int, b: int) -> int          (specialized copy)
//              fn max_str(a: str, b: str) -> str          (specialized copy)
//              fn max_Point(a: Point, b: Point) -> Point  (specialized copy)
//
//            CONSEQUENCES:
//              ✓ Zero runtime overhead. Generics as fast as hand-written code.
//              ✓ Full inlining possible.
//              ✗ Binary size grows with unique type instantiations.
//              ✗ Compile time grows with unique type instantiations.
//
//            BINARY SIZE MITIGATION: Compiler deduplicates identical machine code
//            across specializations (COMDAT folding).
//
// RULE G11:  Generic function cannot recurse with DIFFERENT type parameters.
//            ALLOWED:    fn f<T>(x: T) { f(x) }        ← same T, finite
//            NOT ALLOWED: fn f<T>(x: T) { f(x.wrap()) } ← if wrap() returns U≠T
//
// RULE G12:  Const generics: fn f<const N: int>(arr: [N]int) → N known at compile time.
//
// RULE G13:  Monomorphization happens at the CALL SITE module, not the definition module.
//            Generic code in a .vxl library stores generic IR (not pre-specialized
//            machine code) so it can be re-specialized in each project that imports it.
//
// RULE G14:  Explicit instantiation: Box<str>("hello")  maxOf<int>(3, 5)
//            Required when type cannot be inferred from arguments.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER D — GENERICS IMPLEMENTATION STRATEGY (IR-LEVEL DETAIL)
// (supplements Chapter 15 of vex_final_rules.vex)
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── D.1  MONOMORPHIZATION PIPELINE ───────────────────────────────────────────
//
// RULE GEN1:  GENERIC IR STORAGE IN .vxl FILES
//   Generic functions and types are stored in .vxl files as GENERIC IR —
//   LLVM IR with type placeholders (opaque types). They are NOT pre-compiled
//   to machine code. When a project imports a .vxl and calls a generic,
//   the compiler re-instantiates it with the concrete type at the call site.
//
// RULE GEN2:  MONOMORPHIZATION HAPPENS AT CALL SITE
//   For each unique (genericFn, concreteTypeArgs) pair encountered during
//   compilation, the compiler:
//     Step 1: Clone the generic IR template.
//     Step 2: Substitute all type placeholders with the concrete types.
//     Step 3: Run type-checking on the substituted IR to verify trait bounds.
//     Step 4: Emit specialized LLVM IR for this instantiation.
//     Step 5: Record the instantiation in the SPECIALIZATION REGISTRY to avoid duplication.
//
// RULE GEN3:  SPECIALIZATION REGISTRY
//   The compiler maintains a per-build SPECIALIZATION REGISTRY:
//     Key:   (qualified_generic_name, [concrete_type_args...])
//     Value: pointer to already-emitted LLVM function
//   Before emitting a new specialization, the compiler checks the registry.
//   If already present: reuse the existing LLVM function — no duplicate code.
//
// RULE GEN4:  COMDAT FOLDING (binary size deduplication)
//   Two specializations that produce IDENTICAL machine code (e.g., max<^str> and
//   max<~str> may produce identical pointer-compare code) are folded by the LLVM
//   linker using COMDAT identical-code-folding (ICF).
//   The compiler places each specialization in its own COMDAT group.
//   The linker merges identical groups, keeping only one copy in the binary.
//
// ── D.2  TRAIT BOUND VERIFICATION ────────────────────────────────────────────
//
// RULE GEN5:  TRAIT BOUND CHECKING AT INSTANTIATION
//   When instantiating fn f<T: Ord + Clone>(a: T) with T = MyStruct:
//     a. Check that MyStruct implements Ord. If not: COMPILE ERROR.
//     b. Check that MyStruct implements Clone. If not: COMPILE ERROR.
//     c. Check any where-clause constraints.
//   This check happens ONCE per unique (fn, type) pair.
//   The error message names the call site AND the missing trait implementation.
//
// RULE GEN6:  HIGHER-KINDED CONSTRAINTS (constraints on type constructors)
//   VEX does not support full higher-kinded types. However, the following
//   constrained forms are supported:
//     fn f<T: Iterable<int>>(x: T)     — T must be iterable over int specifically
//     fn f<T: Comparable<T>>(a: T, b: T) — self-referential bound
//   These are sugar for trait bound checks and lower normally.
//
// ── D.3  CONST GENERICS LOWERING ─────────────────────────────────────────────
//
// RULE GEN7:  CONST GENERIC LOWERING
//   fn f<const N: int>(arr: [N]int) lowers as:
//     — N is a comptime integer constant substituted before IR generation.
//     — [N]int becomes a fixed-size LLVM array type [N x i64].
//     — Each specialization with a different N value produces a distinct function.
//   Const generic values are embedded directly in the LLVM IR — no runtime parameter.
//
// ── D.4  GENERIC STRUCT ABI ──────────────────────────────────────────────────
//
// RULE GEN8:  GENERIC STRUCT LAYOUT
//   struct Box<T> { value: T }  instantiated with T = int:
//     LLVM type: { i64 }  (just the int field — no wrapper overhead)
//   instantiated with T = Point { x: f64, y: f64 }:
//     LLVM type: { double, double }
//   The generic struct is a transparent container — no extra metadata fields.
//   Size = sizeof(T), Alignment = alignof(T).
//
// ── D.5  DYNAMIC DISPATCH (interface / trait objects) ────────────────────────
//
// RULE GEN9:  TRAIT OBJECT LAYOUT (when passing struct as interface type)
//   When a concrete type is passed where an interface/trait type is expected,
//   the compiler creates a FAT POINTER (two-word value):
//     [ data_ptr: *T | vtable_ptr: *VTable ]
//   The vtable is a static table of function pointers, one per method in the interface.
//   The vtable is emitted ONCE per (concrete type, interface) pair.
//   Layout of vtable:
//     [ sizeof_T: u64 | alignof_T: u64 | deinit_fn: *fn | method_1: *fn | method_2: *fn ... ]
//   This is the ONLY place in VEX where dynamic dispatch occurs.
//   Generics use static dispatch (monomorphization) — no vtable.
//
// RULE GEN10: INLINE DEVIRTUALIZATION
//   The optimizer attempts to devirtualize virtual calls at known call sites.
//   If the compiler can prove the concrete type at a call site, it replaces
//   the vtable call with a direct call — eliminating the dispatch overhead.
//   This happens during LLVM's optimization passes (-O2 and above).


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 16 — ENUM RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE E1:  Enum variants are accessed with . on the enum TYPE NAME:
//             EnumName.VariantName           ← correct
//             EnumName.VariantName(data)      ← correct with data
//             EnumName::VariantName           ← WRONG — :: is only for modules
//           Inside match on enum value, bare VariantName is fine (type known).
// RULE E2:  Simple variants: Color.Red  (no data)
// RULE E3:  Data variants: Shape.Circle(r: float64)
//           Data field names are optional: Shape.Circle(float64) also valid.
//           With names, you can use named pattern: Circle(radius: r) in match.
// RULE E4:  Recursive enum: variants referencing Self MUST use ^Self (owned heap).
// RULE E5:  Enum can have methods (fn inside enum body). `self` = the enum value.
// RULE E6:  Enum can implement traits/interfaces.
// RULE E7:  `const enum` = integer-backed enum (like C enum).
//           Each variant has an integer value. Default: 0, 1, 2, ...
//           Can set explicit values: Variant = 5
//           Can use bitwise ops: FlagA | FlagB
// RULE E8:  match on enum must be exhaustive. All variants covered or `_` wildcard.
// RULE E9:  `?` operator works on Result and T?:
//           On Result<T, E>: if Err(e) → return Err(e) from enclosing fn
//           On T?:         if null   → return null from enclosing fn

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 17 — CONTROL FLOW RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE C1:  if / elif / else — no parentheses around condition. Braces required.
// RULE C2:  if is an expression: let x := if cond { a } else { b }
//           All branches must return same type.
// RULE C3:  if-let: if let pattern = expr { }
//           Works for: unwrapping T?, destructuring Result, any match pattern.
// RULE C4:  while-let: while let pattern = expr { }
//           Loops while expr matches pattern.
// RULE C5:  match patterns (complete list):
//           literal:          42 | 3.14 | "hello" | true
//           variable binding: n  (binds value to n)
//           wildcard:         _  (matches anything, binds nothing)
//           range:            1..10  1..=10
//           OR:               1 | 2 | 3
//           tuple:            (a, b)  or  (_, b)
//           struct:           { x, y }  or  { x: 0, y }
//           enum:             VariantName(a, b)
//           type:             as TypeName binding  (matches if runtime type is TypeName)
//           guard:            pattern if condition  (extra boolean condition)
// RULE C6:  match is EXHAUSTIVE — compiler verifies all cases covered.
// RULE C7:  match as expression: type of all arms must be identical.
// RULE C8:  Loop keywords:
//           for x in expr         — expr must implement Iterable
//           for i, x in expr      — enumerate: i=index, x=value
//           for k, v in map       — map iteration: k=key, v=value
//           for i in a..b         — range iteration
//           for i in a..b step n  — range with step
//           for var i:=e1;c;e2   — C-style (e1=init, c=condition, e2=step)
//           while cond
//           do { } while cond
//           loop                  — infinite (must stop with `stop`)
// RULE C9:  `skip` = continue (jump to next iteration).
// RULE C10: `stop` = break (exit innermost loop, or labeled loop).
// RULE C11: Labeled loops: label: for ... { skip label / stop label }
// RULE C12: `defer expr` — evaluated at SCOPE EXIT (not function exit).
//           Multiple defers in same scope run in REVERSE ORDER (LIFO).
//           defer runs on: normal exit, early return, AND panic.
// RULE C13: `use let x := resource { body }` — x's .close() called at end of block.
//           x must implement the Closeable trait.
//           Equivalent to: let x := resource; defer x.close(); { body }

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 18 — MEMORY & OWNERSHIP RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE M1:  Every value has exactly one OWNER at a time.
// RULE M2:  Stack values copied on assignment if Copy trait.
//           A type is Copy if: all its fields are Copy (int, float, bool, char, byte,
//           fixed arrays of Copy types, structs of all Copy fields).
// RULE M3:  ^T (owned pointer): moving transfers ownership.
//           After `var b := move a`, `a` is invalid. Accessing `a` = compile error.
// RULE M4:  ~T (shared pointer): cloning increments refcount.
//           Freed automatically when last clone is dropped.
// RULE M5:  &T (borrow): multiple borrows allowed simultaneously.
//           &mut T (mutable borrow): EXCLUSIVE — no other borrows allowed.
//           Enforced at compile time.
// RULE M6:  Lifetime: a borrow (&T) cannot outlive the owner.
//           Compiler verifies this statically. No use-after-free possible.
// RULE M7:  Raw pointer *T: only in `unsafe {}` blocks. No lifetime checking.
// RULE M8:  `defer x.close()` / `use let x` = deterministic cleanup.
// RULE M9:  Arena allocator: fast bump allocation, free everything at once.
// RULE M10: mem::new(val)   → ^T  (heap, single owner)
//           mem::share(val) → ~T  (heap, reference counted)
//           mem::alloc(n)   → *byte (raw N bytes, unsafe)
//           mem::free(ptr)  → void (unsafe, for raw pointers only)
//
// RULE MEM11: ^T → &T  (owned → borrow)
//             ALWAYS ALLOWED. Borrow must not outlive the ^T owner.
//             Syntax: let r: &T = &*owned_ptr  or pass owned_ptr where &T expected.
//
// RULE MEM12: ~T → &T  (shared → borrow)
//             ALWAYS ALLOWED. Borrow must not outlive the ~T shared pointer.
//             Syntax: let r: &T = &*shared_ptr
//
// RULE MEM13: ^T → ~T  (owned → shared)
//             ALLOWED via explicit conversion: mem::intoShared(owned_ptr)
//             Ownership TRANSFERRED. After conversion, the ^T variable is INVALID.
//             EXAMPLE:
//               var h: ^str = mem::new("hello")
//               var s: ~str = mem::intoShared(move h)   ← h is now invalid
//
// RULE MEM14: ~T → ^T  (shared → owned)
//             NOT DIRECTLY ALLOWED. Cannot demote shared to owned.
//             Reason: other references to ~T may exist.
//             Workaround: clone the VALUE — fn extractOwned(s: ~T) -> ^T = mem::new(*s)
//
// RULE MEM15: *T → ^T  (raw → owned)
//             ALLOWED only inside unsafe { } blocks.
//             Syntax: let h: ^T = unsafe { ^T::fromRaw(raw_ptr) }
//
// RULE MEM16: &T → ~T  (borrow → shared)
//             NOT ALLOWED. A borrow does not own the data.
//             Workaround: let s: ~T = mem::share((*borrowed).clone())
//
// RULE MEM17: ^T → *T  (owned → raw)
//             ALLOWED only inside unsafe { } blocks.
//             Syntax: let p: *T = unsafe { owned_ptr.intoRaw() }
//             You MUST call mem::free manually.
//
// RULE MEM18: FULL CONVERSION TABLE:
//
//   From \ To    *T        ^T        ~T        &T        &mut T
//   ──────────   ───────   ───────   ───────   ───────   ──────────
//   *T           —         unsafe    unsafe    unsafe    unsafe
//   ^T           unsafe    (move)    explicit  ✓         ✓ (excl.)
//   ~T           unsafe    ✗         (clone)   ✓         ✓ (excl.)
//   &T           unsafe    ✗         ✗         ✓ (copy)  ✗
//   &mut T       unsafe    ✗         ✗         ✓ (coerce)✓ (reborrow)
//
//   ✓ = always allowed   ✗ = not allowed   explicit = needs mem:: function
//   unsafe = only inside unsafe{}   (move) = moves the pointer   (clone) = ref count +1


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER A — MEMORY MODEL: OWNERSHIP, BORROW, AND ARC RULES
// (deep compiler rules — supplements Chapter 18 of vex_final_rules.vex)
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── A.1  OWNERSHIP TIERS ─────────────────────────────────────────────────────
//
// RULE OWN1:  Every value belongs to exactly one ownership tier at a time:
//
//   Tier        Type syntax   Storage     Freed when             Thread-safe?
//   ─────────   ───────────   ─────────   ──────────────────────  ────────────
//   Stack       T (direct)    Stack       Scope exits             Yes (no share)
//   Owned heap  ^T            Heap        Owner drops             No (single owner)
//   Shared heap ~T            Heap        Refcount reaches 0      Yes (atomic RC)
//   Borrow      &T / &mut T   (alias)     Never — borrows don't own  (checked)
//   Raw         *T            Heap/stack  Manual (unsafe)         No
//
// RULE OWN2:  MOVE SEMANTICS FOR NON-COPY TYPES
//   Non-Copy types: ^T, ~T, class instances, struct containing any non-Copy field,
//                   []T (dynamic list), str, [K:V] map, {}T set.
//   Assignment of a non-Copy type MOVES ownership. The source becomes INVALID.
//   The keyword `move` is REQUIRED in three contexts:
//     a) var b := move a           — explicit move into new variable
//     b) f(move a)                 — explicit move into function argument
//     c) move |params| -> body     — move capture in lambda
//   In all other assignment positions, the compiler inserts move automatically
//   when it can prove there is no other live borrow of the source.
//   If a live borrow exists, assignment without `move` = COMPILE ERROR.
//
// RULE OWN3:  COPY SEMANTICS
//   A type T is Copy if and only if:
//     ALL of the following are true:
//       — T has no ^T, ~T, []T, str, [K:V], {}T fields (recursive check)
//       — T has no class-type fields
//       — T has no non-Copy struct fields
//       — T has no fn-type fields that capture non-Copy values
//     Compiler auto-derives Copy. You CANNOT manually impl Copy.
//   Copy types: int*, uint*, float*, bool, char, byte, [N]T where T is Copy,
//               (A, B) tuple where A and B are both Copy,
//               structs of all-Copy fields.
//   Copy types are silently bitcopied on assignment. `move` is a no-op on them.
//
// RULE OWN4:  DROP ORDER (deterministic destruction)
//   Values are dropped in REVERSE DECLARATION ORDER within a scope.
//   Example in scope { var a; var b; var c }:
//     c dropped first, then b, then a.
//   For struct fields: fields dropped in reverse field-declaration order.
//   deinit {} block runs BEFORE fields are dropped.
//   This mirrors C++ destructor rules and is guaranteed by the compiler.
//
// ── A.2  BORROW CHECKER RULES ────────────────────────────────────────────────
//
// RULE BRW1:  THE BORROW RULES (enforced statically at compile time):
//   At any point in a program, for a given value V, the compiler permits:
//     EITHER: any number of shared borrows (&T) simultaneously
//     OR:     exactly one mutable borrow (&mut T)
//     NEVER:  both shared and mutable borrows at the same time
//   This is checked per-location, per-scope. The compiler uses a NLL
//   (Non-Lexical Lifetime) algorithm — a borrow ends at its LAST USE,
//   not at the closing brace of the scope it was declared in.
//
// RULE BRW2:  LIFETIME NAMES (for annotating complex cases)
//   Lifetime names use tick prefix: 'a  'b  'static
//   They are inferred in all common cases. Explicit annotation only when
//   the compiler cannot infer (function signatures with multiple reference params
//   returning a reference).
//   Syntax:  fn f<'a>(x: &'a int, y: &'a int) -> &'a int
//   'static lifetime = lives for the entire program (string literals, statics).
//   Lifetime elision rules (applied in order, stopping at first match):
//     1. One reference input param  → output gets same lifetime as that input.
//     2. First param is &self / &mut self → output gets same lifetime as self.
//     3. Multiple input lifetimes   → COMPILE ERROR unless annotated explicitly.
//
// RULE BRW3:  REBORROWING
//   A &mut T can be reborrowed as &mut T for a shorter lifetime:
//     fn f(x: &mut int) { g(x) }   // implicit reborrow of x for call to g
//   A &mut T can also be coerced to &T (shared borrow) for a call:
//     fn g(x: &int) { ... }
//     fn f(x: &mut int) { g(x) }   // &mut coerced to & automatically
//   The original &mut borrow is suspended until the reborrow ends.
//
// RULE BRW4:  INTERIOR MUTABILITY (escape hatch for shared mutation)
//   sync::Mutex<T> and sync::RwLock<T> provide safe interior mutability.
//   They hold a T behind a lock. The compiler treats the Mutex itself as
//   immutable — mutation happens through the guard returned by .lock().
//   sync::Atomic<T> provides lock-free interior mutability for primitives.
//   These are the ONLY safe ways to mutate through a shared reference.
//
// RULE BRW5:  BORROW CHECKER ALGORITHM (NLL — compiler internals)
//   The compiler builds a Control Flow Graph (CFG) for each function.
//   For each borrow b of value v:
//     a. Compute the LIVE RANGE of b: from the borrow point to its last use.
//     b. Check that v is not moved or mutably borrowed within that live range.
//     c. Check that v's owner is not dropped within that live range.
//   Errors detected:
//     — Use after move          → COMPILE ERROR: value moved at line N, used at line M
//     — Double move             → COMPILE ERROR: value already moved
//     — Borrow while moved      → COMPILE ERROR: cannot borrow, value was moved
//     — Mutable + shared borrow → COMPILE ERROR: cannot borrow mutably — already borrowed
//     — Borrow outlives owner   → COMPILE ERROR: borrowed value dropped while borrow active
//
// ── A.3  ARC (AUTOMATIC REFERENCE COUNTING) RULES ───────────────────────────
//
// RULE ARC1:  ~T uses ATOMIC reference counting. Thread-safe.
//   The refcount is stored in a heap header block immediately before the value:
//     Layout: [ refcount: atomic<uint64> | value: T | padding ]
//   Alignment of value T is respected. The entire block is one heap allocation.
//
// RULE ARC2:  REFCOUNT OPERATIONS
//   ~T::clone()  → atomically increments refcount, returns new ~T pointing to same data.
//   ~T::drop()   → atomically decrements refcount.
//                  If refcount reaches 0: call deinit on T, then free the heap block.
//   The atomic operations use ACQUIRE/RELEASE memory ordering (no SeqCst needed
//   for the count itself, but the final drop uses ACQUIRE to synchronize deinit).
//
// RULE ARC3:  WEAK REFERENCES (cycle breaking)
//   ~T can produce a weak: ~weak<T> via ~T::downgrade().
//   ~weak<T> does NOT increment the strong refcount.
//   ~weak<T>::upgrade() → ~T?  (null if the strong refcount already hit 0).
//   Weak references prevent reference cycles from leaking memory.
//   Weak refcount is stored in a second atomic<uint64> in the same header block:
//     Layout: [ strong: atomic<uint64> | weak: atomic<uint64> | value: T ]
//   The block is freed only when BOTH strong AND weak counts reach 0.
//
// RULE ARC4:  ~T IS NOT CLONEABLE BY DEFAULT
//   Assigning a ~T copies the POINTER (increments refcount).
//   var s2 := s1             → increments refcount, both point to same data.
//   To deep-clone the VALUE: var s2 := mem::share((*s1).clone())
//   The distinction: pointer-clone (cheap, ~O(1)) vs value-clone (O(size of T)).
//
// RULE ARC5:  CYCLE DETECTION
//   ARC cannot collect cycles on its own. The programmer is responsible for
//   breaking cycles using ~weak<T>. The compiler emits a WARNING (not error)
//   when it detects a potential cycle in struct/class type definitions:
//     "warning: type A contains ~B which contains ~A — consider using ~weak<A>"
//   Cycle detection is a best-effort static analysis, not exhaustive.
//
// RULE ARC6:  ^T vs ~T CHOICE GUIDE
//   Use ^T when:   single clear owner, never needs sharing, short-lived.
//   Use ~T when:   shared between scopes/threads, lifetime unclear at creation.
//   Use &T when:   you just need to look at data, not own it.
//   Prefer ^T → &T (borrow) over ~T whenever possible. ARC has runtime cost.
//
// ── A.4  LLVM CODEGEN FOR MEMORY OPS ────────────────────────────────────────
//
// RULE MEM_CG1: ^T heap allocation lowers to:
//               LLVM: %ptr = call i8* @vex_alloc(i64 sizeof(T), i64 alignof(T))
//               followed by a bitcast to T*.
//               vex_alloc is a thin wrapper around the system allocator (malloc/jemalloc).
//
// RULE MEM_CG2: ^T drop (when owner leaves scope) lowers to:
//               LLVM: call void @vex_free(i8* %ptr)
//               inserted by the compiler at the DROP POINT determined by the borrow checker.
//               Drop points are inserted as LLVM lifetime.end intrinsics + free call.
//
// RULE MEM_CG3: ~T clone lowers to:
//               LLVM: atomicrmw add i64* %refcount_ptr, i64 1, acquire
//               followed by pointer copy (same address, no data copy).
//
// RULE MEM_CG4: ~T drop lowers to:
//               LLVM: %prev = atomicrmw sub i64* %refcount_ptr, i64 1, acq_rel
//                     %is_zero = icmp eq i64 %prev, 1
//                     br i1 %is_zero, label %do_free, label %skip_free
//               do_free: call deinit, then call @vex_free.
//
// RULE MEM_CG5: Borrow &T / &mut T lowers to a plain LLVM pointer (T*).
//               No runtime cost. The borrow checker enforces safety statically.
//               At the LLVM IR level, there is NO difference between &T and *T.
//               Safety exists only in the VEX type system layer.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER B — NAME RESOLUTION ALGORITHM
// ═══════════════════════════════════════════════════════════════════════════════
//
// Name resolution runs in compiler pipeline PHASE 4 (SYMBOL TABLE) and
// PHASE 6 (TYPE CHECKER). It answers: "what does this identifier refer to?"
//
// ── B.1  RESOLUTION PHASES ───────────────────────────────────────────────────
//
// RULE NR1:  NAME RESOLUTION RUNS IN TWO PASSES:
//
//   PASS 1 — DECLARATION COLLECTION (before type-checking):
//     For every file in dependency order:
//       a. Scan all top-level declarations (fn, struct, class, enum, trait,
//          interface, impl, const, type, var, import).
//       b. Insert each pub/internal name into the module's EXPORT TABLE.
//       c. Insert each priv name into the module's PRIVATE TABLE.
//       d. Record impl blocks: map (Type, MethodName) → fn body location.
//     Result: every module has a fully-populated symbol table of its own names.
//
//   PASS 2 — USE RESOLUTION (during type-checking):
//     For every identifier use (variable read, function call, type reference):
//       Apply the lookup chain in RULE NR2.
//
// ── B.2  LOOKUP CHAIN ────────────────────────────────────────────────────────
//
// RULE NR2:  IDENTIFIER LOOKUP ORDER (for a bare name `x` — no :: or . prefix):
//
//   Step 1 — LOCAL SCOPE STACK (innermost to outermost):
//     Walk the scope stack from innermost (current block) outward.
//     At each scope level, check: is `x` declared here (var/let/const/fn param)?
//     First match wins. Shadowing is how inner declarations hide outer ones.
//
//   Step 2 — FUNCTION PARAMETERS:
//     If inside a function, check the function's parameter list.
//
//   Step 3 — ENCLOSING LAMBDA CAPTURE:
//     If inside a lambda, check the capture set.
//     For borrow-captured variables, they are resolved in the outer scope.
//     For copy/move-captured variables, they are in the lambda's own scope.
//
//   Step 4 — CURRENT MODULE'S TOP-LEVEL SCOPE:
//     Check the module's own PRIVATE TABLE + EXPORT TABLE.
//     Includes: module-level fn, struct, class, enum, trait, type, const, var.
//     Also includes: all `impl` methods for types declared in this module.
//
//   Step 5 — IMPORTED MODULES (via aliases only):
//     Bare names do NOT resolve across modules.
//     Only names qualified with a module alias (alias::name) resolve here.
//     Bare `x` will NOT find `x` from an imported module — you must write
//     moduleAlias::x explicitly.
//
//   Step 6 — BUILT-IN NAMES:
//     true, false, null, void, never, any, Self, self, super,
//     int, uint, float, bool, char, str, byte, type, and all primitive types.
//
//   Step 7 — NOT FOUND:
//     COMPILE ERROR: undefined name `x`. Did you mean: <suggestions from Levenshtein distance>?
//
// ── B.3  QUALIFIED NAME RESOLUTION (path::name or value.name) ────────────────
//
// RULE NR3:  MODULE PATH RESOLUTION (:: operator):
//
//   For `A::B::...::Z`:
//     Step 1: Look up A in the current file's import aliases.
//             If found, A is a module alias. Proceed.
//             If not found: COMPILE ERROR: `A` is not an imported module alias.
//     Step 2: Walk the :: chain left to right.
//             Each intermediate segment must be a module directory.
//             The last segment (Z) is the item name inside the final module.
//     Step 3: Look up Z in module A (or A::B::...'s) EXPORT TABLE only.
//             priv symbols of other modules are never visible. COMPILE ERROR if Z is priv.
//     Step 4: Z must be one of: fn, struct, class, enum, trait, interface, const, type.
//             Z cannot be a module file itself — that would require another :: segment.
//
// RULE NR4:  MEMBER ACCESS RESOLUTION (. operator):
//
//   For `expr.name` or `TypeName.name`:
//     Step 1: Determine the type of the left-hand side:
//               — If left is a TYPE NAME: look for static fn / static field / enum variant.
//               — If left is a VALUE:     look for instance fn / instance field / property.
//     Step 2: Collect candidate methods from:
//               a. The type's own body (direct definition).
//               b. impl blocks for the type (same module).
//               c. impl blocks from imported modules (only if they imported the trait).
//               d. Trait default implementations (via MRO — see Chapter 14).
//     Step 3: Among candidates, apply UFCS:
//               x.f(a, b)  is identical to  f(x, a, b)  if no direct method `f` exists
//               but a free function `f` with first param matching x's type exists.
//               UFCS is tried last — only if no method is found in steps a-d.
//     Step 4: Ambiguity (two candidates with same name and compatible signature):
//               COMPILE ERROR: ambiguous method call. Specify explicitly.
//
// RULE NR5:  SELF RESOLUTION:
//   `self` inside a struct/class/enum method = the current instance.
//   `Self` (capital S) = the TYPE of the current instance (useful in traits/generics).
//   `super` = the parent class. `super.method()` bypasses virtual dispatch.
//   `super(args)` in init = calls parent init. Must be the FIRST statement.
//
// ── B.4  GENERIC INSTANTIATION RESOLUTION ────────────────────────────────────
//
// RULE NR6:  GENERIC TYPE PARAMETER RESOLUTION:
//   When a generic function or type is instantiated:
//     Step 1: Collect all concrete types from the call-site arguments (type inference).
//     Step 2: For each type parameter T, verify:
//               — T satisfies all trait bounds (T: TraitA + TraitB).
//               — T satisfies all where-clause constraints.
//     Step 3: If type inference is ambiguous, require explicit annotation:
//               Box<str>("hello")   maxOf<int>(3, 5)
//     Step 4: Record the instantiation (concrete type tuple) in the SPECIALIZATION TABLE.
//             Duplicate instantiations (same type tuple, same generic) reuse existing.
//
// ── B.5  IMPL BLOCK RESOLUTION ───────────────────────────────────────────────
//
// RULE NR7:  IMPL BLOCK SCOPING
//   An impl block for TypeX adds methods to TypeX within the CURRENT MODULE only.
//   impl blocks in module A do not affect how module B resolves methods on TypeX,
//   unless module B imports module A AND the impl block is for a trait B has access to.
//   The compiler merges all impl blocks for a type at the END of Pass 1 (declaration
//   collection) before type-checking begins. Order of impl blocks within a file
//   does not matter.
//
// RULE NR8:  IMPL PRECEDENCE (when multiple impls provide same method name):
//   a. Direct struct/class body definition: HIGHEST priority.
//   b. impl block in same file.
//   c. impl block of a specific trait (trait name determines precedence alphabetically).
//   Two impls providing the same non-trait method name for the same type = COMPILE ERROR.
//   Two trait impls providing same method name = resolved via MRO (Chapter 14).

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 19 — THE `any` TYPE — RUNTIME BEHAVIOR
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE ANY1:  `any` is a DYNAMICALLY TYPED container. It holds any value at runtime.
//             Internally stores: (a) a pointer to the value (or the value itself if it
//             fits in a word), (b) a type tag (typeid — uint64 unique to the runtime type).
//             This is called "boxing".
//
// RULE ANY2:  BOXING COST:
//             Storing a primitive (int, float, bool, char) in `any` costs a
//             heap allocation UNLESS small-value optimization applies (it does for primitives).
//             Storing a struct copies it onto the heap.
//             Storing a class (already heap) only copies the pointer — cheap.
//
// RULE ANY3:  READING FROM `any` — requires a runtime type check. Three forms:
//
//   Form 1: match as (preferred)
//     match val {
//         as int i  => use(i)        // i has static type int here
//         as str s  => use(s)        // s has static type str here
//         _         => handle_other()
//     }
//
//   Form 2: as assertion (panics if wrong type)
//     let i := val as int            // panics if val does not contain int
//
//   Form 3: as? safe cast (returns T?, null if wrong type)
//     let i := val as? int           // returns int? (null if val is not int)
//     if let n = val as? int { use(n) }
//
// RULE ANY4:  Each `as TypeName` check is ONE runtime comparison of typeids. O(1) per check.
//
// RULE ANY5:  `any` CANNOT be used to call methods without unwrapping first.
//             var obj: any = SomeClass(42)
//             obj.method()                   ← COMPILE ERROR
//             (obj as SomeClass).method()    ← OK (panics if wrong type at runtime)
//             (obj as? SomeClass)?.method()  ← OK (safe, does nothing if null)
//
// RULE ANY6:  `any` and GENERICS — prefer generics over `any` for performance.
//             fn processAny(x: any) → boxes everything, runtime dispatch, slow
//             fn process<T>(x: T)   → monomorphized, no boxing, static dispatch, fast
//
// RULE ANY7:  `any` IS NOT a supertype in the inheritance sense.
//             There is no implicit coercion from `any` to any specific type.
//
//   PERFORMANCE SUMMARY:
//     Operation                        Cost
//     ───────────────────────────────  ────────────────────────────────────────
//     Store primitive in any           Possible heap alloc (small-val opt helps)
//     Store class in any               Pointer copy only (cheap)
//     Read from any (as?)              1 typeid comparison (O(1))
//     Match with N type branches       At most N typeid comparisons
//     Call method through any          Not allowed — must unwrap first
//     Generic fn with T                Zero cost (monomorphized, static)

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 20 — ERROR HANDLING RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// VEX has THREE error mechanisms. Each has exactly one correct use case.
//
// RULE ERR1:  THE THREE MECHANISMS AND WHEN TO USE EACH:
//
//   Mechanism       When to use                     When NOT to use
//   ─────────────   ─────────────────────────────   ──────────────────────────────
//   Result<T, E>    Expected, recoverable errors.   Bugs. Impossible states.
//                   Caller must handle or propagate. Performance-critical inner loops.
//
//   panic(msg)      Programmer bugs. Invariant       Expected failures (file missing,
//                   violations. Impossible states.   parse fail, network error).
//
//   try/catch       Catching panics for cleanup      Regular error handling.
//                   at process boundary only.        Never use to silence panics.
//
// RULE ERR2:  Result<T, E> IS the primary error handling system.
//             ? operator propagates: if Err(e), returns Err(e) from enclosing fn.
//             Enclosing fn must return Result with a compatible E type.
//
// RULE ERR3:  panic() is for BUGS — not user errors, not network failures.
//             Correct uses:
//               panic("index out of bounds")         ← programmer used wrong index
//               panic("unreachable branch reached")   ← invariant violated
//               assert(x > 0, "x must be positive")  ← contract violation
//             Incorrect uses:
//               panic("file not found")              ← WRONG: use Result<T, IoError>
//               panic("parse failed")                ← WRONG: use Result<T, ParseError>
//
// RULE ERR4:  try/catch catches PANICS ONLY. It does NOT catch Result errors.
//             You cannot catch a Result::Err with try/catch. Match on Result instead.
//
// RULE ERR5:  DO NOT SILENTLY CATCH PANICS. If you catch a panic: log, report, or re-panic.
//
// RULE ERR6:  Error types SHOULD be enums with one variant per error category.
//
// RULE ERR7:  THE ? OPERATOR — exact behavior:
//             On Result<T, E>:  if Err(e), execute `return Err(e.into())` in enclosing fn.
//                               if Ok(v), evaluates to v (unwraps).
//             On T?:            if null, execute `return null` in enclosing fn.
//                               if non-null, evaluates to the value.
//
// RULE ERR8:  ERROR CONVERSION with ?.into():
//             If the error types don't match exactly, define a From<SourceErr>
//             impl on the target error type. The ? operator calls .into() automatically.
//             fn readInt(path: str) -> Result<int, AppError> {
//                 let s := fs::readFile(path)?    // IoError automatically into AppError
//                 parseInt(s)?                    // ParseError automatically into AppError
//             }


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER F — ERROR HANDLING LOWERING (Option / Result → LLVM IR)
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── F.1  T? (NULLABLE / OPTION) LOWERING ────────────────────────────────────
//
// RULE ERL1:  T? REPRESENTATION IN LLVM IR
//   For pointer-like types (^T, ~T, &T, *T, class, str, []T):
//     T? is represented as the POINTER ITSELF. null = null pointer (0).
//     No extra tag field. sizeof(T?) == sizeof(T).
//     This is the niche optimization applied universally to pointer types.
//
//   For value types (int, float, bool, struct, enum, tuple):
//     T? is represented as an enum: { tag: uint8 | value: T }
//     tag = 0 → null (no value), tag = 1 → value present.
//     sizeof(int?) = sizeof(uint8) + padding + sizeof(int) = typically 9-16 bytes.
//     EXCEPTION: bool? → tag = 0 (null), 1 (false), 2 (true) → fits in uint8 alone.
//
// RULE ERL2:  ?? OPERATOR LOWERING
//   `x ?? default` lowers to:
//     For pointer T?:  %result = select i1 (ptr != null), ptr, default_ptr
//     For value T?:    %is_null = icmp eq i8 %tag, 0
//                      %result  = select i1 %is_null, default_val, %value_field
//   Single conditional select — no branch, branchless on most architectures.
//
// RULE ERL3:  ?. SAFE CALL LOWERING
//   `x?.method(args)` lowers to:
//     %is_null = (x == null)  OR  (%x.tag == 0)
//     br i1 %is_null, label %skip, label %call
//     call: %result = call method(x, args)  → stored in output T?
//     skip: output T? = null
//   Result type of x?.method() is ReturnType? (wraps return in nullable).
//
// ── F.2  RESULT<T, E> LOWERING ───────────────────────────────────────────────
//
// RULE ERL4:  Result<T, E> REPRESENTATION
//   Result<T, E> is an enum with two variants: Ok(T) and Err(E).
//   Follows standard enum layout (RULE ABI5): tagged union.
//   Tag: 0 = Ok, 1 = Err.
//   Data: max(sizeof(T), sizeof(E)) bytes.
//   The ? operator is the primary way to interact with Result.
//
// RULE ERL5:  ? OPERATOR LOWERING ON Result<T, E>
//   `expr?` where expr: Result<T, E> in fn that returns Result<T2, E2>:
//
//   LLVM IR lowering:
//     %res    = <evaluate expr>
//     %tag    = extractvalue %res, 0         ; get tag field
//     %is_err = icmp eq i32 %tag, 1
//     br i1 %is_err, label %propagate, label %ok_path
//
//     propagate:
//       %err_val = extractvalue %res, 1      ; extract Err payload
//       %conv    = call E2 @into(E %err_val) ; .into() conversion if E != E2
//       %ret_err = insertvalue {i32, E2} undef, i32 1, 0
//       %ret_err = insertvalue %ret_err, %conv, 1
//       ret %ret_err                         ; early return with Err
//
//     ok_path:
//       %ok_val = extractvalue %res, 1       ; extract Ok payload (same field offset as Err)
//       ; continue with %ok_val as the unwrapped T value
//
//   KEY POINT: The ? operator compiles to a CONDITIONAL BRANCH + EARLY RETURN.
//   In the happy path (Ok), the branch is predicted NOT TAKEN → near-zero overhead.
//   Error propagation is a branch to a cold exit path — modern CPUs predict this well.
//
// RULE ERL6:  ? OPERATOR ON T? LOWERING
//   `expr?` where expr: T? in fn that returns T2?:
//
//   For pointer T? (null = null pointer):
//     %val     = <evaluate expr>
//     %is_null = icmp eq %val, null
//     br i1 %is_null, label %ret_null, label %continue
//     ret_null: ret null
//     continue: ; use %val as T
//
//   For value T? (tag-based):
//     %opt    = <evaluate expr>
//     %tag    = extractvalue %opt, 0
//     %is_null = icmp eq i8 %tag, 0
//     br i1 %is_null, label %ret_null, label %continue
//     ret_null: ret (null T2?)
//     continue: %val = extractvalue %opt, 1
//               ; use %val as T
//
// ── F.3  PANIC LOWERING ──────────────────────────────────────────────────────
//
// RULE ERL7:  panic() LOWERING
//   panic(msg) lowers to:
//     %msg_ptr = <string literal or formatted str>
//     call void @vex_panic(i8* %msg_ptr, i8* @file_name, i32 %line_number)
//     unreachable
//   @vex_panic is a RUNTIME function that:
//     a. Prints the panic message + file/line to stderr.
//     b. Prints a stack trace (if compiled with -g or -O0).
//     c. Calls abort() (SIGABRT). The process terminates immediately.
//   The `unreachable` LLVM instruction allows the optimizer to treat code after
//   panic() as dead code and eliminate it.
//
// RULE ERL8:  try/catch LOWERING
//   try { ... } catch e { ... } uses PLATFORM SIGNAL HANDLING (not C++ exceptions):
//   The compiler wraps the try block with:
//     a. Install a setjmp/longjmp recovery point (on Linux/macOS/Windows).
//     b. Wrap @vex_panic to check if a recovery point exists before calling abort().
//     c. If recovery point exists: longjmp to the catch block.
//     d. The catch block receives a PanicInfo struct { message: str, stackTrace: str }.
//   COST: setjmp has near-zero cost on the happy path. Only slow when a panic fires.
//   try/catch is designed for PROCESS BOUNDARY error isolation — not normal flow.
//
// ── F.4  assert / assertEq LOWERING ─────────────────────────────────────────
//
// RULE ERL9:  assert() LOWERING
//   assert(condition, msg) lowers to:
//     br i1 %condition, label %pass, label %fail
//     fail: call void @vex_panic(msg, file, line)  ; unreachable after
//     pass: ; continue
//   In RELEASE builds (-O2, -O3): asserts ARE kept by default (safe defaults).
//   With -D DISABLE_ASSERT=true: all asserts compile to nothing (removed from IR).
//   assert() at comptime: becomes COMPILE ERROR if condition is false.
//
// ── F.5  ERROR TYPE CONVERSION (.into()) ─────────────────────────────────────
//
// RULE ERL10: From<E> TRAIT FOR ERROR CONVERSION
//   When ? is used and the error types differ (source E, target E2),
//   the compiler looks for impl From<E> for E2 in scope.
//   If found: calls the conversion at the propagation point.
//   If not found: COMPILE ERROR: cannot convert E into E2 with ?. Impl From<E> for E2.
//   The From trait:
//     trait From<E> {
//         fn from(err: E) -> Self
//     }
//   .into() is the inverse — automatically derived when From is implemented.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 21 — COMPTIME EXECUTION RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE CT1:  `comptime` prefix on const, fn, if, for = compile-time evaluation.
//            All comptime evaluation happens during compilation, producing zero
//            runtime code for the comptime computation itself.
//
// RULE CT2:  WHAT CAN RUN AT COMPTIME — EXACT ALLOW LIST:
//
//   Category                    Allowed at comptime?    Notes
//   ─────────────────────────   ────────────────────    ──────────────────────────
//   Integer arithmetic          ✓ YES                   All int ops: + - * / % ** & | ^ << >>
//   Float arithmetic            ✓ YES                   All float ops
//   Boolean logic               ✓ YES                   && || ! comparisons
//   String literals             ✓ YES                   Concatenation, slicing
//   String formatting           ✓ YES                   f"..." with comptime values only
//   if / elif / else            ✓ YES                   Both branches evaluated for syntax
//   for loops (bounded)         ✓ YES                   Loop must terminate (no infinite)
//   Calling comptime fn         ✓ YES                   Only if that fn is also comptime
//   Calling built-in operators  ✓ YES                   sizeof, alignof, typeid, typeof
//   Type manipulation           ✓ YES                   T.fields, T.methods, T.name
//   Struct field access         ✓ YES                   On comptime-known structs
//   Creating arrays/tuples      ✓ YES                   Fixed size, comptime elements
//   Conditional compilation     ✓ YES                   #if / #elif / #else
//   const generic parameters    ✓ YES                   fn f<const N: int>
//   Recursive comptime fn       ✓ YES                   Must terminate (depth limit: 10000)
//   match expressions           ✓ YES                   On comptime-known values
//   Type aliases / new types    ✓ YES                   comptime type = ...
//
// RULE CT3:  WHAT CANNOT RUN AT COMPTIME — EXACT DENY LIST:
//
//   Category                    Allowed at comptime?    Reason
//   ─────────────────────────   ────────────────────    ──────────────────────────
//   Heap allocation             ✗ NO                    No allocator exists at compile time
//   mem::new / mem::share       ✗ NO                    Runtime memory ops
//   File I/O (fs::*)            ✗ NO                    Filesystem not available to compiler
//   Network I/O (net::*)        ✗ NO                    Network not available to compiler
//   Thread operations           ✗ NO                    No runtime threads during compile
//   async / await               ✗ NO                    Requires async runtime
//   Calling non-comptime fn     ✗ NO                    Would need runtime to execute
//   Calling C functions (FFI)   ✗ NO                    C ABI is a runtime concept
//   I/O (io::print etc.)        ✗ NO                    Runtime I/O
//   panic() at comptime         ✓ SPECIAL               Becomes COMPILE ERROR with message
//   assert() at comptime        ✓ SPECIAL               Becomes COMPILE ERROR if false
//   Mutable global var          ✗ NO                    Global state is runtime
//   Closures with capture       ✗ NO                    Capture requires runtime env
//   Dynamic dispatch (any)      ✗ NO                    Runtime type info needed
//   Random / time / os          ✗ NO                    Not deterministic at compile time
//
// RULE CT4:  Comptime CAN create temporary values on the "comptime stack".
//            These exist ONLY during compilation and produce ZERO runtime data.
//
// RULE CT5:  COMPTIME CAN READ SOURCE FILES — via the #include_bytes directive:
//            comptime const DATA: []byte = #include_bytes("data.bin")
//            This is the ONLY file access allowed at comptime.
//
// RULE CT6:  COMPTIME CAN GENERATE CODE via comptime type manipulation:
//            comptime fn makeStruct(fields: []FieldDesc) -> type { ... }
//
// RULE CT7:  COMPTIME RECURSION LIMIT: 10,000 recursive calls.
//            Exceeding this = COMPILE ERROR: comptime recursion limit exceeded.
//
// RULE CT8:  COMPTIME CONSTANTS are inlined everywhere they are used.
//            They have NO runtime storage — no memory address, no pointer possible.
//
// RULE CT9:  #if / #elif / #else / #end = conditional compilation.
//            The EXCLUDED branch is completely removed from the AST before type-checking.
//
// RULE CT10: Built-in comptime variables (set by compiler, read-only):
//            #OS      = "linux" | "windows" | "macos" | "android" | "wasm"
//            #ARCH    = "x86_64" | "arm64" | "riscv64" | "wasm32"
//            #DEBUG   = true when built with -g or -O0
//            #RELEASE = true when built with -O2 or -O3
//            #TARGET  = full target string e.g. "linux-x64"
//            User defines: -D NAME=value on vex build command.
//
// RULE CT11: comptime fn vs regular fn:
//            comptime fn = can ONLY be called at comptime.
//            Regular fn  = called at runtime. Can also run at comptime if all inputs
//                          are comptime known (constant folding).
//
// RULE CT12: @decorator_def functions are implicitly comptime. They receive and
//            return comptime item descriptors. They cannot call runtime-only code.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 22 — MODULE RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE MOD1:  Every .vex or .vxl file is a module. No `package` or `module` keyword.
// RULE MOD2:  Module name = filename without extension. Must be a valid identifier.
//             File: math_utils.vex  → module name: math_utils
//             File: std/io.vex      → module path: std::io
// RULE MOD3:  Top-level visibility defaults (see Chapter 4 — Visibility for full table).
// RULE MOD4:  priv = this file only. internal = same project dir. pub = anywhere.
//
// RULE MOD5:  CIRCULAR IMPORTS = COMPILE ERROR
//             Vex does NOT allow circular imports. The dependency graph must be a DAG.
//             Detection algorithm:
//               1. Build a directed graph: node per module, edge A→B if A imports B.
//               2. Run topological sort (Kahn's algorithm or DFS).
//               3. If a cycle is detected, report ALL modules in the cycle.
//             Error message example:
//               COMPILE ERROR: Circular import detected:
//                 a.vex → imports b.vex
//                 b.vex → imports a.vex
//               To fix: extract shared code into a third module that both import.
//
// RULE MOD6:  fn init() at module level: runs once when module is first loaded.
//             fn deinit() at module level: runs at program exit.
//
// RULE MOD7:  TWO MODULE FILE FORMATS:
//             .vex = source file (compiled fresh each build)
//             .vxl = compiled library (pre-compiled, no source exposed)
//             Import syntax is IDENTICAL for both. Caller never writes the extension.
//
//             .vxl FILE STRUCTURE (binary format):
//               Section 1 — HEADER
//                 magic bytes: "VXL "
//                 version: uint32
//                 module name: str
//                 target platform: str
//                 compiler version: str
//               Section 2 — TYPE METADATA (for type checker)
//                 all pub fn signatures
//                 all pub struct/class/enum layouts
//                 all pub type aliases and constants
//                 generic specializations that were compiled
//               Section 3 — MACHINE CODE
//                 compiled code for all functions (pub and priv)
//                 priv functions are anonymous — names stripped
//               Section 4 — DEBUG SYMBOLS (optional, only with -g flag)
//               NOT PRESENT: source code, priv function names, internal logic
//
// RULE MOD8:  IMPORT RESOLUTION ORDER (for: import X::Y):
//             Compiler searches in this order, stops at first match:
//               1. <project_root>/X/Y.vex       local source (highest priority)
//               2. <project_root>/X/Y.vxl       local compiled
//               3. <project_root>/libs/official/X@version/Y.vex   installed official pkg
//               4. <project_root>/libs/official/X@version/Y.vxl   installed official pkg
//               5. <project_root>/libs/external/X@version/Y.vex   installed external pkg
//               6. <project_root>/libs/external/X@version/Y.vxl   installed external pkg
//               7. <vex_stdlib>/lib/X/Y.vxl     standard library (pre-compiled)
//               8. <vex_stdlib>/lib/X/Y.vex     stdlib source fallback
//               9. COMPILE ERROR: module X::Y not found
//
// RULE MOD9:  WHAT COMPILER DOES WITH EACH FORMAT:
//             .vex found → lex, parse, type-check, borrow-check, compile, link
//             .vxl found → read type metadata header, type-check caller against it,
//                          link pre-compiled machine code directly
//
// RULE MOD10: THREE IMPORT FORMS:
//
//   FORM 1 — full module import (original, unchanged behaviour):
//               import module_path
//               import module_path as alias
//             Access: always use  moduleName::item  or  alias::item
//             VALID:
//               import std::io               → io::println("hello")
//               import std::math             → math::sqrt(4.0)   math::PI
//               import shapes                → shapes::Circle(3.0)
//               import shapes as geo         → geo::Circle(3.0)
//
//   FORM 2 — selective import (bring specific names into direct scope):
//               import module_path { name1, name2, name3 }
//               import module_path { name1 as local1, name2 }
//             Access: use name directly OR use moduleName::name — both work.
//             VALID:
//               import std::math { sqrt, PI }
//                 sqrt(4.0)           → direct (no prefix needed)
//                 math::sqrt(4.0)     → qualified — also still works
//                 PI                  → direct
//               import std::math { sqrt as squareRoot, PI as Pi }
//                 squareRoot(4.0)     → renamed direct
//                 Pi                  → renamed direct
//               import std::io { println, print }
//                 println("hello")    → direct
//                 io::println("hello") → qualified — also still works
//               import mem::io as a { println }
//                 println("hello")    → direct (uses mem::io's println)
//                 a::println("hello") → qualified via alias
//
//   FORM 3 — open import (bring ALL pub names into direct scope):
//               import module_path { * }
//             Access: use any pub name directly OR qualified — both work.
//             VALID:
//               import std::io { * }
//                 println("hello")    → direct
//                 io::println("hello") → qualified — also still works
//             WARNING: compiler warns if any name shadows an existing in-scope name.
//
//   The last :: segment in ANY form is always a module filename, never a fn/type/const.
//   INVALID — COMPILE ERROR (in all three forms):
//               import std::io::println      → no println.vex or println.vxl
//               import std::math::PI         → no PI.vex or PI.vxl
//               import shapes::Circle        → no Circle.vex or Circle.vxl
//
// RULE MOD11: CALLING AFTER IMPORT — always use module prefix ::
//               import std::io
//               io::println("hello")      ← module::function
//               import std::math
//               math::sqrt(16.0)          ← module::function
//               math::PI                  ← module::constant
//               import shapes
//               shapes::Circle(3.0)       ← module::Type(args) = object creation
//               shapes::Circle.unit()     ← module::Type.staticMethod
//
// RULE MOD12: IMPORT CONFLICT RULES — THREE CASES:
//
//   CASE A — MODULE NAME CONFLICT (same last segment):
//     Two imports resolve to same name → COMPILE ERROR. Must alias one.
//
//     import std::io                ← name "io"
//     import mem::io                ← name "io" — CONFLICT
//     COMPILE ERROR: module name `io` is ambiguous.
//       Fix: import mem::io as memIo
//     CORRECT:
//       import std::io              ← io::println(...)
//       import mem::io as memIo     ← memIo::flush(...)
//
//   CASE B — SELECTIVE IMPORT NAME CONFLICT:
//     Same function/type name brought into direct scope from two modules.
//     Resolved by SIGNATURE — same rules as function overloading:
//
//     DIFFERENT SIGNATURES → both imported, overload resolves at call site:
//       import std::io   { println }    ← fn println(val: any)
//       import std::log  { println }    ← fn println(val: str, level: int)
//       println("hello")      → io::println    (str matches any)
//       println("msg", 2)     → log::println   (str + int match)
//       println(3.14)         → COMPILE ERROR: ambiguous — both match
//                               Fix: io::println(3.14) or log::println(str(3.14), 0)
//
//     IDENTICAL SIGNATURES → COMPILE ERROR, must alias module:
//       import std::io   { println }    ← fn println(val: any)
//       import mylib::io { println }    ← fn println(val: any) ← same
//       COMPILE ERROR: `println` from std::io and mylib::io have identical signature.
//         Cannot resolve by overload. Fix: import mylib::io as myIo
//         then use myIo::println("hello")
//
//     SAME APPLIES TO types and constants:
//       import std::geo   { Point }     ← struct Point { x, y: float64 }
//       import mylib::geo { Point }     ← struct Point { x, y: float64 } ← same layout
//       COMPILE ERROR: `Point` imported from two modules with same definition.
//         Fix: alias one module. import mylib::geo as myGeo
//
//   CASE C — OPEN IMPORT NAME CONFLICT ({ * } shadowing):
//     Open import may shadow existing names — compiler WARNS (not error).
//     Use qualified form moduleName::name to disambiguate when needed.
//       import std::io { * }
//       import std::log { * }         ← WARNING if println exists in both
//       println("hello")              ← uses last imported module's println
//       io::println("hello")          ← unambiguous qualified form
//
//   SAME MODULE TWICE (always an error regardless of form or aliasing):
//     import std::io
//     import std::io as io2           ← COMPILE ERROR: same module imported twice

//
// RULE MOD13: Any number of modules with the same last segment can be imported as long as
//             each gets a unique alias (or only one lacks an explicit alias).
//
// RULE MOD14: ALIAS NAMING RULES:
//             Alias must be a valid identifier.
//             Alias must be unique among all aliases in the current file.
//
// RULE MOD15: MODULE INITIALIZATION ORDER
//
//   STEP 1 — DEPENDENCY ORDER (always):
//     Modules are sorted topologically (leaves of the dependency graph first).
//     A module is initialized only AFTER all modules it imports are initialized.
//
//   STEP 2 — IMPORT ORDER as tiebreaker:
//     If two modules are at the same dependency depth, they are initialized
//     in the order they appear in the importing file's import list.
//
//   STEP 3 — fn init() execution:
//     After all module globals are initialized, each module's fn init() is called.
//
//   STEP 4 — fn main() execution.
//
//   STEP 5 — fn deinit() execution at program exit in REVERSE initialization order.
//
//   EXAMPLE:
//     main.vex imports: a, b
//     a.vex imports: c
//     b.vex imports: c
//
//     Initialization order: c, a, b, main
//     Deinit order (reverse): main, b, a, c
//
//   GLOBAL VARIABLE INITIALIZATION (within a module):
//     Global `var` declarations are initialized in TOP-TO-BOTTOM order within the file.
//     Referencing a global var defined BELOW it in the same file = COMPILE ERROR.


//
// RULE MOD16: `mod` KEYWORD — CURRENT FILE MODULE SCOPE ACCESS
//
//   `mod` is a RESERVED KEYWORD identical in nature to `self` and `super`.
//   Cannot be used as: variable name, function name, type name,
//                      parameter name, loop variable, import alias.
//
//   MEANING: mod.name always refers to a declaration at the TOP LEVEL of the
//            current .vex file — the module scope — regardless of how deeply
//            nested the code is inside classes, functions, or blocks.
//
//   WHY NEEDED: when a local variable, function parameter, or class field
//   has the same name as a module-level declaration, bare name lookup finds
//   the innermost scope first and the module-level name becomes unreachable
//   without an explicit qualifier. `mod.name` always reaches module scope.
//
//   THREE-LEVEL ACCESS PATTERN:
//     var x := 100                  ← module-level (file scope)
//     class Foo {
//         pub x: int = 200          ← instance field
//         fn demo() {
//             var x := 300          ← local variable
//             x          // 300     ← local (innermost wins)
//             self.x     // 200     ← instance field (explicit self)
//             mod.x      // 100     ← module-level   (explicit mod)
//         }
//     }
//
//   mod.name resolves ONLY to module-level declarations:
//     mod.x          → module-level var/let/const x
//     mod.helperFn() → module-level fn helperFn
//     mod.MyType     → module-level struct/class/enum/type MyType
//     mod.PI         → module-level const PI
//
//   mod.name does NOT resolve to:
//     — instance fields           (use self.name)
//     — local variables           (use bare name)
//     — imported module items     (use moduleName::name)
//
//   COMPILE ERRORS:
//     var mod := 42               ERROR: `mod` is a reserved keyword
//     fn mod() { }                ERROR: `mod` is a reserved keyword
//     class mod { }               ERROR: `mod` is a reserved keyword
//     import std::io as mod       ERROR: `mod` is a reserved keyword
//     for mod in list { }         ERROR: `mod` is a reserved keyword
//     fn f(mod: int) { }          ERROR: `mod` is a reserved keyword



// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 23 — IMPORT SYSTEM — FULL RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// The import system handles four distinct cases. Each is described in full.
//
// ── CASE 1: STANDARD LIBRARY ─────────────────────────────────────────────────
//
//   Standard library modules live in: <vex_install>/lib/
//   They are distributed as .vxl (pre-compiled, no source required to ship).
//   Folder name for stdlib is always `lib`.
//
//   import std::io        → <vex_install>/lib/std/io.vxl
//   import std::math      → <vex_install>/lib/std/math.vxl
//   import std::fs        → <vex_install>/lib/std/fs.vxl
//
// ── CASE 2: LOCAL PROJECT MODULES ────────────────────────────────────────────
//
//   Local modules in your project are resolved relative to the project root.
//   They are always .vex source files (compiled as part of your build).
//
//   Project layout:
//     myproject/
//       main.vex
//       utils.vex              → import utils
//       mylib/
//         shapes.vex           → import mylib::shapes
//         math_utils.vex       → import mylib::math_utils
//
//   In main.vex:
//     import utils              → finds myproject/utils.vex
//     import mylib::shapes      → finds myproject/mylib/shapes.vex
//
// ── CASE 3: OFFICIAL VPM PACKAGES ────────────────────────────────────────────
//
//   Packages installed via `vpm install` are placed in the `libs/official/` folder.
//   The folder name `libs` (plural) distinguishes installed packages from the `lib`
//   stdlib folder.
//
//   Installed structure:
//     <project_root>/
//       libs/
//         official/
//           json@v2.1.0/          ← official registry package at exact version
//             json.vex
//             parser.vex
//           http@v1.4.0/
//             http.vex
//
//   To import after installation:
//     import json::parser         → resolves to libs/official/json@v2.1.0/parser.vex
//     import http                 → resolves to libs/official/http@v1.4.0/http.vex
//
//   The compiler reads vex.toml to know which version to pick.
//
// ── CASE 4: EXTERNAL URL PACKAGES ────────────────────────────────────────────
//
//   Packages installed from a custom URL (GitHub, direct URL, etc.) are placed in
//   `libs/external/`.
//
//   Installed structure:
//     <project_root>/
//       libs/
//         external/
//           github.com/user/mathlib@v1.2.3/
//             vectors.vex
//             matrices.vex
//           someurl.dev/pkgs/cryptoutils@main/
//             cryptoutils.vex
//
//   To import:
//     import vectors              → resolves to libs/external/github.com/user/mathlib@v1.2.3/vectors.vex
//
//   The vex.toml maps short names to full versioned paths.
//
// ── LIBRARY DISTRIBUTION — SOURCE vs COMPILED ────────────────────────────────
//
//   A library author can distribute their library in TWO forms:
//
//   FORM 1 — Source (.vex files):
//     Users get full source. Can be audited. Compiled as part of their build.
//     Place .vex files in your package folder.
//     Any user importing the package recompiles from source.
//
//   FORM 2 — Compiled (.vxl files):
//     Users get pre-compiled binary. Source is NEVER exposed.
//     Build: vpm pack --lib mypackage.vex -o mypackage.vxl
//     Distribute only the .vxl file.
//     Users still get full type checking and autocomplete (from type metadata in .vxl).
//     Users cannot read your source or see private implementations.
//
//   The import syntax is IDENTICAL for both forms. The caller does not need to
//   know or care whether they are importing .vex or .vxl — the compiler handles it.
//
//   NOTE: You can upload a normal .vex source file OR a compiled .vxl library to VPM.
//   If you upload .vxl, users never see your source. If you upload .vex, it's open source.
//
// ── DISAMBIGUATION: lib vs libs ──────────────────────────────────────────────
//
//   `lib`   — singular. Used for the Vex standard library install folder.
//             <vex_install>/lib/
//
//   `libs`  — plural. Used for all installed external packages in a project.
//             <project_root>/libs/official/   (from official VPM registry)
//             <project_root>/libs/external/   (from arbitrary URLs)
//
//   This naming prevents any collision between stdlib and user packages.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 24 — CONCURRENCY RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE CO1:  thread::spawn(lambda) → Thread. Lambda must be Send.
//            A type is Send if it's safe to transfer to another thread.
//            ~T is Send. &T is Send if T is Sync. Raw *T is NOT Send.
// RULE CO2:  channel<T>() → (Sender<T>, Receiver<T>). Unbuffered = synchronous.
//            channel<T>(N) → buffered channel with N-item buffer.
//            Sender.push(val) / Receiver.pop() → val
//            Receiver is iterable (for v in recv).
// RULE CO3:  Mutex<T> wraps T. Lock acquires exclusive access. Auto-releases.
// RULE CO4:  RwLock<T>: multiple simultaneous read locks OR one write lock.
// RULE CO5:  Atomic<T>: lock-free operations. Only for primitives (int, bool, ptr).
// RULE CO6:  select { } waits on multiple channel operations simultaneously.
//            First ready case executes. `timeout(duration)` for timeout case.
// RULE CO7:  async fn: cooperative concurrency (green threads / coroutines).
//            No OS threads created. Multiplexed on thread pool by async runtime.
// RULE CO8:  await suspends execution until Future resolves. Only inside async fn.
// RULE CO9:  async::run(future) bridges async and sync code. Blocks current thread.
// RULE CO10: Data races PREVENTED by the type system:
//            Shared mutation requires Mutex or Atomic.
//            Pure reads can be shared with &T / ~T.
//            Mutable access without sync only on owned data in one thread.



// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER C — CONCURRENCY MODEL (THREADS / ASYNC) — DEEP RULES
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — replace/expand Chapter 24 (Concurrency) in vex_final_rules.vex
// Add these rules after existing CO1–CO10 as CO11–CO30
// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 24 ADDENDUM — CONCURRENCY DEEP RULES (CO11–CO30)
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── C.1  SEND AND SYNC TRAITS ────────────────────────────────────────────────
//
// RULE CO11: SEND TRAIT
//   A type T is Send if it is safe to TRANSFER to another thread.
//   Auto-derived by compiler. Rule: T is Send iff ALL fields are Send.
//   Send types:    int, float, bool, char, byte (all primitives)
//                  ^T where T: Send
//                  ~T where T: Send + Sync (shared pointer: needs Sync too)
//                  &mut T where T: Send (exclusive borrow can be sent)
//                  Mutex<T>, RwLock<T>, Atomic<T> regardless of T
//                  structs/enums of all-Send fields
//   NOT Send:      &T (shared borrow — cannot transfer, no exclusive ownership)
//                  *T (raw pointer — no lifetime, unsafe to send)
//                  class instances containing *T or &T fields
//                  thread_local references
//
// RULE CO12: SYNC TRAIT
//   A type T is Sync if it is safe to SHARE A REFERENCE (&T) across threads.
//   Auto-derived by compiler. Rule: T is Sync iff &T is Send.
//   Sync types:    all primitives, Mutex<T> (even if T is not Sync),
//                  RwLock<T>, Atomic<T>, structs of all-Sync fields.
//   NOT Sync:      ~T (ARC pointer — clone/drop mutates refcount, needs atomics,
//                       but the inner T must be Sync for ~T to be Sync).
//                  Cell<T>, RefCell<T> (interior mutability without locks).
//                  *T raw pointer.
//
// RULE CO13: SEND/SYNC ENFORCEMENT
//   thread::spawn(lambda): compiler checks lambda's closure captures are all Send.
//   If any capture is not Send: COMPILE ERROR.
//     let r: &int = &x
//     thread::spawn(move || -> { *r })   // COMPILE ERROR: &int is not Send
//   channel::Sender<T>: T must be Send (data crosses thread boundary on push).
//   ~T is Sync if T: Sync (multiple threads can hold clones of ~T safely).
//
// ── C.2  CHANNEL RULES (CH1–CH5) ─────────────────────────────────────────────
//
// RULE CH1:  channel<T>() returns ALWAYS (Sender<T>, Receiver<T>) tuple.
//            MUST destructure: let (tx, rx) := channel::channel<T>()
//            Cannot use channel result without destructuring.
//
// RULE CH2:  Receiver<T> implements Iterable<T>.
//            for v in rx { } iterates until the channel is CLOSED and DRAINED.
//            Channel is closed by dropping all Sender<T> clones (or calling tx.close()).
//            After close: remaining buffered items are still received; then iteration ends.
//
// RULE CH3:  select { } syntax:
//            select {
//                varName := channelExpr.recv()  => { body }
//                varName := channelExpr.recv()  => { body }
//                timeout(duration)              => { body }
//                _                              => { body }   // default: non-blocking
//            }
//            Exactly ONE arm executes — the first one ready.
//            Multiple ready: chosen non-deterministically (fair random selection).
//            timeout() arm: fires after the given Duration if no channel is ready.
//            _ (default) arm: fires immediately if no channel is ready (non-blocking).
//            timeout() and _ cannot both appear in the same select block.
//
// RULE CH4:  select is NOT a loop. To repeatedly select: wrap in loop { select { } }.
//            select evaluates ALL channel expressions before waiting — channels must
//            be bound to variables before the select block.
//
// RULE CH5:  Sender<T> is Clone. Multiple senders allowed for one Receiver.
//            Receiver<T> is NOT Clone. Only one consumer allowed per channel.
//            For fan-out (one sender, multiple receivers): use ~RwLock<[]T> or
//            spawn N tasks each reading from their own channel fed by a distributor.
//
// ── C.3  MUTEX AND RWLOCK RULES ──────────────────────────────────────────────
//
// RULE CO14: Mutex<T> LOCK PROTOCOL
//   let guard := mutex.lock()       → blocks until lock acquired. Returns MutexGuard<T>.
//   *guard                          → derefs to T (read or write through guard).
//   guard dropped                   → lock automatically released (RAII).
//   mutex.tryLock() → MutexGuard<T>?  → returns null immediately if locked.
//   POISONING: if a thread panics while holding a lock, the mutex is POISONED.
//   Subsequent lock() calls return Result<MutexGuard<T>, PoisonError>.
//   Use mutex.lock().unwrap() to panic-propagate, or handle the PoisonError.
//
// RULE CO15: RwLock<T> LOCK PROTOCOL
//   let rguard := rwlock.readLock()    → shared read, blocks until no writers.
//   let wguard := rwlock.writeLock()   → exclusive write, blocks until no readers/writers.
//   Multiple readers simultaneously: OK.
//   One writer: all readers and writers blocked until writer releases.
//   STARVATION: If readers continuously arrive, writers may starve.
//   Vex RwLock uses writer-preferring implementation to avoid writer starvation.
//
// RULE CO16: LOCK ORDER DISCIPLINE (deadlock prevention)
//   Vex does NOT automatically detect or prevent deadlocks.
//   Programmer responsibility: always acquire multiple locks in a CONSISTENT GLOBAL ORDER.
//   Violating lock order → potential deadlock. No compile-time enforcement.
//   Deadlock detection: only available in debug builds via -D DEADLOCK_DETECT=true
//   (instruments lock acquisition with a wait-for graph checker).
//
// ── C.4  ATOMIC RULES ────────────────────────────────────────────────────────
//
// RULE CO17: Atomic<T> SUPPORTED TYPES
//   T must be: int, uint, int8, int16, int32, int64,
//              uint8, uint16, uint32, uint64, bool, *T (pointer).
//   NOT supported: float32, float64, str, structs (no hardware guarantee).
//   Float atomics: use Mutex<float64> instead.
//
// RULE CO18: MEMORY ORDERING OPTIONS
//   Atomic operations take an optional memory ordering parameter:
//     .load(order?)        .store(val, order?)    .add(val, order?)
//     .swap(val, order?)   .compareSwap(exp, new, order?)
//   Orderings (weakest to strongest):
//     Relaxed  → no synchronization, just atomicity. Use for statistics counters.
//     Acquire  → this load "acquires" — sees all stores before the paired Release.
//     Release  → this store "releases" — all prior stores visible after Acquire.
//     AcqRel   → both Acquire and Release (for read-modify-write like swap).
//     SeqCst   → total global order across ALL threads. Slowest. Default.
//   Default when not specified: SeqCst (safe, potentially slower).
//
// RULE CO19: compareSwap SEMANTICS
//   atomicInt.compareSwap(expected, new_val) → bool
//   If current value == expected: atomically sets to new_val, returns true.
//   Otherwise: leaves current value unchanged, returns false.
//   This is the primitive for implementing lock-free algorithms.
//   Strong form: no spurious failures (unlike weak CAS on some architectures).
//
// ── C.5  ASYNC RULES (deep) ──────────────────────────────────────────────────
//
// RULE CO20: async fn RULES
//   async fn f() -> T is sugar for: fn f() -> Future<T>
//   The future is LAZY: nothing executes until it is polled (awaited or run).
//   Calling an async fn without awaiting it = creates a Future, runs nothing.
//   Futures must not be dropped without polling to completion if they hold
//   resources (file handles, locks) — use defer or structured cleanup.
//
// RULE CO21: await RULES
//   await expr: expr must have type Future<T> or async fn return type.
//   await is ONLY valid inside an async fn. Using await outside = COMPILE ERROR.
//   await does NOT block the OS thread. It suspends the current async task.
//   The OS thread continues running other tasks while the current task waits.
//
// RULE CO22: BLOCKING INSIDE ASYNC (forbidden pattern)
//   Calling sync-blocking operations inside async fn blocks the entire OS thread:
//     WRONG: thread::sleep(1s) inside async fn → blocks thread → starves tasks
//     RIGHT: await async::sleep(1s) inside async fn → yields thread to other tasks
//   Blocking I/O (fs::readFile sync form) inside async → LINT WARNING by default.
//   Use async variants of all I/O inside async fns.
//
// RULE CO23: async::spawn vs async::run
//   async::spawn(f()) → starts task concurrently, does NOT await it.
//                        Returns JoinHandle<T>. Await later: await handle.
//   async::run(f())   → blocks calling OS thread until complete.
//                        Use ONLY at sync→async boundary (e.g., in fn main()).
//
// RULE CO24: STRUCTURED CONCURRENCY with async::all / async::race
//   async::all(f1(), f2(), f3()) → awaits ALL futures, returns tuple of results.
//   If any future returns Err: all remaining cancelled, Err propagated.
//   async::race(f1(), f2()) → returns FIRST future to complete, cancels others.
//   Cancellation: when a future is dropped mid-execution, its destructor runs,
//   releasing all resources it held (file handles, locks, allocations).
//
// ── C.6  OWN RULES (OWN1–OWN4) — referenced in spec ────────────────────────
//
// RULE OWN1: Moving a non-Copy value out of a variable:
//            var b := move a   → a is invalid, b owns the value.
//            f(move a)         → a is invalid, f's parameter owns the value.
//            Explicit `move` keyword required for ^T, ~T, class, non-Copy struct.
//
// RULE OWN2: Auto-move at last use:
//            The compiler MAY automatically move (without explicit `move` keyword)
//            a non-Copy value at its last use in a scope, if no borrow is active.
//            This is an optimization, not a guarantee. Always write `move` explicitly
//            when the semantics matter for correctness.
//
// RULE OWN3: Copy types listed (see ABI_SL2 for sizes):
//            All primitive numerics (int* uint* float* bool char byte).
//            [N]T fixed arrays where T is Copy.
//            Tuples where all elements are Copy.
//            Structs where ALL fields are Copy (compiler auto-derives Copy).
//
// RULE OWN4: Ownership and struct/class:
//            struct  = value type. Moved on assignment if non-Copy.
//            class   = reference type. Variable holds a pointer (~class semantics).
//                      Assigning a class variable increments refcount (like ~T).
//                      Use `move` to transfer without refcount increment.
//
// ── C.7  COLLECTION ITERATION ORDER RULES (COL1–COL4) ───────────────────────
//
// RULE COL1: []T dynamic list: iteration order = INSERTION ORDER. Guaranteed.
//            append adds to end. Removing from middle shifts elements.
//
// RULE COL2: [K:V] map: iteration order = UNSPECIFIED. Do NOT rely on it.
//            May change between program runs, Vex versions, or insertion patterns.
//            For ordered iteration: .entries().sortBy(...) or use OrderedMap.
//
// RULE COL3: collections::OrderedMap<K,V>: iteration order = INSERTION ORDER. Guaranteed.
//            Preserves insertion order. O(n) more memory than [K:V].
//
// RULE COL4: {}T set: iteration order = UNSPECIFIED. Do NOT rely on it.
//            For sorted iteration: .toList().sorted() or use collections::SortedSet.
//            SortedSet iterates in ascending order per T's Ord impl. Guaranteed.
//
// ── C.8  STRING RULES (STR1–STR8) — referenced in spec ──────────────────────
//
// RULE STR1: s.len() → byte count (uint64). NOT Unicode codepoint count.
//            s.charCount() → Unicode codepoint count. O(n) — full scan.
//
// RULE STR2: s[i] → byte at byte offset i. Returns uint8.
//            i is a BYTE offset. O(1).
//            Accessing inside a multi-byte codepoint: returns a raw byte, not an error.
//
// RULE STR3: s.charAt(n) → char (Unicode codepoint) at codepoint index n.
//            O(n) — must scan from start to count n codepoints.
//            Prefer iteration over repeated charAt for performance.
//
// RULE STR4: s[a..b] → byte slice. a, b are BYTE offsets.
//            If a or b split a multi-byte UTF-8 codepoint: RUNTIME PANIC.
//            s.charSlice(a, b) → char-index slice. Safe for Unicode. O(n).
//
// RULE STR5: for b in s { }        → iterates BYTES (uint8). O(n).
//            for c in s.chars() { } → iterates Unicode codepoints (char). O(n).
//
// RULE STR6: str(bytes: []byte) → Result<str, StrError>
//            Validates UTF-8. Returns Err if bytes contain invalid UTF-8 sequences.
//            str.unsafe(bytes)   → str, no validation, inside unsafe{} required.
//
// RULE STR7: str comparison (==, <, >, etc.) → ORDINAL byte-by-byte comparison.
//            NOT locale-aware. 'é' (0xC3 0xA9) > 'z' (0x7A) in ordinal order.
//            Locale-aware comparison: text::collate(a, b) from std::text.
//
// RULE STR8: str::Builder for efficient concatenation.
//            + operator on str allocates a new str each time. Use Builder in loops.
//            var sb := str::Builder(); sb.append(s1); sb.append(s2); sb.toString()
//
// ── C.9  STRUCT INIT AND STATIC FIELD RULES (SI1–SI3, SF1–SF3) ──────────────
//
// RULE SI1: Struct literal: all fields WITHOUT defaults must be provided.
//           Fields WITH defaults may be omitted — default value used.
//           struct Config { host: str = "localhost", port: int = 8080 }
//           Config { port: 9000 }    → host = "localhost" (default), port = 9000
//
// RULE SI2: var s: MyStruct  (no initializer):
//           All fields zero-initialized: int→0, float→0.0, bool→false, str→"",
//           []T→[], ?T→null, ^T→ ERROR (owned ptr cannot be null — must init).
//
// RULE SI3: Struct spread: TypeName { ...other, field: new_val }
//           Copies all fields from `other`, overrides specified fields.
//           `other` must be the same struct type.
//
// RULE SF1: static fieldName: Type = expr  inside struct/class body.
//           Stored in DATA SEGMENT. NOT in struct instances. sizeof unaffected.
//
// RULE SF2: Access static field: TypeName.fieldName  (dot on TYPE NAME).
//           NEVER: TypeName::fieldName  (:: is for modules only).
//           NEVER: instanceVar.staticField  (COMPILE ERROR — static on instance).
//
// RULE SF3: Static fields are initialized ONCE, before fn init() runs.
//           Order: module global vars first (top-to-bottom), then static fields
//           of each type (in declaration order within the type).
//
// ── C.10  DISTINCT TYPE RULES (DT1–DT5) ─────────────────────────────────────
//
// RULE DT1: distinct type NewName = BaseType  creates a NEW type.
//           NOT a type alias. NOT implicitly convertible to/from BaseType.
//
// RULE DT2: Two distinct types with same BaseType are NOT compatible with each other.
//           distinct type OrderId = int64
//           distinct type UserId  = int64
//           OrderId(1) == UserId(1)  → COMPILE ERROR (different types)
//
// RULE DT3: Construction: TypeName(baseValue)   e.g. OrderId(42)
//           Extraction:   .rawValue property    e.g. oid.rawValue → int64
//           Explicit cast: int64(oid)           e.g. same as .rawValue
//
// RULE DT4: Arithmetic NOT auto-derived for distinct types.
//           oid + oid2   → COMPILE ERROR (must implement op + explicitly)
//           Workaround: OrderId(oid.rawValue + oid2.rawValue)
//           Or implement: op +(other: OrderId) -> OrderId = OrderId(self.rawValue + other.rawValue)
//
// RULE DT5: == and != ARE auto-derived (compares rawValue).
//           match oid { OrderId(n) => ... }  binds the inner int64 as n.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 25 — INTEROPERABILITY RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE INTEROP1: Vex calls OUT only to C and C++.
//                They are native compiled languages with compatible ABI.
//                Zero runtime overhead. Direct calls.
//
// RULE INTEROP2: All other languages call INTO Vex.
//                Vex compiles to .so (shared library) or .wasm (WebAssembly).
//                The other language loads and calls Vex. Vex stays pure native.
//                Vex NEVER embeds another language's runtime.
//
// RULE INTEROP3: Why not embed Python/JS/Java runtimes in Vex?
//                Each runtime costs megabytes of memory.
//                Each call crosses a slow boundary (GC, type marshaling, locks).
//                Instead: Python/JS call Vex (fast direction).
//
// ── C INTEROP RULES ──────────────────────────────────────────────────────────
//
// RULE FFI1:  extern "C" { } declares C function signatures for linking.
// RULE FFI2:  extern "C" link("libname") { } links a specific C shared library.
// RULE FFI3:  All C function calls must be inside unsafe { } blocks.
// RULE FFI4:  C type mapping (complete):
//               C type          Vex type      Notes
//               ───────────     ─────────     ──────────────────────────
//               int             int32         always 32-bit in C ABI
//               long            int64         on 64-bit Linux/macOS
//               unsigned int    uint32
//               unsigned long   uint64
//               char            byte          uint8
//               char*           *byte         C string pointer
//               void*           *any          generic pointer
//               bool            bool
//               float           float32
//               double          float64
//               size_t          uint          platform word size
//               ptrdiff_t       int           platform word size
//               NULL            null as *any
//               struct S*       *S            pointer to Vex @packed struct
//               fn(*a,*b)->int  fn(*any,*any)->int32   function pointer
// RULE FFI5:  Vex str is NOT null-terminated. Never pass str directly to C.
//             Use ffi:: helpers from std::ffi:
//               ffi::withCString(s, |ptr| -> { })     safest — ptr cannot escape
//               ffi::toCString(s) -> ^[]byte          owned, auto-freed, use .ptr()
//               ffi::fromCString(ptr: *byte) -> str   C → Vex (copies data)
//               ffi::fromCStringLen(ptr, len) -> str
// RULE FFI6:  @export("c_name") makes a Vex fn callable from C.
// RULE FFI7:  @extern("c_name") links a C fn under a different Vex name.
// RULE FFI8:  C callbacks: the Vex function passed to C MUST be @export.
// RULE FFI9:  syscall(number, ...args) = direct OS system call (unsafe).
//
// ── C++ INTEROP RULES ────────────────────────────────────────────────────────
//
// RULE CPP1:  RECOMMENDED: write extern "C" wrapper functions in C++ and call those.
// RULE CPP2:  extern "C++" { } for direct C++ calls (mangled names — fragile).
// RULE CPP3:  asm cpp { } = inline C++ code block. Compiled by clang++/g++.
//
// ── INLINE CODE RULES ────────────────────────────────────────────────────────
//
// RULE ASM1:  asm c { }       = inline C code.
// RULE ASM2:  asm cpp { }     = inline C++ code.
// RULE ASM3:  asm x86_64 { }  = inline x86_64 assembly.
// RULE ASM4:  asm arm64 { }   = inline ARM64 assembly.
// RULE ASM5:  in("reg") varName   = pass Vex variable as input to asm.
//             out("reg") varName  = receive asm output into Vex variable.
// RULE ASM6:  All asm blocks are implicitly unsafe.
//
// ── STRUCT LAYOUT RULES ──────────────────────────────────────────────────────
//
// RULE LAYOUT1: @packed = no padding between fields.
// RULE LAYOUT2: @align(N) = struct aligned to N bytes. N must be power of 2.
// RULE LAYOUT3: @derive(C_Layout) = compiler verifies layout matches C struct.
// RULE LAYOUT4: bitfield struct Name: BaseType { field: bits }
//               Fields are bit-packed into BaseType (must be integer type).
//
// ── EXPORT RULES ─────────────────────────────────────────────────────────────
//
// RULE EXP1:  vex build --shared main.vex -o libname.so
// RULE EXP2:  @export("name") marks a pub fn as exported from the .so.
// RULE EXP3:  Python loads via ctypes.CDLL or cffi.
// RULE EXP4:  Ruby loads via Fiddle.
// RULE EXP5:  Any C-ABI-compatible language can call @export functions.
//
// ── WASM RULES ───────────────────────────────────────────────────────────────
//
// RULE WASM1: vex build --target wasm main.vex -o mylib.wasm
// RULE WASM2: @wasmExport("name") marks a pub fn as exported from the .wasm.
// RULE WASM3: WASM only supports int32, int64, float32, float64 at the boundary.
//             Strings and arrays must be passed via WASM linear memory.
// RULE WASM4: JS reads/writes WASM memory via WebAssembly.Memory buffer.
// RULE WASM5: No JS runtime runs inside Vex. Vex is the computation engine.
//
// ── DYNAMIC LOADING RULES ────────────────────────────────────────────────────
//
// RULE DYN1:  ffi::dlopen("libname.so") -> Result<DynLib, str>
// RULE DYN2:  lib.symbol<FnType>("name") -> Result<FnType, str>
// RULE DYN3:  All dynamic function calls must be inside unsafe { }.
// RULE DYN4:  DynLib auto-unloads when it goes out of scope (RAII).


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER E — STRUCT / ENUM ABI LAYOUT
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── E.1  DEFAULT STRUCT LAYOUT ───────────────────────────────────────────────
//
// RULE ABI1:  DEFAULT STRUCT FIELD LAYOUT ALGORITHM
//   The compiler lays out struct fields in DECLARATION ORDER with natural alignment.
//   For each field, the compiler:
//     a. Aligns the current byte offset UP to the alignment of the field's type.
//     b. Places the field at that offset.
//     c. Advances the byte offset by sizeof(field type).
//   After all fields, the struct size is rounded up to a multiple of the struct's
//   overall alignment (which is the maximum of all field alignments).
//
//   NATURAL ALIGNMENT TABLE:
//     Type         sizeof    alignof
//     ──────────   ───────   ───────
//     bool         1         1
//     int8/uint8   1         1
//     int16/uint16 2         2
//     int32/uint32 4         4
//     int64/uint64 8         8
//     float32      4         4
//     float64      8         8
//     *T (pointer) 8         8  (on 64-bit)
//     ^T           8         8  (pointer-sized)
//     ~T           8         8  (pointer-sized)
//     &T           8         8  (pointer-sized)
//     char         4         4  (Unicode codepoint)
//     byte         1         1
//     [N]T         N*sizeof(T)  alignof(T)
//     (A,B) tuple  sizeof(A)+pad+sizeof(B)  max(alignof(A), alignof(B))
//
// RULE ABI2:  STRUCT LAYOUT EXAMPLE
//   struct Example { a: int8, b: int64, c: int32, d: bool }
//   Offset 0:  a: int8   (size 1, align 1)
//   Offset 1:  3 bytes padding (to align b to 8)
//   Offset 4:  NO — b needs align 8: round up to offset 8
//   Wait — a at 0, next is offset 1, b needs align 8, so pad to offset 8.
//   Offset 8:  b: int64  (size 8, align 8)
//   Offset 16: c: int32  (size 4, align 4)
//   Offset 20: d: bool   (size 1, align 1)
//   Offset 21: 3 bytes padding (struct total must be multiple of 8 = align of b)
//   Total size: 24 bytes.
//
//   COMPILER NOTE: The compiler MAY reorder fields for smaller structs when NO
//   C_Layout or @packed attribute is present, if reordering reduces padding.
//   Reordering is performed by the "field sort" pass: sort fields by decreasing
//   alignment (largest first), secondary sort by declaration order.
//   HOWEVER: if the struct has @derive(C_Layout) OR @packed, NO reordering occurs —
//   fields stay in declaration order.
//
// RULE ABI3:  @packed LAYOUT
//   With @packed: NO padding between fields. Fields placed at CONSECUTIVE bytes.
//   Accessing unaligned fields MAY generate slower code (multiple loads on x86).
//   On ARM64, unaligned access may trap unless the CPU supports it.
//   @packed is ONLY for C interop and hardware register structs. Do NOT use elsewhere.
//
// RULE ABI4:  @align(N) LAYOUT
//   Forces the struct's starting alignment to N bytes (N must be power of 2).
//   Individual field alignments are unchanged; only the struct start is forced.
//   The struct size is padded to a multiple of N.
//   Useful for SIMD (align 16 or 32) and cache-line alignment (align 64).
//
// ── E.2  ENUM ABI LAYOUT ─────────────────────────────────────────────────────
//
// RULE ABI5:  ENUM LAYOUT — TAGGED UNION
//   An enum with data variants is laid out as a TAGGED UNION:
//     [ tag: uint32 | padding | largest_variant_data ]
//   The tag identifies the active variant at runtime.
//   The data section is the size of the LARGEST variant's data, aligned to the
//   largest alignment required by any variant's fields.
//   All variants share the same data section (union-style memory overlap).
//
//   EXAMPLE:
//     enum Shape {
//         Circle(r: float64)         → data: f64 (8 bytes)
//         Rect(w: float64, h: float64) → data: f64 + f64 (16 bytes)
//         Point                      → data: none (0 bytes)
//     }
//   Tag: uint32 (4 bytes), padding: 4 bytes, data: 16 bytes (Rect is largest).
//   Total: 24 bytes. All variants use the same 24-byte allocation.
//
// RULE ABI6:  ENUM TAG VALUES
//   Tag values are assigned in DECLARATION ORDER, starting at 0:
//     Variant 0 = 0, Variant 1 = 1, Variant 2 = 2, ...
//   For const enum, tag values are the explicit integer values assigned:
//     const enum Flags: uint32 { Read = 1, Write = 2, Exec = 4 }
//   For regular enums, tag is ALWAYS uint32 regardless of variant count
//   (simplifies FFI and predictable layout). Future: compiler may shrink tag
//   to uint8/uint16 as an optimization when @derive(C_Layout) is not present.
//
// RULE ABI7:  ENUM NICHE OPTIMIZATION
//   For enums where one variant is a non-nullable pointer type (^T, ~T, &T),
//   the compiler may use the NULL pointer value as the tag for a no-data variant,
//   eliminating the tag field entirely (niche optimization).
//   EXAMPLE: Result<^T, E> where Ok holds ^T:
//     Null pointer → Err variant.  Non-null pointer → Ok variant.
//     Size = sizeof(^T) + sizeof(E) instead of sizeof(tag) + max(sizeof(^T), sizeof(E)).
//   This optimization is ONLY applied when:
//     a. Exactly TWO variants, one with data and one without (or a small-data one).
//     b. @derive(C_Layout) is NOT present (niche changes ABI).
//   The compiler emits a note in -v (verbose) mode when niche optimization applies.
//
// RULE ABI8:  ENUM IN C FFI
//   Only const enum (integer-backed) is safe to pass directly across C FFI.
//   Regular enums with data variants must NEVER be passed directly to C.
//   To pass a tagged-union enum to C:
//     a. Declare a @packed struct with a uint32 tag + a union of data variants.
//     b. Write conversion functions between the Vex enum and the C struct.
//
// ── E.3  TUPLE ABI LAYOUT ────────────────────────────────────────────────────
//
// RULE ABI9:  TUPLE LAYOUT
//   A tuple (A, B, C) is laid out as an anonymous struct with fields .0, .1, .2.
//   Same natural alignment rules as struct (RULE ABI1) apply.
//   Field reordering for size optimization MAY occur (same rule as structs).
//   Tuples are anonymous — they have no name, no methods, no impl blocks.
//
// ── E.4  STR ABI LAYOUT ──────────────────────────────────────────────────────
//
// RULE ABI10: str INTERNAL REPRESENTATION
//   str is a FAT POINTER: { ptr: *uint8, len: uint64 }
//   ptr → immutable UTF-8 byte data on the heap (or in read-only data segment
//         for string literals).
//   len → byte length (NOT character count).
//   str literals are deduplicated into the LLVM read-only data section.
//   str does NOT store a null terminator (it is NOT a C string).
//   sizeof(str) = 16 bytes on 64-bit platforms.
//
// RULE ABI11: []T (dynamic list) INTERNAL REPRESENTATION
//   []T is: { ptr: *T, len: uint64, cap: uint64 }
//   ptr → heap-allocated T array.
//   len → number of live elements.
//   cap → allocated capacity (cap >= len always).
//   sizeof([]T) = 24 bytes on 64-bit platforms.
//   Growth strategy: double capacity when full (amortized O(1) append).




// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER A — ABI & DATA LAYOUT
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — paste after Chapter 25 (Interoperability) in vex_final_rules.vex
// as CHAPTER 25-A — ABI & DATA LAYOUT
// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 25-A — ABI & DATA LAYOUT
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── A.1  CALLING CONVENTION ──────────────────────────────────────────────────
//
// RULE ABI_CC1:  VEX NATIVE CALLING CONVENTION
//   Vex uses the PLATFORM SYSTEM ABI as its native calling convention:
//     Linux / macOS x86-64  → System V AMD64 ABI
//     Windows x86-64        → Microsoft x64 ABI
//     Linux / macOS arm64   → AAPCS64 (ARM64 Procedure Call Standard)
//     WASM                  → WASM calling convention (operand stack)
//   Vex does NOT define a custom calling convention. Using the system ABI
//   means Vex functions are directly callable from C with zero adapter overhead.
//
// RULE ABI_CC2:  SYSTEM V AMD64 ABI (Linux / macOS x86-64) — integer arguments:
//   Arguments passed in registers (left to right): rdi, rsi, rdx, rcx, r8, r9
//   Additional arguments: pushed on stack right-to-left.
//   Return value: rax (64-bit), rax+rdx (128-bit), xmm0 (float64).
//   Callee-saved registers: rbx, rbp, r12–r15. Caller saves rest.
//   Stack alignment: 16 bytes before any call instruction.
//   Red zone: 128 bytes below rsp may be used by leaf functions (no signal safety).
//
// RULE ABI_CC3:  SYSTEM V AMD64 ABI — float / SIMD arguments:
//   Float32 / float64 arguments: xmm0–xmm7 (first 8 float args).
//   Additional float args: pushed on stack.
//   SIMD (Vec4f @align(16)): passed in xmm0–xmm7 if fits, else by pointer.
//
// RULE ABI_CC4:  MICROSOFT x64 ABI (Windows x86-64):
//   Integer args: rcx, rdx, r8, r9. Float args: xmm0–xmm3.
//   Shadow space: 32 bytes reserved on stack above return address (always).
//   No red zone. Stack aligned to 16 bytes before call.
//   Callee-saved: rbx, rdi, rsi, rbp, r12–r15, xmm6–xmm15.
//
// RULE ABI_CC5:  STRUCT ARGUMENT PASSING
//   Structs <= 16 bytes (SysV) or <= 8 bytes (Win64): passed in registers if
//   field types fit. Otherwise: passed by pointer (hidden first argument).
//   Return value struct > 16 bytes: caller allocates stack space, passes pointer
//   in rdi (SysV) or rcx (Win64) as hidden first arg; function fills it.
//   @packed structs always passed by pointer regardless of size.
//
// RULE ABI_CC6:  VARIADIC FUNCTION ABI
//   Vex variadic (fn f(x: ...T)) always passes variadic args as []T on the
//   Vex side. No C va_list involved. The []T fat pointer (ptr+len) is passed.
//   C variadic functions (declared in extern "C" as ...any): use C va_list
//   conventions per the platform ABI. Called only inside unsafe{}.
//
// ── A.2  STRUCT DATA LAYOUT ──────────────────────────────────────────────────
//
// RULE ABI_SL1:  DEFAULT STRUCT LAYOUT ALGORITHM
//   For each field in declaration order:
//     1. Align current byte offset UP to alignof(field_type).
//     2. Place field at that offset.
//     3. Advance offset by sizeof(field_type).
//   After all fields: pad total size to multiple of struct's overall alignment.
//   Struct alignment = max(alignof(field)) across all fields.
//   Compiler MAY reorder fields to minimize padding UNLESS:
//     @derive(C_Layout) is present, OR @packed is present.
//   Reorder strategy: sort by descending alignof, stable (preserve decl order for ties).
//
// RULE ABI_SL2:  PRIMITIVE TYPE SIZES AND ALIGNMENTS (64-bit platform):
//
//   Type            sizeof    alignof    Notes
//   ──────────────  ───────   ───────    ─────────────────────────────────────
//   bool            1         1
//   int8 / uint8    1         1
//   byte            1         1          alias for uint8
//   int16 / uint16  2         2
//   int32 / uint32  4         4
//   float32         4         4
//   char            4         4          Unicode codepoint (UTF-32 scalar)
//   int64 / uint64  8         8
//   float64         8         8
//   int / uint      8         8          platform word — 64-bit on 64-bit targets
//   int128 / uint128 16       16
//   *T              8         8          raw pointer (all pointer types)
//   ^T              8         8          owned pointer
//   ~T              8         8          shared pointer (pointer to ARC block)
//   &T              8         8          borrow reference
//   &mut T          8         8          mutable borrow reference
//   str             16        8          fat pointer: { *uint8, uint64 }
//   []T             24        8          fat pointer: { *T, uint64, uint64 }
//   [K:V]           24        8          fat pointer to hash map internals
//   {}T             24        8          fat pointer to hash set internals
//   fn(A)->R        8         8          function pointer (plain fn, no capture)
//   (A,B) tuple     sizeof(struct{A,B})  same rules as anonymous struct
//   [N]T            N*sizeof(T)  alignof(T)
//
// RULE ABI_SL3:  @packed LAYOUT
//   All padding eliminated. Fields packed at consecutive byte offsets.
//   Struct alignment = 1 (unless @align(N) also specified).
//   Accessing unaligned fields emits multiple-byte loads — legal on x86-64,
//   may trap on ARM64 if CPU lacks unaligned-access support.
//   Use ONLY for hardware register maps and C struct interop.
//
// RULE ABI_SL4:  @align(N) LAYOUT
//   Forces struct starting address to be a multiple of N bytes.
//   N must be a power of 2 and >= 1.
//   Field internal layout is unchanged; only the struct start and size rounding change.
//   struct size is padded to multiple of max(N, max_field_align).
//   Example: @align(64) for cache-line isolation (avoids false sharing).
//
// RULE ABI_SL5:  STATIC FIELDS — NOT STORED IN STRUCT INSTANCES
//   static fieldName: Type = value  declared inside a struct/class body.
//   Static fields are stored in the module's DATA SEGMENT (BSS or rodata),
//   NOT inside any struct instance. They have a single global address.
//   sizeof(MyStruct) does NOT include any static fields.
//
// ── A.3  ENUM DATA LAYOUT ────────────────────────────────────────────────────
//
// RULE ABI_EL1:  TAGGED-UNION LAYOUT (regular enum with data variants):
//   [ tag: uint32 | alignment_padding | data: max_variant_payload ]
//   Tag at offset 0, size 4. Padding inserted after tag to align data section.
//   Data section size = sizeof(largest data variant), aligned to max variant align.
//   All variants share the data section (union-style overlap).
//   Total size padded to multiple of max(4, max_variant_align).
//
// RULE ABI_EL2:  TAG VALUE ASSIGNMENT
//   Variants assigned tags in declaration order: 0, 1, 2, …
//   Reserved tag value: uint32::MAX — used internally as "uninit sentinel".
//   For const enum: explicit integer values replace auto-assigned tags.
//
// RULE ABI_EL3:  NICHE OPTIMIZATION (automatic, no user syntax)
//   Applied when ALL of the following are true:
//     a. Exactly two variants: one with a non-nullable pointer payload (^T ~T &T),
//        one with no data OR small data that fits in unused pointer bit patterns.
//     b. @derive(C_Layout) is NOT present (niche changes the ABI).
//   Effect: null pointer value serves as the discriminant for the null-data variant.
//   Tag field eliminated entirely. sizeof(enum) = sizeof(pointer payload).
//   Most common case: Result<^T, ()> and T? for pointer types — both become
//   single pointer width (8 bytes) with null = Err/null.
//
// RULE ABI_EL4:  const enum LAYOUT
//   Backed by BaseType (uint8, uint16, uint32, uint64).
//   No data payload. sizeof(const enum E: uint32) = 4.
//   Bit operations (|, &, ^, ~) valid directly on const enum values.
//   C-compatible by default — no tag overhead, same binary representation.
//
// ── A.4  SPECIAL TYPE LAYOUTS ────────────────────────────────────────────────
//
// RULE ABI_SP1:  str INTERNAL LAYOUT
//   struct { ptr: *uint8, len: uint64 }   // 16 bytes, align 8
//   ptr  → heap or rodata UTF-8 byte sequence. NOT null-terminated.
//   len  → byte count (NOT codepoint count).
//   String literals: ptr into LLVM rodata section, refcount not used.
//   Heap strings: ptr into heap block managed by str::Builder or slice ops.
//
// RULE ABI_SP2:  []T DYNAMIC LIST INTERNAL LAYOUT
//   struct { ptr: *T, len: uint64, cap: uint64 }  // 24 bytes, align 8
//   ptr  → heap-allocated T array.
//   len  → count of live elements (0 ≤ len ≤ cap).
//   cap  → allocated capacity in elements.
//   Growth factor: 2x when len == cap (amortized O(1) append).
//   Empty list: ptr = null, len = 0, cap = 0. No heap allocation until first append.
//
// RULE ABI_SP3:  [K:V] MAP INTERNAL LAYOUT
//   Open-addressing hash table. Fat pointer: { ptr: *MapBlock<K,V>, len, cap }
//   Load factor threshold: 0.75 (resize when len > 0.75 * cap).
//   Iteration order: NOT guaranteed. Depends on hash and insertion history.
//   Use collections::OrderedMap<K,V> for guaranteed insertion order.
//
// RULE ABI_SP4:  ~T ARC BLOCK LAYOUT
//   struct ArcBlock<T> {
//       strong: atomic<uint64>,    // strong reference count
//       weak:   atomic<uint64>,    // weak reference count
//       value:  T,                 // the actual value (natural alignment)
//   }
//   ~T pointer points to &value field (NOT to start of ArcBlock).
//   Strong count starts at 1 at creation. Weak count starts at 1 (the strong
//   pointer itself holds one implicit weak to keep the block alive).
//   Block freed when strong == 0 AND weak == 0.
//
// RULE ABI_SP5:  INTERFACE / TRAIT OBJECT LAYOUT (fat pointer)
//   When a concrete type is passed where an interface type is expected:
//   { data_ptr: *T, vtable_ptr: *VTable }   // 16 bytes, align 8
//   VTable layout:
//     [ 0]  sizeof_T:   uint64
//     [ 8]  alignof_T:  uint64
//     [16]  deinit_fn:  *fn(*T)             // null if no deinit
//     [24]  method_0:   *fn(...)
//     [32]  method_1:   *fn(...)
//     ...   (one entry per interface method, in declaration order)
//   VTable is a static read-only global per (concrete type, interface) pair.
//   One vtable shared across all instances of that (type, interface) pair.
//
// ── A.5  WASM DATA LAYOUT ────────────────────────────────────────────────────
//
// RULE ABI_WA1:  WASM LINEAR MEMORY LAYOUT
//   Vex WASM target uses a single linear memory:
//     [0x0000]         Reserved (null pointer sentinel)
//     [0x0001–0x0FFF]  Stack (grows down from a configured base)
//     [0x1000–...]     Heap (grows up, managed by wasm allocator)
//     [end–end+N]      rodata (string literals, vtables, static data)
//   Stack size: configurable, default 1 MB.
//
// RULE ABI_WA2:  WASM BOUNDARY TYPES
//   Only int32, int64, float32, float64 cross WASM export/import boundaries.
//   str, []T, structs: passed via linear memory (write to WASM memory, pass offset+length).
//   JS interop pattern for str:
//     1. Call vex_alloc(len) from JS → returns int32 offset.
//     2. Write UTF-8 bytes into memory at offset.
//     3. Call exported Vex fn(offset: int32, len: int32).
//     4. Vex fn reconstructs str from linear memory pointer.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 26 — SCOPING & LIFETIME RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE SC1: { } creates a new scope. Variables declared inside are freed at }.
// RULE SC2: Lexical scoping: inner scope can read outer scope variables.
// RULE SC3: Shadowing: inner scope can redeclare same name (outer still exists).
// RULE SC4: Lifetime of a value = the scope where it's declared.
// RULE SC5: Borrow (&T) lifetime: borrow must not outlive the borrowed value.
//           Compiler tracks this. Returning a borrow to a local variable = error.
// RULE SC6: defer runs at the END of the scope it's declared in (not function end).
// RULE SC7: use let x := resource { } — resource's lifetime IS the block.
// RULE SC8: Closures extending lifetime: copy/move capture extends lifetime of
//           captured values to match the closure's lifetime.

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 27 — DECORATOR RULES
// ═══════════════════════════════════════════════════════════════════════════════
//
// RULE D1:  @decorator applied to the item immediately below it.
// RULE D2:  Multiple decorators stack. Applied bottom-up (closest to item first).
// RULE D3:  Custom decorator: mark a comptime fn with @decorator_def.
// RULE D4:  Built-in decorators with parameters: @retry(3)  @deprecated("use f2")
// RULE D5:  @test functions: only compiled and run with `vex test` command.
// RULE D6:  @derive(Trait1, Trait2): auto-generate trait implementations.
//           Supported: Clone Debug Eq Ord Hash Default Display C_Layout
// RULE D7:  @export("name"): function visible from C. Uses C calling convention.
// RULE D8:  @packed: struct fields have no padding.
// RULE D9:  @align(N): struct has N-byte alignment (N must be power of 2).
// RULE D10: @pure: compiler may cache/inline calls. No observable side effects.


// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER G — @derive AUTO-IMPLEMENTATION RULES
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — expand RULE D6 in Chapter 27 (Decorator Rules)
// Add rules DRV1–DRV10 immediately after RULE D6
// ════════════════════════════════════════════════════════════════════════════════

// ── RULE D6 EXPANDED — @derive AUTO-IMPLEMENTATIONS ──────────────────────────
//
// RULE DRV1:  @derive(TraitList) generates trait implementations automatically.
//   Applied to struct, class, or enum. Multiple traits comma-separated.
//   The compiler generates code at compile time — no runtime cost beyond what
//   a hand-written impl would cost.
//   COMPILE ERROR if @derive is applied to a trait or interface.
//
// RULE DRV2:  @derive(Clone) GENERATES:
//   fn clone() -> Self {
//       Self { field1: self.field1.clone(), field2: self.field2.clone(), ... }
//   }
//   For enum: each variant's data fields are cloned.
//   REQUIRES: all fields must also implement Clone.
//   Copy types: their clone() is just a bitcopy (zero-cost).
//
// RULE DRV3:  @derive(Debug) GENERATES:
//   fn toRepr() -> str
//   Output format: "TypeName { field1: <repr of field1>, field2: <repr of field2> }"
//   For enum: "VariantName(field1: val, ...)" or "VariantName" for no-data variants.
//   REQUIRES: all fields must implement Debug (have toRepr()).
//   Used by {x!r} format conversion and in panic messages.
//
// RULE DRV4:  @derive(Display) GENERATES:
//   op str() -> str
//   Output format: "TypeName(field1=<str of field1>, field2=<str of field2>)"
//   For enum: "VariantName(val)" or "VariantName" for no-data.
//   REQUIRES: all fields must have op str() or implement Display.
//   Used by f"{x}" without specifier.
//
// RULE DRV5:  @derive(Eq) GENERATES:
//   op ==(other: Self) -> bool {
//       self.field1 == other.field1 && self.field2 == other.field2 && ...
//   }
//   Also auto-derives !=.
//   For enum: compares tags first; if equal, compares data fields.
//   REQUIRES: all fields must implement Eq (have op ==).
//
// RULE DRV6:  @derive(Ord) GENERATES:
//   fn compareTo(other: Self) -> int
//   Lexicographic comparison: compares fields in DECLARATION ORDER.
//   First unequal field determines result. Returns -1, 0, or +1.
//   Also auto-derives <, >, <=, >= from compareTo.
//   For enum: compare by tag value first; equal tags → compare data fields.
//   REQUIRES: all fields must implement Ord.
//   ALSO REQUIRES: @derive(Eq) or existing op == (Ord implies Eq).
//
// RULE DRV7:  @derive(Hash) GENERATES:
//   fn hash() -> uint64
//   Combines hashes of all fields using a mixing function (FNV-1a or similar).
//   For enum: mixes tag value with data field hashes.
//   REQUIRES: all fields must implement Hash.
//   Hash is consistent within a single run but NOT across runs (randomized seed).
//   Do NOT serialize hash values or rely on them being stable across program runs.
//
// RULE DRV8:  @derive(Default) GENERATES:
//   static fn default() -> Self
//   Returns an instance with all fields set to their DEFAULT VALUES:
//     int / uint / float → 0      bool → false     char → '\0'
//     str → ""                    []T → []          T? → null
//     ^T → COMPILE ERROR (owned ptr has no default; cannot be null)
//     Struct field with explicit default value → uses that value
//   For enum: returns the FIRST declared variant with no data.
//   COMPILE ERROR if no zero-arg variant exists for enum with @derive(Default).
//
// RULE DRV9:  @derive(C_Layout) GENERATES:
//   No runtime code. Instructs compiler to:
//     a. FREEZE field declaration order (no reordering optimization).
//     b. Use NATURAL ALIGNMENT with no compiler-inserted reordering.
//     c. Verify (at compile time) that the struct layout matches what a C compiler
//        would produce for the equivalent C struct with the same field types.
//   If the layout would differ from C: COMPILE ERROR with explanation.
//   @derive(C_Layout) is often combined with @packed or @align(N).
//
// RULE DRV10: @derive DEPENDENCY CHAIN
//   Some traits require others:
//     Ord      requires Eq
//     Hash     does NOT require Eq (but is typically used with it)
//     Display  does NOT require Debug
//   If you write @derive(Ord) without Eq being implemented: COMPILE ERROR.
//   Shorthand: @derive(Eq, Ord) handles the dependency automatically.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 28 — COMPILER PIPELINE
// ═══════════════════════════════════════════════════════════════════════════════
//
//  Phases:
//    1.  LEXER           → tokens
//    2.  PARSER          → AST (Pratt parser for expressions, recursive descent for stmts)
//    3.  IMPORT RESOLVER → resolve imports, build dependency DAG
//                          → detect cycles (COMPILE ERROR if found)
//                          → detect last-segment alias conflicts (COMPILE ERROR)
//                          → build initialization order (topological sort)
//                          → verify last :: segment is a .vex or .vxl file (not a fn/type)
//    4.  SYMBOL TABLE    → collect all top-level declarations
//    5.  VISIBILITY CHECK→ verify all access respects pub/priv/prot/internal
//    6.  TYPE CHECKER    → infer types, check constraints, resolve generics
//    7.  MRO RESOLVER    → resolve method lookup order, detect trait conflicts
//    8.  BORROW CHECKER  → verify ownership, lifetimes, pointer conversions
//    9.  COMPTIME EVAL   → evaluate all comptime expressions, specialize generics
//                          → enforce comptime allow/deny list (CT2/CT3)
//   10.  LOWERING        → AST → IR
//   11.  OPTIMIZER       → constant folding, inlining, dead code elimination
//   12.  MONOMORPHIZER   → generate specialized copies for each generic instantiation
//   13.  CODE GEN        → IR → LLVM IR → machine code (x86_64 / arm64 / wasm)
//   14.  LINKER          → link modules + C libraries → executable / .vxl / .so
//
//  BACKEND: LLVM. The code generation phase emits LLVM IR, which is then compiled
//  and optimized by LLVM. This gives access to LLVM's full optimization pipeline
//  and targets all LLVM-supported architectures automatically.
//
//  Key parser notes:
//    - T in `fn f<T>(...)` is parsed as: fn-name is `f`, generic-param is `T`
//    - |params| -> body: lexer sees | and checks if next tokens form params
//      If inside lambda context: lambda start. Otherwise: bitwise OR.
//    - { }: context-sensitive: after type name or . = struct literal. Standalone = block.
//    - *x vs *T: * before type in type position = pointer type. * before expr = dereference.


// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER G — RUNTIME vs COMPILER RESPONSIBILITY BOUNDARY
// ═══════════════════════════════════════════════════════════════════════════════
//
// This chapter defines exactly what the COMPILER guarantees at compile time
// vs what the RUNTIME LIBRARY is responsible for at execution time.
//
// ── G.1  COMPILER GUARANTEES (static, zero runtime cost) ────────────────────
//
// RULE RTB1:  THE COMPILER IS RESPONSIBLE FOR:
//
//   Memory safety:
//     — Borrow checking (no use-after-free, no double-free, no dangling pointers).
//     — Lifetime tracking (borrows never outlive their owners).
//     — Move semantics (moved values cannot be used).
//     — Ownership uniqueness (^T has exactly one owner).
//     ALL enforced at compile time. Zero runtime checks for these.
//
//   Type safety:
//     — Every expression has a known, correct static type.
//     — No implicit type coercion (except defined implicit promotions in RULE T7).
//     — Generic type parameter satisfaction (trait bounds checked at instantiation).
//     — Exhaustiveness of match (all variants covered).
//     ALL enforced at compile time.
//
//   Control flow:
//     — Unreachable code after never-returning expressions (panic, never type).
//     — ? operator produces correct early-return code.
//     — Tail-call recognition and optimization marker insertion.
//     ALL done by the compiler before emitting LLVM IR.
//
//   Concurrency (static):
//     — Send/Sync trait enforcement: prevents non-Send types from crossing threads.
//     — Borrow checker prevents data races on stack/owned data.
//     — Shared mutation requires Mutex/Atomic (enforced via type system).
//     ALL enforced at compile time. No runtime data-race detection in production.
//
//   Code generation:
//     — Monomorphization of all generics.
//     — Lowering of ?, ??, ?., match, defer, use, and all control flow.
//     — Vtable generation for interface types.
//     — Enum tag/data layout per ABI rules.
//     — Import resolution, name resolution, visibility enforcement.
//     — Drop-point insertion (where to free ^T, where to call deinit).
//
// ── G.2  RUNTIME LIBRARY RESPONSIBILITIES ────────────────────────────────────
//
// RULE RTB2:  THE RUNTIME LIBRARY (vex_rt) IS RESPONSIBLE FOR:
//
//   Memory allocation:
//     — vex_alloc(size, align): allocates heap memory.
//       Uses jemalloc by default (better performance than system malloc for
//       many small allocations). Falls back to system malloc with --no-rt flag.
//     — vex_free(ptr): frees heap memory.
//     — The compiler inserts CALLS to these; the runtime provides the IMPLEMENTATION.
//
//   ARC operations:
//     — vex_arc_retain(ptr): atomically increment refcount.
//     — vex_arc_release(ptr): atomically decrement refcount; free if zero.
//     — vex_arc_alloc(size, align): allocate with ARC header.
//     — The compiler DECIDES when to call these; the runtime EXECUTES them.
//
//   Panic handling:
//     — vex_panic(msg, file, line): print, stack trace, abort.
//     — vex_panic_begin / vex_panic_end: setjmp/longjmp for try/catch.
//     — Stack unwinding (backtrace collection with -g builds).
//
//   String operations:
//     — UTF-8 validation (str::from([]byte)).
//     — String formatting engine (f"..." with format specifiers).
//     — String hashing (for map keys).
//
//   Async runtime:
//     — Green thread scheduler (M:N thread model — many tasks on few OS threads).
//     — Future poll loop (async::run()).
//     — I/O event loop (epoll/kqueue/IOCP per platform).
//     — Task queue, work-stealing across OS threads.
//     — The COMPILER generates Future state machines; the runtime SCHEDULES them.
//
//   Thread management:
//     — thread::spawn: creates an OS thread.
//     — thread::join: waits for OS thread completion.
//     — Thread-local storage initialization.
//
//   Channel / sync primitives:
//     — Channel send/receive queue implementation (with backpressure for buffered).
//     — Mutex/RwLock implementation (using OS futex or POSIX mutexes).
//     — Atomic operations (thin wrappers around LLVM atomic IR → CPU instructions).
//
//   Module initialization:
//     — vex_rt_init: calls fn init() for all modules in topological order.
//     — vex_rt_deinit: calls fn deinit() for all modules in reverse order at exit.
//
//   Stack overflow detection:
//     — Guard pages at the bottom of each thread's stack.
//     — Signal handler converts SIGSEGV on guard page to a panic("stack overflow").
//
//   Type introspection (for `any` and runtime casts):
//     — typeid table: maps each type to a unique uint64 ID at runtime.
//     — vex_type_name(typeid): returns the type name as a str.
//     — Used by `as` and `as?` type assertions.
//
// ── G.3  WHAT NEITHER COMPILER NOR RUNTIME DOES ──────────────────────────────
//
// RULE RTB3:  NO GARBAGE COLLECTOR
//   VEX has no garbage collector. Memory is:
//     — Stack values: freed at scope exit (compiler-inserted).
//     — ^T owned heap: freed when owner goes out of scope (compiler-inserted).
//     — ~T shared heap: freed when refcount hits 0 (runtime ARC — vex_arc_release).
//   There is no GC pause, no GC thread, no GC metadata in the heap.
//
// RULE RTB4:  NO IMPLICIT RUNTIME TYPE ERASURE
//   Generics are monomorphized — no type erasure, no boxing of generic values,
//   no runtime type metadata for generic functions (only for interface vtables).
//   sizeof(Box<int>) = sizeof(int). No wrapper overhead.
//
// RULE RTB5:  NO IMPLICIT RUNTIME BOUNDS CHECKING (in release builds)
//   Array index bounds checking (arr[i]) is:
//     — ON  in debug builds (-O0, -g): compiler inserts explicit bounds check.
//     — OFF in release builds (-O2, -O3): bounds checks removed for speed.
//       If you need bounds safety in release: use arr.get(i) → T? (returns null
//       instead of panicking) or arr.safeAt(i) → Result<T, BoundsError>.
//
// ── G.4  MINIMAL RUNTIME MODE (--no-rt) ──────────────────────────────────────
//
// RULE RTB6:  --no-rt FLAG (bare metal / OS kernel / WASM without WASI)
//   With --no-rt, the following are UNAVAILABLE:
//     — async runtime (no green threads, no async::run)
//     — channel, Mutex, RwLock (require OS primitives)
//     — thread::spawn (requires OS threads)
//     — str::Builder with heap growth (no allocator)
//     — fs::, net:: modules (require OS syscalls)
//     — panic stack traces (no backtrace library)
//     — Module init/deinit ordering (fn init() still runs, but called by user)
//   Still AVAILABLE with --no-rt:
//     — All compile-time features (comptime, generics, macros)
//     — Stack memory, fixed arrays, tuples
//     — Manual unsafe memory ops (asm, *T, mem::alloc with user-provided allocator)
//     — math:: (pure computation, no allocations)
//     — All type system features
//     — ARC (~T) IF user provides a custom allocator via:
//         vex_alloc / vex_free function symbols in their build
//   Use case: OS kernels, embedded firmware, WASM modules without WASI.
//
// ── G.5  RUNTIME SIZE AND FOOTPRINT ──────────────────────────────────────────
//
// RULE RTB7:  RUNTIME BINARY FOOTPRINT
//   The vex runtime (vex_rt) is a compiled static library linked into every binary.
//   Approximate sizes (stripped release build):
//     Full runtime (with async):   ~120 KB
//     Without async:               ~45 KB
//     --no-rt (no runtime):        ~0 KB (only libc calls remain)
//   These sizes are STATIC LINK additions — the runtime is NOT a separate .so that
//   must be distributed. It is baked into the final executable.



// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER B — RUNTIME ARCHITECTURE
// ████████████████████████████████████████████████████████████████████████████████

// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — paste after Chapter 28 (Compiler Pipeline) in vex_final_rules.vex
// as CHAPTER 28-A — RUNTIME ARCHITECTURE
// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 28-A — RUNTIME ARCHITECTURE
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── B.1  RUNTIME COMPONENTS ──────────────────────────────────────────────────
//
// RULE RT1:  THE VEX RUNTIME (vex_rt) IS A STATIC LIBRARY
//   Linked into every Vex executable at build time. NOT a shared library.
//   Not distributed separately. Baked into the final binary.
//   Approximate sizes (stripped release):
//     Full (with async scheduler):  ~120 KB
//     Without async:                 ~45 KB
//     --no-rt (bare metal):           ~0 KB (only libc calls remain)
//
// RULE RT2:  PROGRAM STARTUP SEQUENCE
//   1. OS hands control to _start (injected by Vex linker shim).
//   2. _start calls vex_rt_init():
//        a. Initializes heap allocator (jemalloc or system malloc).
//        b. Installs stack-overflow guard signal handler (SIGSEGV on guard page).
//        c. Initializes thread-local storage for the main thread.
//        d. Initializes async runtime thread pool (if async is used).
//        e. Calls fn init() for each module in topological dependency order.
//   3. vex_rt_init() calls fn main().
//   4. fn main() returns (or calls process::exit(code)).
//   5. vex_rt_deinit():
//        a. Calls fn deinit() for each module in REVERSE init order.
//        b. Drains and shuts down async runtime (waits for pending tasks).
//        c. Releases heap allocator.
//   6. Process exits with main's return code (or exit code from process::exit).
//
// RULE RT3:  HEAP ALLOCATOR
//   Default: jemalloc (better fragmentation behavior than system malloc).
//   Interface (called by compiler-inserted allocation code):
//     vex_alloc(size: uint64, align: uint64) -> *void
//     vex_free(ptr: *void)
//     vex_realloc(ptr: *void, new_size: uint64, align: uint64) -> *void
//   Custom allocator: implement these three symbols and link before vex_rt.
//   Arena allocator (mem::Arena): bump pointer into a pre-allocated block.
//     Alloc is O(1) pointer bump. Free is O(1) reset of the entire arena.
//     No per-object free. Use for request-scoped or frame-scoped allocation.
//
// RULE RT4:  STACK MANAGEMENT
//   Each OS thread has a fixed stack (default 8 MB, configurable via thread::spawn).
//   Stack guard page: unmapped page at the bottom of each thread stack.
//   SIGSEGV on guard page → signal handler → panic("stack overflow").
//   No segmented or growable stack. Stack size fixed at thread creation.
//   Async tasks (green threads) use SMALL stacks (default 64 KB per task),
//   managed by the async runtime — these can grow if needed (see RT7).
//
// RULE RT5:  PANIC MODEL
//   panic(msg) flow:
//     1. Format message + capture current stack trace (backtrace).
//     2. Check if a try/catch recovery point exists on the current thread's
//        recovery stack (a thread-local linked list of setjmp contexts).
//     3. If recovery point exists: longjmp to it, pass PanicInfo to catch block.
//     4. If no recovery point: write to stderr, then call abort() (SIGABRT).
//   PanicInfo struct: { message: str, file: str, line: int, stackTrace: str }
//   Stack traces: only available in debug builds (-g). Release builds omit them.
//   Double panic (panic inside catch): always calls abort() — no infinite loop.
//
// RULE RT6:  MODULE INITIALIZATION
//   fn init() at module level: runs ONCE per process, before fn main().
//   fn deinit() at module level: runs ONCE per process, after fn main() returns.
//   Order: topological (imports init before importers).
//   Within same dependency level: import-list order in the importing file.
//   Global var initialization: top-to-bottom within each module, after all
//   modules it imports have been initialized.
//   fn init() must NOT call async functions or block on I/O (runtime not fully up).
//
// ── B.2  ASYNC RUNTIME ───────────────────────────────────────────────────────
//
// RULE RT7:  ASYNC RUNTIME ARCHITECTURE (M:N green threading)
//   The async runtime implements M:N threading:
//     M = number of async tasks (potentially millions, user-created)
//     N = number of OS threads in the thread pool (default: CPU core count)
//   Each OS thread runs an event loop (the "executor").
//   Tasks are scheduled across OS threads via a work-stealing deque:
//     Each executor has a local deque. When empty, steals from other executors.
//   This achieves near-CPU-bound utilization without OS thread overhead per task.
//
// RULE RT8:  ASYNC TASK LIFECYCLE
//   1. async::run(future) or spawning a task creates a Task object.
//   2. Task is placed in the executor's local deque.
//   3. Executor calls task.poll() on the task.
//   4. poll() runs the task's state machine until it returns:
//        Pending  → task suspends (awaiting I/O, timer, channel, etc.)
//        Ready(v) → task complete, value available to caller.
//   5. When a suspended resource is ready (I/O done, timer fired, etc.):
//        The resource's Waker is called → re-enqueues the task in the deque.
//   6. Executor picks up the re-enqueued task and polls it again.
//
// RULE RT9:  FUTURE / ASYNC FN COMPILATION
//   async fn f(a: int) -> Result<str, E> { ... await ... }
//   Compiler transforms this into a STATE MACHINE struct:
//     struct f_StateMachine {
//         state:   uint32,          // which suspend point we are at
//         a:       int,             // captured parameter
//         _local1: TypeOfLocal1,    // locals that live across await points
//         _local2: TypeOfLocal2,
//     }
//   impl Future<Result<str, E>> for f_StateMachine {
//       fn poll(self: &mut Self, waker: &Waker) -> Poll<Result<str, E>> { ... }
//   }
//   The poll() function is a switch on self.state — a resumable coroutine.
//   await lowers to: suspend (return Pending), store waker, resume at next state.
//   sizeof(f_StateMachine) = sizeof all locals alive across any await point.
//   Allocated on the heap (one allocation per task spawn).
//
// RULE RT10: I/O EVENT LOOP (platform-specific, used by async tasks)
//   Linux:   io_uring (preferred) with epoll fallback.
//   macOS:   kqueue.
//   Windows: IOCP (I/O Completion Ports).
//   WASM:    JS event loop integration (browser) or WASI poll (standalone).
//   The runtime registers I/O handles with the OS. When I/O completes:
//   OS notifies runtime → runtime calls Waker → task re-enqueued → poll resumes.
//   All I/O in async tasks is NON-BLOCKING at the OS level.
//
// RULE RT11: async::run() vs thread::spawn()
//   async::run(f()) → submits f to the async executor, BLOCKS the calling OS thread
//                     until f is complete. Used to bridge sync→async boundary.
//   thread::spawn(lambda) → creates a new OS thread, non-blocking to caller.
//                           thread::join() blocks until the OS thread finishes.
//   Inside async fn: use async::spawn(f()) to spawn a non-blocking async task.
//   Do NOT call blocking I/O (fs::readFile, net::connect in sync form) inside
//   async fn — it blocks the OS thread and starves other tasks on that executor.
//   Use the async variants instead: await fs::readFileAsync(path) etc.
//
// RULE RT12: WAKER PROTOCOL
//   A Waker is a reference-counted callback: fn wake(*const RawWaker).
//   When a resource (channel, timer, I/O) is ready:
//     resource.waker.wake() → re-enqueues the task in the executor's deque.
//   The Future::poll() contract:
//     If returning Pending: the future MUST ensure wake() will be called in future.
//     If wake() is never called: the task hangs forever (programmer error).
//   This is enforced by convention, not by the type system (same as Rust futures).
//
// ── B.3  THREAD-LOCAL STORAGE ────────────────────────────────────────────────
//
// RULE RT13: THREAD-LOCAL VARIABLES
//   Declared with: thread_local var name: T = init_expr
//   Each OS thread gets its own copy, initialized lazily on first access.
//   init_expr evaluated independently per thread (not shared).
//   Accessible via the same name — compiler inserts TLS lookup per access.
//   NOT accessible from async tasks unless the task is pinned to one OS thread.
//
// ── B.4  RUNTIME TYPE SYSTEM ─────────────────────────────────────────────────
//
// RULE RT14: TYPEID TABLE (for `any`, `as`, `as?`, `is`)
//   Every type that can be stored in `any` or checked with `is`/`as`/`as?`
//   gets a unique uint64 typeid, assigned at compile time.
//   The compiler emits a static TYPEID TABLE per binary:
//     [ typeid: uint64 | name_ptr: *uint8 | name_len: uint64 ] per entry
//   typeid lookup: O(1) — directly embedded in the any value's header.
//   typeof(expr) → str: calls vex_type_name(typeid(expr)) at runtime → O(1).
//   typeid(expr) → uint64: comptime constant for known types, runtime for any.



// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 29 — BUILD SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── RUNNING AND BUILDING ─────────────────────────────────────────────────────
//
//   By default, `vex` run with no arguments compiles and IMMEDIATELY RUNS
//   the entry file (main.vex or whatever is set in vex.toml as the entry).
//
//   `vex build` compiles and produces an executable. No special flags needed
//   when fn main() is present. The output is a native executable binary.
//
//   The LLVM backend is used. The compiler can produce:
//     - Native executable binaries (default when fn main() is present)
//     - Compiled Vex libraries (.vxl)
//     - Shared libraries (.so / .dll / .dylib)
//     - WebAssembly modules (.wasm)
//
// ── WHAT GETS GENERATED ──────────────────────────────────────────────────────
//
//  CONDITION                              OUTPUT
//  ─────────────────────────────────      ──────────────────────────────────────
//  has fn main(), no flags                executable binary     (./myapp)
//  has fn main(), --shared                shared library        (libmyapp.so)
//  no fn main(), --lib                    Vex library           (mylib.vxl)
//  no fn main(), --shared                 shared library        (libmyapp.so)
//  no fn main(), --lib --shared           both                  (mylib.vxl + libmyapp.so)
//  no fn main(), no flags                 COMPILE ERROR — nothing to produce
//  --target wasm                          WebAssembly module    (myapp.wasm)
//
//  When building a shared library, the compiler ALSO generates:
//    libmyapp.so          — the shared library itself
//    libmyapp.vex.h       — auto-generated C header (all @export function signatures)
//    libmyapp_meta.vex    — metadata for other Vex programs that import this lib
//
// ── HOW IMPORTS ARE RESOLVED DURING BUILD ────────────────────────────────────
//
//  You NEVER manually list files — the imports ARE the build specification.
//  The compiler follows imports recursively to build a complete dependency graph.
//
//  BUILD GRAPH EXAMPLE:
//    main.vex  →  import std::io          ← stdlib
//              →  import std::math        ← stdlib
//              →  import app::user        ← local: app/user.vex
//              →  import shapes           ← local: shapes.vex
//    shapes.vex → import std::math        ← already compiled, skip
//    app/user.vex → import std::io        ← already compiled, skip
//
//  Compiler compiles each file ONCE, in dependency order.
//
// ── HOW YOUR OWN LIBRARY IS BUILT AND USED ───────────────────────────────────
//
//  BUILDING YOUR LIBRARY — THREE OUTPUTS, DIFFERENT AUDIENCES:
//
//    vex build --lib mylib.vex -o mylib.vxl
//      → mylib.vxl          Vex compiled library (no source exposed)
//
//    vex build --shared mylib.vex -o libmylib.so
//      → libmylib.so        Shared library (for C/Python/etc.)
//      → libmylib.vex.h     C header (auto-generated)
//
//    vex build --lib --shared mylib.vex
//      → mylib.vxl  +  libmylib.so  +  libmylib.vex.h  (all three at once)
//
//  USING YOUR LIBRARY FROM VEX — SOURCE (open source):
//    Other Vex programs import your .vex source directly.
//    import mylib::shapes       ← finds mylib/shapes.vex, compiles it
//
//  USING YOUR LIBRARY FROM VEX — COMPILED (closed source):
//    Build: vex build --lib mylib.vex -o mylib.vxl
//    Distribute: mylib.vxl only — no source exposed
//    import mylib               ← finds mylib.vxl, links pre-compiled code
//    Same import syntax. Users get full type checking. Source stays private.
//
//  USING YOUR LIBRARY FROM C/PYTHON/OTHER LANGUAGES (.so):
//    Compile to .so first:
//      vex build --shared mylib.vex -o libmylib.so
//
//    Python example:
//      import ctypes
//      lib = ctypes.CDLL("./libmylib.so")
//      lib.vex_add.restype = ctypes.c_int32
//      result = lib.vex_add(3, 4)
//
//    C example:
//      #include "libmylib.vex.h"    // auto-generated header
//      int main() { int r = vex_add(3, 4); }
//      // compile: gcc main.c -L. -lmylib -o myapp
//
// ── vex.toml — PROJECT CONFIGURATION FILE ────────────────────────────────────
//
//  vex.toml lives at the project root. Created by `vex init` or `vpm install`.
//
//  [project]
//  name    = "myapp"           ← project name
//  version = "1.0.0"           ← semver version
//  entry   = "main.vex"        ← entry point file (must have fn main())
//  authors = ["Your Name"]
//
//  [dependencies]
//  json    = { source = "official", version = "v2.1.0" }
//  vectors = { source = "https://github.com/user/mathlib", version = "v1.2.3" }
//
//  [build]
//  optimization = "O2"         ← default: O2 for release, O0 for debug
//  target       = "linux-x64"  ← default: current platform
//  output       = "myapp"      ← default: same as project name
//
//  [lib]                       ← only if building a library
//  vxl    = true               ← produce mylib.vxl (Vex library, no source)
//  shared = true               ← produce libmylib.so (for C/Python callers)
//  exports = ["main.vex"]      ← which files have @export functions for .so
//
//  [c_interop]                 ← only if linking C libraries
//  link      = ["ssl", "sqlite3"]
//  link_path = ["/usr/local/lib"]
//  include   = ["/usr/local/include"]
//
// ── OPTIMIZATION FLAGS ────────────────────────────────────────────────────────
//
//  -O0    no optimization  (fast compile, readable debug output)
//  -O1    basic            (dead code removal, simple inlining)
//  -O2    standard         (default for release — balance speed/size)
//  -O3    aggressive       (max speed, larger binary, slower compile)
//  -Os    size             (minimize binary size)
//  -g     debug symbols    (include symbol table for debugger)
//
// ── SUPPORTED TARGETS ────────────────────────────────────────────────────────
//
//  ── TIER 1 — Primary targets (full support, always tested) ──────────────────
//  --target linux-x64          Linux x86-64   — servers, cloud, Docker
//  --target linux-arm64        Linux ARM64    — AWS Graviton, RPi 4/5
//  --target windows-x64        Windows x64    — desktop, enterprise
//  --target macos-arm64        macOS ARM64    — Apple Silicon M1/M2/M3
//  --target wasm               WebAssembly    — browser, Node.js, Workers
//
//  ── TIER 2 — Secondary targets (supported, tested on release) ───────────────
//  --target macos-x64          macOS x64      — Intel Macs
//  --target wasm-wasi          WASM + WASI    — standalone WASM runtime, edge compute
//  --target linux-riscv64      Linux RISC-V64 — open-source CPU architecture
//  --target android-arm64      Android ARM64  — Android NDK, mobile high-perf code
//
//  DEFAULT TARGET: current host machine architecture and OS.
//  Cross-compilation: build for any target from any host.
//
// ── COMPLETE COMMAND REFERENCE ───────────────────────────────────────────────
//
//  INIT:
//  vex init                         create new project with vex.toml
//  vex init --lib                   create new library project
//
//  RUN (compile + immediately execute, no output file kept):
//  vex                              compile + run entry from vex.toml (DEFAULT — no args needed)
//  vex run                          same as above (explicit form)
//  vex run main.vex                 run specific file
//  vex run -- arg1 arg2             pass arguments to the program
//
//  BUILD (compile to output file):
//  vex build                        build using vex.toml settings → executable
//  vex build main.vex               build specific file → executable
//  vex build main.vex -o myapp      named output executable
//  vex build --lib mylib.vex        build .vxl (no source exposed)
//  vex build --lib mylib.vex -o mylib.vxl   named .vxl output
//  vex build --shared mylib.vex     build .so (for C/Python/Ruby callers)
//  vex build --lib --shared mylib.vex  build both .vxl and .so at once
//  vex build --target wasm main.vex build WebAssembly module
//
//  DEVELOPMENT:
//  vex check main.vex               type-check only — no code generation
//  vex fmt main.vex                 auto-format source file in place
//  vex fmt .                        format all .vex files in project
//
//  TESTING & BENCHMARKS:
//  vex test                         run all @test functions in project
//  vex test main.vex                run @test functions in specific file
//  vex test --filter "testAdd"      run tests matching pattern
//  vex bench                        run all @bench functions
//
//  DOCUMENTATION:
//  vex doc                          generate HTML docs from /// comments
//  vex doc --out ./docs             output to specific directory
//
//  DEFINES (set comptime variables):
//  -D DEBUG=true               enable debug mode (#DEBUG = true)
//  -D MY_FEATURE=true          custom feature flag
//
//  LINKING C LIBRARIES:
//  --link ssl                  link libssl.so
//  --link-path /usr/local/lib  add directory to library search path
//  --include-path /usr/include add directory to C header search path
//  --no-std                    do not link standard library (bare metal)
//
// ── BUILD INTERNALS ──────────────────────────────────────────────────────────
//
//  Given: vex build main.vex
//
//  1. PARSE vex.toml (if exists) — load project config and dependency versions
//
//  2. READ entry file (main.vex) — lex + parse into AST
//
//  3. RESOLVE IMPORTS recursively:
//       For each `import X`:
//         - Is X a std module?   → find in <stdlib>/lib/
//         - Is X a local file?   → find relative to current file / project root
//         - Is X an official pkg?→ find in libs/official/ (check version via vex.toml)
//         - Is X an external pkg?→ find in libs/external/ (check version via vex.toml)
//         - Not found?           → COMPILE ERROR with helpful message
//       Build complete dependency graph. Detect cycles → COMPILE ERROR.
//
//  4. COMPILE each file in dependency order (leaves first, entry last):
//       For each .vex file (each compiled ONCE):
//         a. Type check
//         b. Borrow check
//         c. Comptime evaluation + generic specialization
//         d. Lower to IR → emit LLVM IR
//
//  5. LINK all compiled IR modules together via LLVM:
//       - Resolve cross-module references
//       - Link C libraries (--link flags or vex.toml [c_interop])
//       - Apply LLVM optimization passes (-O level)
//       - Generate final machine code
//
//  6. OUTPUT based on mode:
//       executable:     write ./myapp           (or -o name)
//       .vxl library:   write ./mylib.vxl       type metadata + machine code, no source
//       shared library: write ./libmyapp.so     + libmyapp.vex.h (C header)
//       both:           write ./mylib.vxl       + ./libmyapp.so + ./libmyapp.vex.h
//       wasm:           write ./myapp.wasm
//
//  INCREMENTAL BUILDS:
//       Compiler caches compiled IR for each .vex file in .vex_cache/
//       On rebuild: only recompile files that changed or whose imports changed
//       `vex clean` removes .vex_cache/ and forces full rebuild

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 30 — VPM — VEX PACKAGE MANAGER
// ═══════════════════════════════════════════════════════════════════════════════
//
//  VPM is the standalone package manager for Vex. It is a separate tool
//  (invoked as `vpm`) that handles downloading, installing, updating, and
//  removing packages. It is NOT part of the compiler but integrates tightly
//  with the build system through vex.toml.
//
// ── PACKAGE INSTALL LOCATIONS ────────────────────────────────────────────────
//
//  All installed packages live under the project's `libs/` folder:
//
//    <project_root>/
//      libs/
//        official/                    ← packages from the official VPM registry
//          json@v2.1.0/               ← name@version (exact version pinned)
//            json.vex  (or json.vxl)  ← source or compiled, as uploaded by author
//            parser.vex
//          http@v1.4.0/
//            http.vex
//
//        external/                    ← packages from arbitrary URLs
//          github.com/
//            user/
//              mathlib@v1.2.3/
//                vectors.vex
//                matrices.vex
//          someurl.dev/pkgs/
//            cryptoutils@main/
//              cryptoutils.vex
//
//  The `@version` suffix in the folder name allows multiple versions of the same
//  package to coexist. vex.toml controls which version each project uses.
//
// ── WHAT USERS CAN UPLOAD TO VPM ─────────────────────────────────────────────
//
//   OPTION A — Source package (.vex files):
//     Upload your .vex source files directly.
//     Users who install the package can read your source.
//     Good for open-source libraries.
//
//   OPTION B — Compiled library (.vxl file):
//     Build first: vpm pack --lib mylib.vex -o mylib.vxl
//     Upload: vpm publish mylib.vxl
//     Users who install cannot read your source.
//     They still get full type checking and autocomplete.
//     Good for closed-source / commercial libraries.
//
//   SEAMLESS TO USERS:
//     Whether a package ships .vex or .vxl, the import syntax is identical.
//     The compiler handles both transparently. Users do not need to know or care.
//     import json::parser          ← works whether parser.vex or parser.vxl is present
//
// ── VPM COMMANDS ─────────────────────────────────────────────────────────────
//
//  INSTALLING PACKAGES:
//
//  vpm install json                       install latest json from official registry
//  vpm install json@v2.1.0               install exact version
//  vpm install json@">=v2.0.0"           install latest version >= v2.0.0
//
//  When installed from official registry:
//    → placed in: libs/official/json@v2.1.0/
//    → added to vex.toml under [dependencies]:
//      json = { source = "official", version = "v2.1.0" }
//
//  vpm install https://github.com/user/mathlib              install from GitHub (latest)
//  vpm install https://github.com/user/mathlib@v1.2.3       install exact version
//  vpm install https://github.com/user/mathlib@main         install from branch
//
//  When installed from URL:
//    → placed in: libs/external/github.com/user/mathlib@v1.2.3/
//    → added to vex.toml under [dependencies]:
//      vectors = { source = "https://github.com/user/mathlib", version = "v1.2.3" }
//
//  SHORT FLAG:
//  vpm -i json                     same as vpm install json
//  vpm -i json@v2.1.0              same as vpm install json@v2.1.0
//  vpm -i https://github.com/...   same as vpm install <url>
//
//  AFTER INSTALLATION — IMPORTING:
//
//    Packages are imported using their module name(s), not the full path.
//    The vex.toml mapping tells the compiler where to find each package.
//
//    import json              → libs/official/json@v2.1.0/json.vex (or .vxl)
//    import json::parser      → libs/official/json@v2.1.0/parser.vex
//    import vectors           → libs/external/github.com/user/mathlib@v1.2.3/vectors.vex
//
//  UPDATING PACKAGES:
//  vpm update json                  update json to latest version allowed by vex.toml constraint
//  vpm update                       update all packages
//  vpm upgrade json                 upgrade json to absolute latest (ignores constraint)
//
//  REMOVING PACKAGES:
//  vpm remove json                  remove json from project (removes from vex.toml + libs/)
//
//  LISTING:
//  vpm list                         list all installed packages for this project
//  vpm list --outdated              list packages with newer versions available
//
//  CLEANING:
//  vpm clean                        remove all downloaded package files from libs/
//                                   (re-download next time vpm install is run)
//
//  PUBLISHING YOUR OWN PACKAGE:
//  vpm pack mylib.vex               package source as-is (users can read source)
//  vpm pack --lib mylib.vex -o mylib.vxl  compile before packaging (source hidden)
//  vpm publish mylib.vxl            publish to the official VPM registry
//  vpm publish mylib.vex            publish source package to official VPM registry
//
//  REGISTRY:
//  vpm search json                  search official registry for packages matching "json"
//  vpm info json                    show info about a package (versions, description, author)
//
// ── PACKAGE RESOLUTION IN vex.toml ──────────────────────────────────────────
//
//  When vpm installs a package, it writes to vex.toml's [dependencies] section.
//  The compiler reads this to know:
//    a) Where to find the package (official vs external, and which URL)
//    b) Which version to use
//    c) What short import name to assign
//
//  Example vex.toml [dependencies] after running:
//    vpm install json@v2.1.0
//    vpm install https://github.com/user/mathlib@v1.2.3
//
//  [dependencies]
//  json    = { source = "official", version = "v2.1.0" }
//  mathlib = { source = "https://github.com/user/mathlib", version = "v1.2.3" }
//
//  In your code:
//    import json              → resolves to libs/official/json@v2.1.0/
//    import mathlib::vectors  → resolves to libs/external/github.com/user/mathlib@v1.2.3/
//
// ── PACKAGE STRUCTURE (what a valid Vex package must contain) ─────────────────
//
//   mypackage/
//     vex.toml                  ← package metadata (required)
//     mypackage.vex             ← main module (required for single-module packages)
//     utils.vex                 ← optional additional modules
//     README.md                 ← optional but recommended
//
//   vex.toml for a package:
//     [package]
//     name    = "json"
//     version = "v2.1.0"
//     authors = ["Author Name"]
//     description = "JSON parser and serializer for Vex"
//     license = "MIT"
//
//     [dependencies]
//     ... (any packages this package depends on)



// ████████████████████████████████████████████████████████████████████████████████
// CHAPTER D — STANDARD LIBRARY CORE
// ████████████████████████████████████████████████████████████████████████████████

