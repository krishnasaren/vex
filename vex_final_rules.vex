// ════════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 31 — STANDARD LIBRARY CORE (full signatures)
// ═══════════════════════════════════════════════════════════════════════════════
//
//  All stdlib modules live under <vex_install>/lib/std/ and ship as .vxl.
//  The name list below is expanded with FULL SIGNATURES for each module.
//
// ── std::io ───────────────────────────────────────────────────────────────────
//
//  fn println(val: any)                    print val + newline to stdout
//  fn print(val: any)                      print val (no newline) to stdout
//  fn printErr(val: any)                   print to stderr
//  fn printErrLn(val: any)                 print to stderr + newline
//  fn readLine() -> str?                   read one line from stdin (null on EOF)
//  fn readAll() -> str                     read all of stdin
//  fn flush()                              flush stdout buffer
//  struct Writer { fn write(s: str), fn writeLn(s: str), fn flush() }
//  struct Reader { fn readLine() -> str?, fn readAll() -> str }
//  fn stdout() -> Writer                   get stdout Writer handle
//  fn stderr() -> Writer                   get stderr Writer handle
//  fn stdin()  -> Reader                   get stdin Reader handle
//
