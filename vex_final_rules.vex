// ════════════════════════════════════════════════════════════════════════════════
// [RULES FILE] — add to Chapter 31 (Standard Library Core) — missing modules
// ════════════════════════════════════════════════════════════════════════════════

// ── std::ffi (full signatures, supplements interop chapter) ──────────────────
//
//  fn withCString(s: str, f: fn(*byte) -> R) -> R
//    Converts s to a null-terminated C string, calls f(ptr), then frees.
//    ptr is ONLY valid inside f. Cannot escape. Safest C string pattern.
//
//  fn toCString(s: str) -> ^[]byte
//    Allocates a null-terminated C string on heap. Returns owned ^[]byte.
//    .ptr() on the result gives the *byte for passing to C.
//    Auto-freed when ^[]byte owner drops. Safe for pointers that outlive a lambda.
//
//  fn fromCString(ptr: *byte) -> str
//    Copies a null-terminated C string into a Vex str. ptr may be freed after.
//
//  fn fromCStringLen(ptr: *byte, len: uint) -> str
//    Copies exactly len bytes from ptr into a Vex str (does not stop at null).
//
//  fn dlopen(path: str) -> Result<DynLib, str>
//    Dynamically load a shared library (.so / .dll / .dylib).
//
//  struct DynLib {
//      fn symbol<FnType>(name: str) -> Result<FnType, str>
//          // load a function symbol from the library (unsafe to call)
//      // auto-unloads (dlclose) when DynLib drops (RAII)
//  }
//
//  fn syscall(number: int, ...args: int) -> int    (unsafe)
//    Direct OS system call. Platform-specific number. All args as int-sized.
//
// ── std::os ──────────────────────────────────────────────────────────────────
//
//  fn platform() -> str        "linux" | "windows" | "macos" | "android" | "wasm"
//  fn arch()     -> str        "x86_64" | "arm64" | "riscv64" | "wasm32"
//  fn cpuCount() -> uint       number of logical CPU cores
//  fn pageSize() -> uint       OS memory page size in bytes (typically 4096)
//  fn hostname() -> Result<str, str>
//  fn username() -> Result<str, str>
//  fn pid()      -> uint       current process ID
//  fn ppid()     -> uint       parent process ID
//
//  fn signal(sig: Signal, handler: fn(Signal))    install signal handler
//  fn raise(sig: Signal)                          send signal to self
//  enum Signal { SIGINT, SIGTERM, SIGHUP, SIGUSR1, SIGUSR2, SIGPIPE, SIGALRM }
//  fn ignoreSignal(sig: Signal)                   ignore a signal
//  fn defaultSignal(sig: Signal)                  restore default handler
//
//  fn getrlimit(resource: RlimitResource) -> Result<(uint64, uint64), str>
//    Returns (soft_limit, hard_limit) for a resource.
//  fn setrlimit(resource: RlimitResource, soft: uint64, hard: uint64) -> Result<void, str>
//  enum RlimitResource { NOFILE, STACK, AS, CORE, CPU, DATA }
//
// ── std::text ────────────────────────────────────────────────────────────────
//
//  fn collate(a: str, b: str) -> int
//    Locale-aware string comparison. Returns -1, 0, 1.
//    Uses the system locale (LC_COLLATE). For ordinal: use == / < directly on str.
//
//  fn normalize(s: str, form: NfForm) -> str
//    Unicode normalization. form: NFC | NFD | NFKC | NFKD
//  enum NfForm { NFC, NFD, NFKC, NFKD }
//
//  fn toUpperLocale(s: str, locale: str = "") -> str
//    Locale-aware uppercase (handles ß→SS, İ→i, etc.)
//
//  fn toLowerLocale(s: str, locale: str = "") -> str
//    Locale-aware lowercase.
//
//  fn graphemes(s: str) -> []str
//    Split str into user-perceived characters (Unicode grapheme clusters).
//    Use instead of .chars() when displaying text (emoji sequences, combining marks).
//
//  fn isAlpha(c: char) -> bool      Unicode alphabetic
//  fn isDigit(c: char) -> bool      Unicode decimal digit
//  fn isAlnum(c: char) -> bool      alphabetic OR digit
//  fn isSpace(c: char) -> bool      Unicode whitespace
//  fn isUpper(c: char) -> bool
//  fn isLower(c: char) -> bool
//  fn isPunct(c: char) -> bool
//  fn toUpper(c: char) -> char      simple case fold (non-locale-aware)
//  fn toLower(c: char) -> char
//
//  fn encode(s: str, enc: Encoding) -> []byte
//    Encode str to byte sequence in given encoding.
//  fn decode(bytes: []byte, enc: Encoding) -> Result<str, str>
//    Decode bytes from given encoding to UTF-8 str.
//  enum Encoding { UTF8, UTF16LE, UTF16BE, UTF32LE, UTF32BE, Latin1, ASCII }
//
// ── std::str (module — supplements str built-in type) ────────────────────────
//
//  struct Builder {  ... (see Chapter 31 above) ... }
//  fn join(sep: str, parts: []str) -> str
//  fn repeat(s: str, n: int) -> str
//  fn format(fmt: str, ...any) -> str       runtime f-string equivalent
//
//  // These are methods on str (callable via UFCS or str.method())
//  // Already available on all str values — listed here for reference:
//  str.len()           -> uint      byte count
//  str.charCount()     -> uint      Unicode codepoint count  O(n)
//  str.charAt(n: uint) -> char      nth codepoint  O(n)
//  str.charSlice(a,b: uint) -> str  char-index slice  O(n)
//  str.bytes()         -> []byte    copy as byte array
//  str.chars()         -> []char    copy as char array
//  str.trim()          -> str       remove leading/trailing whitespace
//  str.trimStart()     -> str
//  str.trimEnd()       -> str
//  str.upper()         -> str       ASCII uppercase (non-locale)
//  str.lower()         -> str       ASCII lowercase (non-locale)
//  str.contains(sub: str) -> bool
//  str.startsWith(pre: str) -> bool
//  str.endsWith(suf: str) -> bool
//  str.indexOf(sub: str) -> uint?   byte offset of first occurrence
//  str.lastIndexOf(sub: str) -> uint?
//  str.replace(old, new: str) -> str    first occurrence
//  str.replaceAll(old, new: str) -> str
//  str.split(sep: str) -> []str
//  str.splitN(sep: str, n: int) -> []str   at most n parts
//  str.lines() -> []str             split on \n / \r\n
//  str.repeat(n: int) -> str
//  str.reversed() -> str
//  str.isPalindrome() -> bool
//  str.padStart(width: uint, fill: char = ' ') -> str
//  str.padEnd(width: uint, fill: char = ' ') -> str
//  str.count(sub: str) -> uint      count non-overlapping occurrences
//  str.isAscii() -> bool
//  str.toInt() -> int?              try-parse integer
//  str.toFloat() -> float?          try-parse float



// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER 32 — QUICK REFERENCE CARD (complete syntax cheatsheet)
// ═══════════════════════════════════════════════════════════════════════════════

// VARIABLES          var x := 42          let y := "hi"         const Z := 100
// NULLABLE           var n: int? = null   n ?? 0   n?.method()
// TYPES              int  float  bool  char  str  byte  any  void
// POINTER TYPES      *int  ^int  ~int  &int  int?
// CAST               int(x)   float(x)   str(x)   int?(x) → nullable parse
// ARRAY              var a: [5]int = [1,2,3,4,5]
// LIST               var l: []int = [1,2,3]     l.append(4)
// MAP                var m: [str:int] = ["a":1]  m["b"] = 2
// SET                var s: {}str = {"x","y"}    s | t   s & t   s - t
// TUPLE              let t: (int,str) = (1,"hi") t.0  t.1
//
// FUNCTION           fn add(a: int, b: int) -> int = a + b
// GENERIC FN         fn max<T: Ord>(a: T, b: T) -> T = if a>b {a} else {b}
// MULTIPLE RETURN    fn f() -> (int, str) { (1, "hi") }
// LAMBDA             |x: int| -> x * 2
// NO-PARAM LAMBDA    || -> io::println("hi")
// CLOSURE COPY       copy |x| -> x + captured
// CLOSURE MOVE       move |x| -> use_owned(x)
//
// IF                 if x>0 { } elif x<0 { } else { }
// IF EXPR            let v := if x>0 { "pos" } else { "neg" }
// IF-LET             if let val = maybe { use(val) }
// MATCH              match x { 1|2 => "small", 3..=9 => "mid", _ => "big" }
// MATCH TYPE         match v { as str s => s.len(), as int i => i, _ => 0 }
// FOR-IN             for item in list { }
// FOR INDEXED        for i, item in list { }
// FOR RANGE          for i in 0..10 { }    for i in 0..=10 step 2 { }
// WHILE              while cond { }
// LOOP               loop { if done { stop } }
// DEFER              defer file.close()
// USE BLOCK          use let f := open("x") { read(f) }
//
// STRUCT             struct Point { x: float64, y: float64, init(x,y) }
// STRUCT LITERAL     Point { x: 3.0, y: 4.0 }
// STRUCT SPREAD      Point { ...other, x: 10.0 }
// STRUCT DESTRUCT    let { x, y } := point
// OPERATOR OVERLOAD  op +(other: Point) -> Point = ...
// PROPERTY           prop name: T { get => ..., set(v) => ... }
//
// CLASS              class Dog : Animal { priv breed: str, init(name, breed) { super(name,"Dog") } }
// OBJECT CREATION    let u := User("Alice", 30)
// STATIC FIELD       User.count                           Dog.species
// STATIC METHOD      User.maxAge()                        Point.origin()
// INSTANCE METHOD    u.greet()   u.name   alice.promote(Role.Editor)
// INTERFACE          interface Drawable { fn draw(); fn area() -> float64 }
// TRAIT              trait Printable { fn toString() -> str; fn print() = io::print(toString()) }
// IMPL BLOCK         impl str { fn shout() -> str = self.upper() + "!" }
//
// GENERIC STRUCT     struct Box<T> { value: T, init(value), fn get() -> T = self.value }
// ENUM DATA          enum Shape { Circle(r: float64), Rect(w,h: float64) }
// ENUM VARIANT       Shape.Circle(5.0)   Color.Red   Role.Admin   AppError.NotFound("x")
// CONST ENUM         const enum Flags: uint32 { A=1, B=2, C=4 }
//
// RESULT             fn f() -> Result<int, str> { Ok(42) / Err("oops") }
// ERROR PROP         let v := f()?
// OPTION             var x: int? = null   // T? IS the option type
//
// OWNED HEAP         var h: ^str = mem::new("hi")   *h   move h
// SHARED HEAP        var s: ~str = mem::share("hi")  s.clone()
// BORROW             fn f(x: &int)   fn f(x: &mut int)
// RAW POINTER        unsafe { var p: *int = mem::alloc(4) }
//
// THREAD             let t := thread::spawn(|| -> { work() });  t.join()
// CHANNEL            let (s, r) := channel<int>(100);  s.push(1);  for v in r { }
// MUTEX              let m := Mutex<int>(0);  let g := m.lock();  *g += 1
// ASYNC              async fn f() -> Result<T, E> { let x := await g()? }
// RUN ASYNC          async::run(myAsyncFn())
//
// COMPTIME CONST     comptime const N := factorial(10)
// COMPTIME FN        comptime fn f(n: int) -> int { ... }
// COND COMPILE       #if OS == "linux" { fn f() -> str = "linux" }
//
// C CALL             extern "C" { fn printf(fmt: *byte, ...any) -> int32 }
// C LINK             extern "C" link("libssl") { fn SSL_new(ctx: *any) -> *any }
// UNSAFE BLOCK       unsafe { *raw_ptr = 42 }
// C STRING           ffi::withCString(s, |ptr| -> { unsafe { strlen(ptr) } })
// EXPORT .so         @export("fn_name") pub fn f(a: int32) -> int32 = a
// EXPORT WASM        @wasmExport("fn_name") pub fn f(a: int32) -> int32 = a
// DYNAMIC LOAD       let lib := ffi::dlopen("lib.so").unwrap()
// INLINE ASM         asm x86_64 { "rdtsc"; out("rax") result }
//
// MODULE CALL        io::println("x")   math::sqrt(4.0)   shapes::Circle(3.0)
// IMPORT             import std::io        → stdlib
// IMPORT LOCAL       import shapes         → shapes.vex (source) or shapes.vxl (compiled)
// IMPORT ALIAS       import shapes as geo  → geo::Circle  geo::rectArea
// INSTALL PKG        vpm install json@v2.1.0
// INSTALL EXT PKG    vpm install https://github.com/user/lib@v1.0.0
// IMPORT PKG         import json::parser
// BUILD RUN          vex                  (compile + run immediately, default behavior)
// BUILD EXE          vex build            → executable
// BUILD LIB          vex build --lib mylib.vex -o mylib.vxl
// BUILD SHARED       vex build --shared mylib.vex -o libmylib.so
// BUILD BOTH         vex build --lib --shared mylib.vex
// VISIBILITY         pub fn f()    priv var x: int    internal struct S
// DECORATORS         @inline @pure @test @bench @override @deprecated("msg") @derive(Clone)
// PIPE               "  hi  " |> str::trim |> str::upper   →  "HI"
// SPREAD             [...a, ...b, extra]    fn call(...list)
// STRING INTERP      f"x={x} sum={a+b} hex={n:#x}"
// MULTILINE STR      `SELECT * FROM users WHERE active=true`




// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║         VEX LANGUAGE — MISSING PARTS (Compiler Reference Addendum)          ║
// ║  These sections are absent from vex_final_rules.vex and vex_spec_final.vex  ║
// ║  Add each chapter to your rules file and each spec section to your spec.    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝
//
//  Contents:
//    CHAPTER A  — Memory Model (Ownership, Borrow, ARC — deep compiler rules)
//    CHAPTER B  — Name Resolution Algorithm
//    CHAPTER C  — Import System + Visibility (compiler resolution detail)
//    CHAPTER D  — Generics Implementation Strategy (IR-level detail)
//    CHAPTER E  — Struct / Enum ABI Layout
//    CHAPTER F  — Error Handling Lowering (Option / Result → LLVM IR)
//    CHAPTER G  — Runtime vs Compiler Responsibility Boundary
//
//  SPEC sections follow each chapter for copy-paste into vex_spec_final.vex.



// ═══════════════════════════════════════════════════════════════════════════════
// CHAPTER C — IMPORT SYSTEM + VISIBILITY (COMPILER RESOLUTION DETAIL)
// (supplements Chapters 4, 22, 23 of vex_final_rules.vex)
// ═══════════════════════════════════════════════════════════════════════════════
//
// ── C.1  IMPORT RESOLUTION AT COMPILE TIME ───────────────────────────────────
//
// RULE IMP1:  IMPORT PROCESSING ORDER (within a single file):
//   All import statements are processed BEFORE any other declaration in the file.
//   An import at the bottom of a file is identical to one at the top.
//   (This differs from some languages where imports are positional.)
//   The compiler collects all imports, resolves them (using MOD8 search order),
//   and THEN begins declaration collection for the file's own symbols.
//
// RULE IMP2:  IMPORT RESOLUTION IS EAGER AND COMPLETE
//   Every import must resolve at compile time. There is no deferred/dynamic
//   module loading at runtime (except ffi::dlopen for C libraries — not Vex modules).
//   If any import cannot be resolved: the ENTIRE build fails immediately with a
//   clear error naming the missing module and the file that tried to import it.
//
// RULE IMP3:  THE MODULE IDENTITY KEY
//   A module is uniquely identified by its RESOLVED FILE PATH, not its import name.
//   If two different import paths resolve to the same physical file, it is
//   the SAME module — its init() runs once, its globals are shared.
//   Aliasing does not create a second module: `import std::io as myio` — there is
//   still only ONE io module instance. `myio` is just an alias for the same export table.
//
// ── C.2  VISIBILITY ENFORCEMENT IN THE COMPILER ──────────────────────────────
//
// RULE VIS6:  VISIBILITY CHECK ALGORITHM (compiler Phase 5):
//   For every identifier access `A` in file F accessing symbol S declared in file D:
//
//   Case 1 — S is `pub`:    Always accessible from any file. Check passes.
//
//   Case 2 — S is `priv`:   Accessible ONLY if F == D (same physical file).
//                            Otherwise: COMPILE ERROR: `S` is private to `D`.
//
//   Case 3 — S is `internal`: Accessible if F and D share the same PROJECT DIRECTORY.
//                               Project directory = the directory containing vex.toml.
//                               Subdirectories do NOT count as "same directory".
//                               If D is in project_root/sub/ and F is in project_root/,
//                               they do NOT share the same directory → access denied.
//
//   Case 4 — S is `prot`:    Accessible ONLY from within a class body AND only if
//                               the accessing class is D's class OR a subclass of it.
//                               `prot` outside a class = COMPILE ERROR at declaration site.
//
// RULE VIS7:  VISIBILITY AND IMPL BLOCKS
//   An impl block inherits the visibility of the MODULE it is written in.
//   A `pub fn` inside an `impl` block written in a `priv` context is still pub
//   as a method — visibility is on the SYMBOL, not the impl block container.
//   The impl block itself has no visibility modifier; only its contents do.
//
// RULE VIS8:  RE-EXPORT (making an imported symbol visible to importers of your module)
//   By default, importing a symbol does NOT re-export it.
//   To re-export: declare a `pub` type alias or wrapper in your module:
//     pub type Vec3 = math::Vec3          // re-exports math's Vec3 under your module
//     pub fn sqrt(x: float64) -> float64 = math::sqrt(x)   // wrapper fn
//   There is no `pub import` syntax. Re-export must be explicit.
//
// ── C.3  IMPORT ALIAS SCOPING RULES ──────────────────────────────────────────
//
// RULE IMP4:  IMPORT ALIAS SCOPE
//   Import aliases are FILE-SCOPED. They are NOT inherited by sub-imports or
//   transitively available to other files.
//   File A imports std::io as myio → alias `myio` exists ONLY in file A.
//   File B imports file A → file B does NOT get `myio`. File B must import its own.
//
// RULE IMP5:  ALIAS SHADOWING
//   An import alias may NOT shadow a module-level declaration name in the same file.
//   Example: if you have `fn io() {}` at module level, you cannot `import std::io`
//   without an alias, because `io` would be ambiguous.
//   Compiler detects this and requires: `import std::io as stdIo`.
//
// ── C.4  CIRCULAR IMPORT DETECTION ALGORITHM ─────────────────────────────────
//
// RULE IMP6:  CYCLE DETECTION ALGORITHM (Phase 3 of compiler pipeline):
//   1. Build directed graph G: one node per module, edge A → B if A imports B.
//   2. Run Tarjan's Strongly Connected Components algorithm on G.
//   3. Any SCC with more than one node = a cycle.
//   4. For each cycle found, emit:
//        COMPILE ERROR: Circular import detected:
//          A.vex imports B.vex
//          B.vex imports C.vex
//          C.vex imports A.vex        ← cycle closes here
//        Fix: extract shared code into a new module that all three can import.
//   5. Build fails — no partial compilation of cyclic modules.
//
// ── C.5  CONDITIONAL IMPORTS ─────────────────────────────────────────────────
//
// RULE IMP7:  IMPORTS INSIDE #if BLOCKS
//   An import may appear inside a #if / #elif / #else block for platform-specific
//   module selection:
//     #if OS == "linux" {
//         import platform::linux as os_impl
//     } elif OS == "windows" {
//         import platform::windows as os_impl
//     }
//   The alias (os_impl) is available in the file regardless of which branch compiled.
//   Only ONE branch is compiled; the other is dropped before type-checking.
//   The alias must be defined in ALL branches, or the alias is undefined in excluded
//   branches — guaranteed consistent because #if is resolved at comptime.




// ═══════════════════════════════════════════════════════════════════════════════
// ──────────────── SPEC FILE ADDITIONS (for vex_spec_final.vex) ───────────────
// ═══════════════════════════════════════════════════════════════════════════════
//
//  The sections below are formatted as spec code demonstrations.
//  Add them to vex_spec_final.vex in the appropriate places.


// ──────────────────────────────────────────────────────────────────────────────
// SPEC SECTION B — NAME RESOLUTION DEMO
// ──────────────────────────────────────────────────────────────────────────────

var moduleGlobal: int = 1000

fn nameResolutionDemo() {
    var x := 1                        // Step 1 scope: local

    {
        var x := 2                    // shadows outer x in this scope
        io::println(x)                // 2 (inner scope)
    }
    io::println(x)                    // 1 (outer x restored)

    // Qualified module name required — bare names don't cross module boundaries
    io::println("must use io:: prefix")  // correct
    // println("hi")                  // COMPILE ERROR: undefined name `println`

    // Static method via type name (dot on TYPE, not instance)
    let origin := Point.origin()      // TypeName.staticMethod()
    // Point::origin()                // COMPILE ERROR: :: is for modules only

    // Module function via alias
    let sq := math::sqrt(16.0)        // module::fn

    // UFCS — free function callable as method if first param matches
    // fn double(x: int) -> int = x * 2
    // let n := 5.double()            // valid if double(int)->int exists in scope

    // Accessing module-level global from within a fn
    io::println(moduleGlobal)         // resolved at Step 4 (module top-level scope)
}

// ──────────────────────────────────────────────────────────────────────────────
// SPEC SECTION C — IMPORT VISIBILITY DEMO
// ──────────────────────────────────────────────────────────────────────────────

// pub: visible to any importer
pub fn publicFunction() -> str = "anyone can call me"

// priv: only callable inside THIS FILE
priv fn privateFunction() -> str = "only this file sees me"

// internal: callable by any file in the SAME project directory
internal fn internalFunction() -> str = "same directory only"

// Re-export pattern (there is no pub import — must wrap explicitly)
pub type ReExportedPoint = Point          // re-exports Point under this module's namespace
pub fn wrapSqrt(x: float64) -> float64 = math::sqrt(x)  // wrapper re-export

// Conditional platform import
#if OS == "linux" {
    import platform::linux as os_impl
} elif OS == "windows" {
    import platform::windows as os_impl
} else {
    import platform::generic as os_impl
}
// os_impl:: is available regardless of which branch was selected

// ──────────────────────────────────────────────────────────────────────────────
// SPEC SECTION D — GENERICS IMPLEMENTATION DEMO (with static vs dynamic dispatch)
// ──────────────────────────────────────────────────────────────────────────────

// STATIC DISPATCH — monomorphized at call site, zero overhead
fn printIfOrd<T: Ord + Printable>(a: T, b: T) {
    if a < b {
        a.println()
    } else {
        b.println()
    }
}
// Above generates separate compiled copies for each T used with it.

// DYNAMIC DISPATCH — single compiled function, vtable call overhead
fn printDrawable(shape: Drawable) {
    shape.draw()
    io::println(f"area = {shape.area():.2f}")
}
// Above compiles ONCE. shape is a fat pointer {data_ptr, vtable_ptr}.
// shape.draw() → indirect call through vtable.

fn genericsDispatchDemo() {
    // Static dispatch — no boxing, direct call (monomorphized)
    printIfOrd(3, 5)          // uses max_int specialization
    printIfOrd("abc", "xyz")  // uses max_str specialization

    // Dynamic dispatch — boxing occurs (struct → fat pointer)
    let c := Circle(3.0)
    printDrawable(c)          // Circle boxed into (data_ptr, vtable_ptr) at call site

    // Prefer static dispatch (generics) for performance-critical code.
    // Use dynamic dispatch (interface types) when heterogeneous collections needed.
    var shapes: []Drawable = [Circle(1.0), Circle(2.0), Circle(3.0)]
    for s in shapes { s.draw() }  // vtable call per iteration
}

// ──────────────────────────────────────────────────────────────────────────────
// SPEC SECTION E — ABI LAYOUT DEMO
// ──────────────────────────────────────────────────────────────────────────────

// Default layout — compiler may reorder for minimal padding
struct DefaultLayout {
    a: int8     // 1 byte
    b: int64    // 8 bytes → compiler WILL insert 7 bytes padding before b
    c: int32    // 4 bytes
    d: bool     // 1 byte
    // total with natural alignment and reorder: 24 bytes (a,b,c,d as declared)
    // with compiler reorder: b(8), c(4), a(1), d(1) + 2 padding = 16 bytes
}

// C-compatible layout — MUST match C struct exactly, no reordering
@packed
@derive(C_Layout)
struct CCompatLayout {
    a: int8     // offset 0, size 1
    b: int64    // offset 1 (@packed — no padding!)
    c: int32    // offset 9
    d: bool     // offset 13
    // total: 14 bytes (@packed, no padding anywhere)
}

// SIMD-aligned layout
@align(16)
struct Simd128 {
    x: float32
    y: float32
    z: float32
    w: float32
    // total: 16 bytes, alignment: 16 (for SSE/NEON loads)
}

// Enum layout demo — tagged union
enum TaggedUnionDemo {
    Small(x: int8)               // tag=0, data: 1 byte
    Medium(x: int32, y: int32)   // tag=1, data: 8 bytes
    Large(a: float64, b: float64, c: float64)  // tag=2, data: 24 bytes
    // Compiler layout: tag(4) + pad(4) + data(24) = 32 bytes total
    // All variants share the same 32-byte space
}

fn abiLayoutDemo() {
    // sizeof / alignof at comptime
    comptime const DEFAULT_SIZE := sizeof(DefaultLayout)
    comptime const C_SIZE       := sizeof(CCompatLayout)
    comptime const SIMD_ALIGN   := alignof(Simd128)

    io::println(f"DefaultLayout size: {DEFAULT_SIZE}")
    io::println(f"CCompatLayout size: {C_SIZE}")
    io::println(f"Simd128 alignment: {SIMD_ALIGN}")

    // str internal: fat pointer {ptr, len} = 16 bytes
    comptime const STR_SIZE := sizeof(str)        // 16
    // []T internal: fat pointer {ptr, len, cap} = 24 bytes
    comptime const LIST_SIZE := sizeof([]int)     // 24
}

// ──────────────────────────────────────────────────────────────────────────────
// SPEC SECTION F — ERROR HANDLING LOWERING DEMO
// ──────────────────────────────────────────────────────────────────────────────

// Implementing From<E> for cross-error-type propagation with ?
enum DbError {
    ConnectionFailed(msg: str)
    QueryFailed(sql: str, msg: str)
}

enum ServiceError {
    Database(inner: DbError)
    NotFound(id: int)
    Unauthorized
}

// Implementing From<DbError> for ServiceError enables `?` propagation
impl ServiceError {
    static fn from(e: DbError) -> ServiceError = ServiceError.Database(e)
}

fn queryUser(id: int) -> Result<User, DbError> {
    if id <= 0 { return Err(DbError.QueryFailed("SELECT ...", "invalid id")) }
    Ok(User("fetched", id))
}

fn getUser(id: int) -> Result<User, ServiceError> {
    // queryUser returns Result<User, DbError>
    // ? converts DbError → ServiceError automatically via From impl
    let user := queryUser(id)?
    if user.age < 0 { return Err(ServiceError.NotFound(id)) }
    Ok(user)
}

fn errorLoweringDemo() {
    // ? chains — each ? is a conditional branch to early return on error
    match getUser(42) {
        Ok(u)  => io::println(u.greet())
        Err(e) => match e {
            ServiceError.Database(db) => io::println(f"DB error: {db}")
            ServiceError.NotFound(id) => io::println(f"user {id} not found")
            ServiceError.Unauthorized => io::println("unauthorized")
        }
    }

    // T? propagation
    fn findPositive(nums: []int) -> int? {
        for n in nums {
            if n > 0 { return n }  // returns int?, not null
        }
        null
    }

    // Safe-call chaining on nullable
    var maybeList: []int? = [1, 2, 3]
    let first := maybeList?.find(|n| -> n > 1) ?? 0  // int, defaulted to 0

    // assert at comptime → compile error if false
    comptime const SAFE: bool = sizeof(int) == 8
    // comptime assert(SAFE, "int must be 8 bytes on this platform")
}

// ──────────────────────────────────────────────────────────────────────────────
// SPEC SECTION G — RUNTIME vs COMPILER BOUNDARY DEMO
// ──────────────────────────────────────────────────────────────────────────────

fn runtimeBoundaryDemo() {

    // ── Things the COMPILER guarantees (zero runtime cost) ───────────────────

    // 1. Borrow safety — no runtime check, compiler verified
    var data := [1, 2, 3, 4, 5]
    let view: &[]int = &data       // borrow — compiler ensures data outlives view
    io::println(f"len={view.len()}")
    // data.clear()                // COMPILE ERROR — data borrowed by view

    // 2. Move tracking — no runtime check
    var owned: ^str = mem::new("owned")
    let taken := move owned
    // io::println(*owned)         // COMPILE ERROR at compile time, not runtime

    // 3. Exhaustive match — no runtime "unhandled case" — compiler verified
    enum TwoVariants { A, B }
    let v := TwoVariants.A
    let result := match v {
        TwoVariants.A => "got A"
        TwoVariants.B => "got B"
        // no _ needed — compiler knows all variants covered
    }

    // ── Things the RUNTIME handles ────────────────────────────────────────────

    // 4. ARC refcount — runtime atomic operation on each clone/drop
    var s: ~str = mem::share("arc string")
    var s2 := s.clone()    // runtime: atomic increment refcount
    // s2 dropped here:    // runtime: atomic decrement; free if 0

    // 5. Bounds check — runtime only in debug builds (-O0)
    var arr := [10, 20, 30]
    // arr[5]              // runtime panic in debug; UNDEFINED in release (-O2)
    let safe := arr.get(5) ?? -1   // safe: returns null instead of panicking

    // 6. Async scheduling — runtime green thread scheduler
    let result2 := async::run(async fn() -> int {
        await async::sleep(10ms)
        42
    }())
    io::println(f"async result: {result2}")

    // 7. panic — runtime prints message + stack trace + calls abort()
    let x := 5
    assert(x > 0, "x must be positive")  // runtime check (unless comptime-known)

    // ── No GC — memory freed deterministically ────────────────────────────────

    // 8. ^T freed exactly when its scope ends — compiler inserts free call
    {
        var temp: ^[]int = mem::new([1, 2, 3])
        io::println(f"temp len={temp.len()}")
    }  // ← compiler inserts vex_free(temp) HERE, exactly at this brace

    // No GC pause. No GC thread. No GC metadata on heap objects.
}

