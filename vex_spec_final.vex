// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║          VEX LANGUAGE v4.0 — COMPLETE SPECIFICATION & SOURCE FILE           ║
// ║                                                                              ║
// ║  Compiled · Native · No GC · Safe · Clean Syntax                            ║
// ║  File = Module. No package declaration ever needed.                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝
//
// DESIGN GOALS:
//   1. Every symbol has ONE meaning — compiler-friendly, zero ambiguity
//   2. Shorter code = more readable (not more cryptic)
//   3. C-level power with Python-level clarity
//   4. Consistent rules from top to bottom — no exceptions

// ──────────────────────────────────────────────────────────────────────────────
// IMPORTS
// ──────────────────────────────────────────────────────────────────────────────
//
// THREE IMPORT FORMS:
//   import module_path                        ← Form 1: always use moduleName::item
//   import module_path as alias               ← Form 1: aliased, use alias::item
//   import module_path { name1, name2 }       ← Form 2: name1 and name2 usable directly
//   import module_path { name as localName }  ← Form 2: renamed direct access
//   import module_path { * }                  ← Form 3: all pub names usable directly
//
// Forms 2 and 3: direct name OR qualified moduleName::name — both always work.
// The last :: segment is ALWAYS a module filename (.vex or .vxl).
// You never write the extension — the compiler resolves it.
// NEVER: import std::io::println   ← no println.vex exists → COMPILE ERROR
// NEVER: import std::math::PI      ← no PI.vex exists → use: import std::math { PI }

import std::io
import std::math
import std::mem
import std::thread
import std::fs
import std::regex
import std::net
import std::time
import std::async
import std::ffi
import std::collections
import std::sync
import std::channel
import std::text

// ──────────────────────────────────────────────────────────────────────────────
// SECTION 1 — PRIMITIVE TYPES
// ──────────────────────────────────────────────────────────────────────────────
//
//  INTEGERS (signed):   int8  int16  int32  int64  int128
//                       int = int64 on 64-bit platforms
//  INTEGERS (unsigned): uint8  uint16  uint32  uint64  uint128
//                       uint = uint64 on 64-bit platforms
//  FLOATS:              float32  float64
//                       float = float64 (default)
//  TEXT:                char   (single Unicode codepoint, 4 bytes)
//                       str    (UTF-8 immutable string, see STR1–STR8 for rules)
//                       byte   = uint8 alias
//  LOGIC:               bool   (true / false)
//  SPECIAL:             void   (no value — return type only)
//                       any    (holds any type, checked at runtime)
//                       never  (function never returns — panic, infinite loop)
//                       type   (a type itself, for comptime)
//
//  POINTER TYPES:
//    *T     raw pointer      unsafe, no lifetime, no ownership
//    ^T     owned pointer    heap, single owner, freed at scope end
//    ~T     shared pointer   ref-counted heap, freed at refcount=0
//    &T     borrow ref       non-owning, lifetime-checked, always valid
//    &mut T mutable borrow   exclusive, non-owning, lifetime-checked
//    T?     nullable T       any type can be nullable
//
//  COMPOUND TYPES:
//    [N]T         fixed-size array (stack, N must be comptime)
//    []T          dynamic list (heap, grows automatically)
//    [K:V]        hash map (iteration order unspecified — see COL2)
//    (A, B, C)    tuple — fixed, ordered, mixed types
//    fn(A,B)->R   function type

// ──────────────────────────────────────────────────────────────────────────────
// SECTION 2 — VARIABLES
// ──────────────────────────────────────────────────────────────────────────────

fn variablesDemo() {

    // ── Declaration forms ─────────────────────────────────────────────────────
    var a: int = 10
    let b: str = "hello"
    const C: int = 100

    var x := 42
    let y := "world"
    let z := true

    // ── Multiple declaration ──────────────────────────────────────────────────
    var p, q, r := 1, 2, 3
    let m, n    := "foo", "bar"

    // ── Swap ──────────────────────────────────────────────────────────────────
    p, q = q, p

    // ── Nullable types ────────────────────────────────────────────────────────
    var maybeAge: int? = null
    var name: str  = "Alice"
    maybeAge = 25
    maybeAge = null

    let age  := maybeAge ?? 0
    let msg  := maybeAge?.toString() ?? "unknown"

    // ── Type casting ──────────────────────────────────────────────────────────
    let f   := float64(42)
    let i   := int(3.99)           // truncates to 3
    let s   := str(42)
    let num := int?("abc")         // returns null on failure
    let ok  := int("99")           // panics if invalid

    // Integer overflow — explicit operators available in all build modes
    var overflowDemo: int8 = 127
    let wrapped   := overflowDemo +% 1    // -128   (wrapping add)
    let saturated := overflowDemo +| 1    // 127    (saturating add, clamps at max)
    let wrapped2  := overflowDemo -% 200  // wrapping subtract

    // Checked cast (returns T? — null if value does not fit)
    let big: int64 = 999_999_999_999
    let small := int32.checked(big)       // int32? → null (does not fit)
    let trunc := int32.wrap(big)          // int32  → truncates to low 32 bits

    // ── Discard ───────────────────────────────────────────────────────────────
    let _ = expensiveButIgnored()

    // ── sizeof / typeof / alignof ─────────────────────────────────────────────
    let sz  := sizeof(int64)     // 8  (comptime)
    let al  := alignof(float64)  // 8  (comptime)
    let tn  := typeof(x)         // "int" (runtime string)
    let tid := typeid(x)         // unique integer ID of type (comptime)
}

fn expensiveButIgnored() -> int = 42


