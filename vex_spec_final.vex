// ──────────────────────────────────────────────────────────────────────────────
// SECTION 2-A — TYPE INFERENCE PATTERNS
// ──────────────────────────────────────────────────────────────────────────────

fn typeInferenceDemo() {

    // ── Literal defaults ──────────────────────────────────────────────────────
    var a := 42            // int   (int64 on 64-bit)
    var b := 3.14          // float (float64)
    var c := "hello"       // str
    var d := 'A'           // char
    var e := true          // bool

    // ── Suffix overrides default ──────────────────────────────────────────────
    var f := 42u8          // uint8
    var g := 42i16         // int16
    var h := 3.14f         // float32
    var j := 42L           // int64 (explicit, same as int on 64-bit)

    // ── Context-driven narrowing ──────────────────────────────────────────────
    var n: int8    = 100   // 100 treated as int8 (fits)
    var p: float32 = 1.0   // 1.0 treated as float32
    // var bad: int8 = 200  // COMPILE ERROR: 200 does not fit in int8

    // ── Empty collection requires context ────────────────────────────────────
    var list1: []int   = []              // OK — context provides element type
    var map1:  [str:int] = [:]           // OK — context provides key/value types
    var set1:  {}str   = {}              // OK — context provides element type
    // var list2 := []                   // COMPILE ERROR: cannot infer type

    // ── Lambda inference from call-site ──────────────────────────────────────
    let nums := [1, 2, 3, 4, 5]
    let doubled := nums.map(|x| -> x * 2)      // x inferred as int from []int
    let evens   := nums.filter(|x| -> x % 2 == 0)

    // Lambda must be typed when used standalone
    let f2: fn(int) -> int = |x| -> x + 1     // x inferred from fn type
    // let f3 := |x| -> x + 1                  // COMPILE ERROR: x type unknown

    // ── Generic inference ─────────────────────────────────────────────────────
    fn wrap<T>(x: T) -> []T = [x]
    let wi := wrap(42)            // T inferred as int → []int
    let ws := wrap("hello")       // T inferred as str → []str
    // let wm := wrap(maxOf(3, 5.0))  // COMPILE ERROR: conflicting T (int vs float64)
    let wm := wrap(maxOf<float64>(3.0, 5.0))  // explicit T resolves it → []float64

    // ── Null inference ────────────────────────────────────────────────────────
    var q: int? = null             // OK — T? context from annotation
    var r := (true ? 42 : null)    // r: int?  (int arm + null arm → int?)
    // var s := null                // COMPILE ERROR: cannot infer T in T?

    fn maybeInt(b2: bool) -> int? {
        if b2 { 42 } else { null }  // OK — return type int? is annotated
    }

    // ── Tuple inference ───────────────────────────────────────────────────────
    let t := (1, "hi", true)          // (int, str, bool)
    let (ta, tb, tc) := t             // ta:int, tb:str, tc:bool
    let (_, tb2, _) := t              // tb2:str (others discarded)

    // ── Match arm type unification ────────────────────────────────────────────
    let label := match ta {
        1 => "one"
        2 => "two"
        _ => "other"
    }                                 // label: str (all arms produce str)

    let maybeLabel: str? = match ta {
        1 => "one"               // str
        _ => null                // null — auto-lifted to str?
    }                            // maybeLabel: str?

    io::println(f"a={a} b={b} c={c} f={f} doubled={doubled}")
}


// ──────────────────────────────────────────────────────────────────────────────
// SECTION 3 — LITERALS
// ──────────────────────────────────────────────────────────────────────────────

fn literalsDemo() {
    // Integer literals
    let dec  := 1_000_000
    let hex  := 0xFF_A0
    let bin  := 0b1010_1100
    let oct  := 0o755
    let big  := 42L
    let u    := 42u
    let u8   := 255u8
    let i16  := 1000i16

    // Float literals
    let f1   := 3.14
    let f2   := 3.14f
    let f3   := 1.5e10
    let f4   := 0.001_5

    // String literals
    let s1   := "hello\nworld"
    let s2   := r"\n is not an escape"
    let s3   := f"Value is {dec}"
    let s4   := f"Math: {1 + 2}"
    let s5   := f"Hex: {hex:#x}"
    let s6   := `
        SELECT *
        FROM users
        WHERE active = true
    `

    // Char literal
    let c1   := 'A'
    let c2   := '\n'
    let c3   := '\u{1F600}'        // Unicode codepoint 😀

    // Bool
    let yes  := true
    let no   := false

    // Array / list
    let arr : [3]int  = [1, 2, 3]
    let list: []int   = [1, 2, 3, 4]

    // Map (iteration order unspecified per COL2)
    let scores: [str:int] = ["Alice": 95, "Bob": 87]

    // Tuple
    let pair  : (int, str)     = (42, "hello")
    let triple: (str,int,bool) = ("x", 1, true)

    // Null
    let nothing: str? = null

    // Duration literals
    let t1 := 1000ms
    let t2 := 5s
    let t3 := 500us
    let t4 := 100ns
}

