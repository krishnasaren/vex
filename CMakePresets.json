{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LLVM_DIR": "$env{LLVM_DIR}",
        "VEX_ENABLE_POLLY": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LLVM_DIR": "$env{LLVM_DIR}",
        "VEX_ENABLE_POLLY": "OFF"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "LLVM_DIR": "$env{LLVM_DIR}"
      }
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug",
      "inherits": "debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-x64.cmake"
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "inherits": "release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-x64.cmake"
    },
    {
      "name": "linux-arm64-debug",
      "displayName": "Linux ARM64 Debug",
      "inherits": "debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-arm64.cmake"
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS ARM64 Debug",
      "inherits": "debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/macos-arm64.cmake"
    },
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "inherits": "debug",
      "generator": "Visual Studio 17 2022",
      "toolchainFile": "${sourceDir}/cmake/toolchains/windows-x64.cmake"
    },
    {
      "name": "wasm-debug",
      "displayName": "WebAssembly Debug",
      "inherits": "debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/wasm.cmake"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "linux-x64-debug",
      "configurePreset": "linux-x64-debug"
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}